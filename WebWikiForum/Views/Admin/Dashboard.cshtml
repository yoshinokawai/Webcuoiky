@model IEnumerable<WebWikiForum.Models.Vtuber>
@{
    ViewData["Title"] = Localizer["Dash_Title"];
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full min-h-screen">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-black text-slate-900 dark:text-white flex items-center gap-3">
                <span class="material-symbols-outlined text-primary text-4xl">admin_panel_settings</span>
                @Localizer["Dash_Title"]
            </h1>
            <p class="text-slate-600 dark:text-slate-400 mt-2">@Localizer["Dash_Desc"]</p>
        </div>
        <div class="flex items-center gap-3 w-full md:w-auto">
            <div class="relative flex-1 md:flex-none">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                <input type="text" placeholder="@Localizer["Dash_Search_Placeholder"]" class="w-full md:w-72 pl-12 pr-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface-dark focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all" />
            </div>
            <a href="/Wiki/Create" class="flex items-center gap-2 px-5 py-3 bg-primary text-white font-bold rounded-xl shadow-lg shadow-primary/25 hover:bg-primary-dark hover:shadow-xl hover:shadow-primary/30 transition-all duration-300 whitespace-nowrap group">
                <span class="material-symbols-outlined text-xl group-hover:rotate-90 transition-transform duration-300">add</span>
                @Localizer["Dash_Btn_Add"]
            </a>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-8">
        <div class="bg-white dark:bg-surface-dark rounded-2xl border border-slate-200 dark:border-slate-800 p-5 flex items-center gap-4 shadow-sm">
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-primary text-2xl">groups</span>
            </div>
            <div>
                <p class="text-2xl font-black text-slate-900 dark:text-white">@(Model?.Count() ?? 0)</p>
                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">@Localizer["Dash_Stat_Total"]</p>
            </div>
        </div>
        <div class="bg-white dark:bg-surface-dark rounded-2xl border border-slate-200 dark:border-slate-800 p-5 flex items-center gap-4 shadow-sm">
            <div class="w-12 h-12 rounded-xl bg-green-50 flex items-center justify-center">
                <span class="material-symbols-outlined text-green-500 text-2xl">sensors</span>
            </div>
            <div>
                <p class="text-2xl font-black text-slate-900 dark:text-white">@(Model?.Count(v => v.Status == "Active") ?? 0)</p>
                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">@Localizer["Status_Active"]</p>
            </div>
        </div>
        <div class="bg-white dark:bg-surface-dark rounded-2xl border border-slate-200 dark:border-slate-800 p-5 flex items-center gap-4 shadow-sm">
            <div class="w-12 h-12 rounded-xl bg-orange-50 flex items-center justify-center">
                <span class="material-symbols-outlined text-orange-500 text-2xl">pending</span>
            </div>
            <div>
                <p class="text-2xl font-black text-slate-900 dark:text-white">@(Model?.Count(v => v.Status == "Pending") ?? 0)</p>
                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">@Localizer["Status_Pending"]</p>
            </div>
        </div>
        <div class="bg-white dark:bg-surface-dark rounded-2xl border border-slate-200 dark:border-slate-800 p-5 flex items-center gap-4 shadow-sm">
            <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center">
                <span class="material-symbols-outlined text-slate-500 text-2xl">history_edu</span>
            </div>
            <div>
                <p class="text-2xl font-black text-slate-900 dark:text-white">@(Model?.Count(v => v.Status == "Graduated" || v.Status == "Hiatus") ?? 0)</p>
                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Other / Hiatus</p>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="bg-white dark:bg-surface-dark rounded-3xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-700 text-sm uppercase text-slate-500 font-bold tracking-wider">
                        <th class="p-5 font-semibold">@Localizer["Dash_Col_Talent"]</th>
                        <th class="p-5 font-semibold">@Localizer["Dash_Col_Info"]</th>
                        <th class="p-5 font-semibold text-center">@Localizer["Dash_Col_Status"]</th>
                        <th class="p-5 font-semibold text-right">@Localizer["Dash_Col_Actions"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/20 transition-colors group">
                                <td class="p-5">
                                    <div class="flex items-center gap-4">
                                        <div class="w-14 h-14 rounded-2xl overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-600 shadow-sm">
                                            @if (!string.IsNullOrEmpty(item.AvatarUrl))
                                            {
                                                <img src="@item.AvatarUrl" alt="@item.Name" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                            }
                                            else
                                            {
                                                <span class="w-full h-full flex items-center justify-center text-slate-400 material-symbols-outlined text-2xl">person</span>
                                            }
                                        </div>
                                        <div>
                                            <div class="font-bold text-lg text-slate-900 dark:text-white">@item.Name</div>
                                            <div class="text-xs text-primary font-semibold flex items-center gap-1">
                                                <span class="material-symbols-outlined !text-[12px]">domain</span>
                                                @(item.Agency != null ? item.Agency.Name : Localizer["Dash_Independent"])
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-5">
                                    <div class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2 max-w-xs">
                                        @(string.IsNullOrEmpty(item.Lore) ? Localizer["Dash_No_History"].Value : item.Lore)
                                    </div>
                                    <div class="text-xs text-slate-500 mt-2 font-medium flex items-center gap-2">
                                        <span class="material-symbols-outlined !text-[14px]">calendar_month</span>
                                        @Localizer["Dash_Debuted"] @(item.DebutDate?.ToString("MMMM dd, yyyy") ?? Localizer["Dash_Unknown"].Value)
                                    </div>
                                </td>
                                <td class="p-5 text-center">
                                    @if (item.Status == "Active")
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold leading-none bg-green-100 text-green-700 border border-green-200 shadow-sm">
                                            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> @Localizer["Status_Active"]
                                        </span>
                                    }
                                    else if (item.Status == "Graduated")
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold leading-none bg-slate-100 text-slate-700 border border-slate-200 shadow-sm">
                                            <span class="w-1.5 h-1.5 rounded-full bg-slate-500"></span> @Localizer["Status_Graduated"]
                                        </span>
                                    }
                                    else if (item.Status == "Hiatus")
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold leading-none bg-amber-100 text-amber-700 border border-amber-200 shadow-sm">
                                            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> @Localizer["Status_Hiatus"]
                                        </span>
                                    }
                                    else if (item.Status == "Approved")
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold leading-none bg-blue-100 text-blue-700 border border-blue-200 shadow-sm">
                                            <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span> Approved
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold leading-none bg-orange-100 text-orange-700 border border-orange-200 shadow-sm">
                                            <span class="w-1.5 h-1.5 rounded-full bg-orange-500 animate-pulse"></span> @Localizer["Status_Pending"]
                                        </span>
                                    }
                                </td>
                                <td class="p-5 text-right whitespace-nowrap">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="/Wiki/Details/@item.Id" target="_blank" class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:text-primary hover:bg-primary/10 transition-colors tooltip" title="@Localizer["Dash_Action_View"]">
                                            <span class="material-symbols-outlined !text-[18px]">visibility</span>
                                        </a>

                                        <a href="/Wiki/Edit/@item.Id" class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:text-primary hover:bg-primary/10 transition-colors tooltip" title="@Localizer["Dash_Action_Edit"]">
                                            <span class="material-symbols-outlined !text-[18px]">edit</span>
                                        </a>

                                        @if (item.Status == "Pending" || item.Status == "Approved")
                                        {
                                            <div class="flex items-center gap-1 p-1 bg-slate-100 dark:bg-slate-800 rounded-xl">
                                                <form asp-controller="Admin" asp-action="Approve" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <input type="hidden" name="status" value="Active" />
                                                    <button type="submit" class="w-8 h-8 flex items-center justify-center rounded-lg text-green-600 hover:bg-green-100 transition-colors" title="Set Active">
                                                        <span class="material-symbols-outlined !text-[18px]">check_circle</span>
                                                    </button>
                                                </form>
                                                <form asp-controller="Admin" asp-action="Approve" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <input type="hidden" name="status" value="Hiatus" />
                                                    <button type="submit" class="w-8 h-8 flex items-center justify-center rounded-lg text-amber-600 hover:bg-amber-100 transition-colors" title="Set Hiatus">
                                                        <span class="material-symbols-outlined !text-[18px]">timer</span>
                                                    </button>
                                                </form>
                                                <form asp-controller="Admin" asp-action="Approve" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <input type="hidden" name="status" value="Graduated" />
                                                    <button type="submit" class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-600 hover:bg-slate-200 transition-colors" title="Set Graduated">
                                                        <span class="material-symbols-outlined !text-[18px]">logout</span>
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                        else
                                        {
                                            <!-- Allow changing status even if already set -->
                                            <div class="flex items-center gap-1">
                                                 <form asp-controller="Admin" asp-action="Approve" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <input type="hidden" name="status" value="Active" />
                                                    <button type="submit" class="w-8 h-8 flex items-center justify-center rounded-lg @(item.Status == "Active" ? "bg-green-500 text-white" : "text-green-600 hover:bg-green-50") transition-colors" title="Active">
                                                        <span class="material-symbols-outlined !text-[18px]">check_circle</span>
                                                    </button>
                                                </form>
                                                <form asp-controller="Admin" asp-action="Approve" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <input type="hidden" name="status" value="Graduated" />
                                                    <button type="submit" class="w-8 h-8 flex items-center justify-center rounded-lg @(item.Status == "Graduated" ? "bg-slate-500 text-white" : "text-slate-600 hover:bg-slate-50") transition-colors" title="Graduated">
                                                        <span class="material-symbols-outlined !text-[18px]">logout</span>
                                                    </button>
                                                </form>
                                            </div>
                                        }

                                        <form asp-controller="Admin" asp-action="Delete" method="post" style="display:inline;" onsubmit="event.preventDefault(); window.showConfirmModal({ title: '@Localizer["Dash_Action_Delete"]', message: '@string.Format(Localizer["Dash_Confirm_Delete"].Value, item.Name)', onConfirm: () => this.submit() });">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="w-9 h-9 flex items-center justify-center rounded-xl bg-red-50 text-red-600 hover:text-white hover:bg-red-500 transition-colors shadow-sm" title="@Localizer["Dash_Action_Delete"]">
                                                <span class="material-symbols-outlined !text-[18px]">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="p-12 text-center text-slate-500">
                                <div class="flex flex-col items-center justify-center gap-4">
                                    <span class="material-symbols-outlined text-5xl text-slate-300">hourglass_empty</span>
                                    <p class="text-lg font-medium">@Localizer["Dash_Empty_Title"]</p>
                                    <p class="text-sm">@Localizer["Dash_Empty_Desc"]</p>
                                    <a href="/Wiki/Create" class="mt-2 inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-bold rounded-xl shadow-lg shadow-primary/25 hover:bg-primary-dark transition-all">
                                        <span class="material-symbols-outlined text-xl">add</span>
                                        @Localizer["Dash_Empty_Btn"]
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
