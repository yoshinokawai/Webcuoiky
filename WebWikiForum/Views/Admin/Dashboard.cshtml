@model WebWikiForum.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = Localizer["Dash_Title"];
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full min-h-screen" x-data="{ activeTab: 'vtubers' }">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-black text-slate-900 dark:text-white flex items-center gap-3">
                <span class="material-symbols-outlined text-primary text-4xl">admin_panel_settings</span>
                @Localizer["Dash_Title"]
            </h1>
            <p class="text-slate-600 dark:text-slate-400 mt-2">@Localizer["Dash_Desc"]</p>
        </div>
        <div class="flex items-center gap-3 w-full md:w-auto">
            <template x-if="activeTab === 'vtubers'">
                <a href="/Wiki/Create" class="flex items-center gap-2 px-5 py-3 bg-primary text-white font-bold rounded-xl shadow-lg shadow-primary/25 hover:bg-primary-dark hover:shadow-xl hover:shadow-primary/30 transition-all duration-300 whitespace-nowrap group">
                    <span class="material-symbols-outlined text-xl group-hover:rotate-90 transition-transform duration-300">add</span>
                    @Localizer["Dash_Btn_Add"]
                </a>
            </template>
            <template x-if="activeTab === 'agencies'">
                <a href="/Wiki/CreateAgency" class="flex items-center gap-2 px-5 py-3 bg-indigo-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-600/25 hover:bg-indigo-700 hover:shadow-xl hover:shadow-indigo-600/30 transition-all duration-300 whitespace-nowrap group">
                    <span class="material-symbols-outlined text-xl group-hover:rotate-90 transition-transform duration-300">domain_add</span>
                    Add Agency
                </a>
            </template>
            <template x-if="activeTab === 'events'">
                <a href="/Wiki/CreateEvent" class="flex items-center gap-2 px-5 py-3 bg-amber-500 text-white font-bold rounded-xl shadow-lg shadow-amber-500/25 hover:bg-amber-600 hover:shadow-xl hover:shadow-amber-500/30 transition-all duration-300 whitespace-nowrap group">
                    <span class="material-symbols-outlined text-xl group-hover:rotate-90 transition-transform duration-300">add_circle</span>
                    Add Event
                </a>
            </template>
        </div>
    </div>

    <!-- Tabs Navigation -->
    <div class="flex p-1 bg-slate-100 dark:bg-slate-800/50 rounded-2xl mb-8 w-full md:w-fit">
        <button 
            @@click="activeTab = 'vtubers'" 
            :class="activeTab === 'vtubers' ? 'bg-white dark:bg-slate-700 text-primary shadow-sm' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400'"
            class="flex items-center gap-2 px-8 py-2.5 rounded-xl font-bold text-sm transition-all duration-200">
            <span class="material-symbols-outlined text-[18px]">groups</span>
            VTubers
            <span class="ml-1.5 px-2 py-0.5 rounded-md bg-slate-100 dark:bg-slate-800 text-[10px]" :class="activeTab === 'vtubers' ? 'bg-primary/10 text-primary' : ''">@(Model.Vtubers?.Count() ?? 0)</span>
        </button>
        <button 
            @@click="activeTab = 'agencies'" 
            :class="activeTab === 'agencies' ? 'bg-white dark:bg-slate-700 text-indigo-600 shadow-sm' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400'"
            class="flex items-center gap-2 px-8 py-2.5 rounded-xl font-bold text-sm transition-all duration-200">
            <span class="material-symbols-outlined text-[18px]">domain</span>
            Agencies
            <span class="ml-1.5 px-2 py-0.5 rounded-md bg-slate-100 dark:bg-slate-800 text-[10px]" :class="activeTab === 'agencies' ? 'bg-indigo-600/10 text-indigo-600' : ''">@(Model.Agencies?.Count() ?? 0)</span>
        </button>
        <button 
            @@click="activeTab = 'events'" 
            :class="activeTab === 'events' ? 'bg-white dark:bg-slate-700 text-amber-500 shadow-sm' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400'"
            class="flex items-center gap-2 px-8 py-2.5 rounded-xl font-bold text-sm transition-all duration-200">
            <span class="material-symbols-outlined text-[18px]">newspaper</span>
            Events & News
            <span class="ml-1.5 px-2 py-0.5 rounded-md bg-slate-100 dark:bg-slate-800 text-[10px]" :class="activeTab === 'events' ? 'bg-amber-500/10 text-amber-500' : ''">@(Model.News?.Count() ?? 0)</span>
        </button>
    </div>

    <!-- VTubers Tab Content -->
    <div x-show="activeTab === 'vtubers'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0">
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-8">
            <div class="bg-white dark:bg-surface-dark rounded-2xl border border-slate-200 dark:border-slate-800 p-5 flex items-center gap-4 shadow-sm">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary text-2xl">groups</span>
                </div>
                <div>
                    <p class="text-2xl font-black text-slate-900 dark:text-white">@(Model.Vtubers?.Count() ?? 0)</p>
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">@Localizer["Dash_Stat_Total"]</p>
                </div>
            </div>
            <div class="bg-white dark:bg-surface-dark rounded-2xl border border-slate-200 dark:border-slate-800 p-5 flex items-center gap-4 shadow-sm">
                <div class="w-12 h-12 rounded-xl bg-green-50 flex items-center justify-center">
                    <span class="material-symbols-outlined text-green-500 text-2xl">sensors</span>
                </div>
                <div>
                    <p class="text-2xl font-black text-slate-900 dark:text-white">@(Model.Vtubers?.Count(v => v.Status == "Active" || v.Status == "Approved") ?? 0)</p>
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">@Localizer["Status_Active"]</p>
                </div>
            </div>
            <!-- ... other stats ... -->
        </div>

        <div class="bg-white dark:bg-surface-dark rounded-3xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-700 text-sm uppercase text-slate-500 font-bold tracking-wider">
                            <th class="p-5 font-semibold">@Localizer["Dash_Col_Talent"]</th>
                            <th class="p-5 font-semibold">@Localizer["Dash_Col_Info"]</th>
                            <th class="p-5 font-semibold text-center">@Localizer["Dash_Col_Status"]</th>
                            <th class="p-5 font-semibold text-right">@Localizer["Dash_Col_Actions"]</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                        @foreach (var item in Model.Vtubers)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/20 transition-colors group">
                                <td class="p-5">
                                    <div class="flex items-center gap-4">
                                        <div class="w-14 h-14 rounded-2xl overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-600 shadow-sm">
                                            @if (!string.IsNullOrEmpty(item.AvatarUrl))
                                            {
                                                <img src="@item.AvatarUrl" alt="@item.Name" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                            }
                                            else
                                            {
                                                <div class="w-full h-full flex items-center justify-center text-primary font-bold">@item.Name.Substring(0, 1)</div>
                                            }
                                        </div>
                                        <div>
                                            <div class="font-bold text-lg text-slate-900 dark:text-white">@item.Name</div>
                                            <div class="text-xs text-primary font-semibold flex items-center gap-1">
                                                <span class="material-symbols-outlined !text-[12px]">domain</span>
                                                @(item.Agency != null ? item.Agency.Name : Localizer["Dash_Independent"])
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-5 text-sm">
                                    <div class="flex flex-col gap-1">
                                        <div class="flex items-center gap-1.5 text-slate-700 dark:text-slate-300 font-medium whitespace-nowrap">
                                            <span class="material-symbols-outlined text-[16px] text-slate-400">public</span>
                                            @item.Region
                                        </div>
                                        <div class="flex items-center gap-1.5 text-slate-500 dark:text-slate-400 text-xs whitespace-nowrap">
                                            <span class="material-symbols-outlined text-[16px]">calendar_month</span>
                                            @(item.DebutDate.HasValue ? item.DebutDate.Value.ToString("MMM dd, yyyy") : "N/A")
                                        </div>
                                    </div>
                                </td>
                                <td class="p-5 text-center">
                                    <div x-data="{ open: false }" class="relative flex justify-center">
                                        <button @@click="open = !open" type="button" class="px-3 py-1 rounded-full text-xs font-black transition-all hover:scale-105 @(item.Status == "Active" ? "bg-green-100 text-green-700" : item.Status == "Graduated" ? "bg-slate-100 text-slate-700" : "bg-orange-100 text-orange-700") flex items-center gap-1">
                                            @item.Status
                                            <span class="material-symbols-outlined text-[14px]">arrow_drop_down</span>
                                        </button>
                                        <div x-show="open" @@click.away="open = false" x-cloak class="absolute top-full mt-2 w-32 bg-white dark:bg-slate-800 rounded-xl shadow-xl border border-slate-100 dark:border-slate-700 z-50 overflow-hidden py-1">
                                            <form asp-controller="Admin" asp-action="Approve" method="post">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" name="status" value="Active" class="w-full px-4 py-2 text-left text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-700 text-green-600">Active</button>
                                                <button type="submit" name="status" value="Graduated" class="w-full px-4 py-2 text-left text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-600">Graduated</button>
                                                <button type="submit" name="status" value="Hiatus" class="w-full px-4 py-2 text-left text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-700 text-orange-600">Hiatus</button>
                                            </form>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-5 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="/Wiki/Details/@item.Id" target="_blank" class="p-2 hover:bg-primary/10 text-slate-600 hover:text-primary rounded-lg transition-colors" title="View Profile">
                                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                                        </a>
                                        <a href="/Wiki/Edit/@item.Id" class="p-2 hover:bg-primary/10 text-slate-600 hover:text-primary rounded-lg transition-colors">
                                            <span class="material-symbols-outlined text-[20px]">edit</span>
                                        </a>
                                        <form asp-controller="Admin" asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete @item.Name?')">
                                            <button type="submit" class="p-2 hover:bg-red-50 text-slate-600 hover:text-red-600 rounded-lg transition-colors">
                                                <span class="material-symbols-outlined text-[20px]">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Agencies Tab Content -->
    <div x-show="activeTab === 'agencies'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" x-cloak>
        <div class="bg-white dark:bg-surface-dark rounded-3xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-700 text-sm uppercase text-slate-500 font-bold tracking-wider">
                            <th class="p-5 font-semibold">Agency</th>
                            <th class="p-5 font-semibold">Region & Focus</th>
                            <th class="p-5 font-semibold text-center">Status</th>
                            <th class="p-5 font-semibold text-center">Talents</th>
                            <th class="p-5 font-semibold text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                        @if (Model.Agencies != null && Model.Agencies.Any())
                        {
                            foreach (var agency in Model.Agencies)
                            {
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/20 transition-colors group">
                                    <td class="p-5">
                                        <div class="flex items-center gap-4">
                                            <div class="w-14 h-14 rounded-2xl overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-600 shadow-sm">
                                                @if (!string.IsNullOrEmpty(agency.LogoUrl))
                                                {
                                                    <img src="@agency.LogoUrl" alt="@agency.Name" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                                }
                                                else
                                                {
                                                    <div class="w-full h-full flex items-center justify-center text-primary font-bold">@agency.Name.Substring(0, 1)</div>
                                                }
                                            </div>
                                            <div>
                                                <div class="font-bold text-lg text-slate-900 dark:text-white">@agency.Name</div>
                                                <div class="text-[10px] text-slate-500 uppercase font-bold tracking-widest mt-0.5 truncate max-w-[150px]">
                                                    @agency.Description
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="p-5 text-sm">
                                        <div class="flex flex-col gap-1">
                                            <span class="inline-flex items-center gap-1.5 text-slate-700 dark:text-slate-300 font-medium">
                                                <span class="material-symbols-outlined text-[16px] text-slate-400">location_on</span>
                                                @agency.Region
                                            </span>
                                            <span class="inline-flex items-center gap-1.5 text-slate-500 dark:text-slate-400">
                                                <span class="material-symbols-outlined text-[16px]">stars</span>
                                                @agency.Focus
                                            </span>
                                        </div>
                                    </td>
                                    <td class="p-5 text-center">
                                        <div x-data="{ open: false }" class="relative flex justify-center">
                                            <button @@click="open = !open" type="button" class="px-3 py-1 rounded-full text-xs font-black transition-all hover:scale-105 @(agency.Status == "Active" ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700") flex items-center gap-1">
                                                @(agency.Status ?? "Active")
                                                <span class="material-symbols-outlined text-[14px]">arrow_drop_down</span>
                                            </button>
                                            <div x-show="open" @@click.away="open = false" x-cloak class="absolute top-full mt-2 w-32 bg-white dark:bg-slate-800 rounded-xl shadow-xl border border-slate-100 dark:border-slate-700 z-50 overflow-hidden py-1">
                                                <form asp-controller="Admin" asp-action="ApproveAgency" method="post">
                                                    <input type="hidden" name="id" value="@agency.Id" />
                                                    <button type="submit" name="status" value="Active" class="w-full px-4 py-2 text-left text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-700 text-green-600">Active</button>
                                                    <button type="submit" name="status" value="Defunct" class="w-full px-4 py-2 text-left text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-700 text-red-600">Defunct</button>
                                                </form>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="p-5 text-center">
                                        <div class="inline-flex flex-col items-center">
                                            <span class="text-xl font-black text-slate-900 dark:text-white">@agency.TalentCount</span>
                                            <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Profiles</span>
                                        </div>
                                    </td>
                                    <td class="p-5 text-right whitespace-nowrap">
                                        <div class="flex items-center justify-end gap-2">
                                            <a href="/Wiki/Agencies?searchTerm=@agency.Name" target="_blank" class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:text-indigo-600 hover:bg-indigo-50 transition-colors">
                                                <span class="material-symbols-outlined text-[18px]">visibility</span>
                                            </a>
                                            <a href="/Wiki/EditAgency/@agency.Id" class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:text-indigo-600 hover:bg-indigo-50 transition-colors">
                                                <span class="material-symbols-outlined text-[18px]">edit</span>
                                            </a>
                                            <form asp-controller="Wiki" asp-action="DeleteAgency" asp-route-id="@agency.Id" method="post" onsubmit="return confirm('Delete agency @agency.Name?')">
                                                <button type="submit" class="w-9 h-9 flex items-center justify-center rounded-xl bg-red-50 text-red-600 hover:text-white hover:bg-red-500 transition-colors shadow-sm">
                                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="p-10 text-center text-slate-500 italic">No agencies found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Events Tab Content -->
    <div x-show="activeTab === 'events'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" x-cloak>
        <div class="bg-white dark:bg-surface-dark rounded-3xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-700 text-sm uppercase text-slate-500 font-bold tracking-wider">
                            <th class="p-5 font-semibold">Event / Title</th>
                            <th class="p-5 font-semibold">Category</th>
                            <th class="p-5 font-semibold">Date</th>
                            <th class="p-5 font-semibold">Featured</th>
                            <th class="p-5 font-semibold text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                        @if (Model.News != null && Model.News.Any())
                        {
                            foreach (var item in Model.News)
                            {
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/20 transition-colors group">
                                    <td class="p-5">
                                        <div class="flex items-center gap-4">
                                            <div class="w-16 h-10 rounded-lg overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-600 shadow-sm relative">
                                                <img src="@item.ImageUrl" alt="@item.Title" class="w-full h-full object-cover" />
                                            </div>
                                            <div class="font-bold text-slate-900 dark:text-white max-w-md truncate">@item.Title</div>
                                        </div>
                                    </td>
                                    <td class="p-5">
                                        @{
                                            var badgeColor = item.Type switch {
                                                "Event" => "bg-purple-100 text-purple-700",
                                                "Debut" => "bg-blue-100 text-blue-700",
                                                "Music" => "bg-green-100 text-green-700",
                                                "ASMR" => "bg-pink-100 text-pink-700",
                                                "Gaming" => "bg-orange-100 text-orange-700",
                                                _ => "bg-slate-100 text-slate-700"
                                            };
                                        }
                                        <span class="px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-wider @badgeColor">@item.Type</span>
                                    </td>
                                    <td class="p-5 text-sm text-slate-500 dark:text-slate-400 font-medium">
                                        @item.PublishDate.ToString("MMM dd, yyyy")
                                    </td>
                                    <td class="p-5 text-center">
                                        @if (item.IsFeatured)
                                        {
                                            <span class="material-symbols-outlined text-amber-400 fill-amber-400">star</span>
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-slate-300">star</span>
                                        }
                                    </td>
                                    <td class="p-5 text-right">
                                        <div class="flex items-center justify-end gap-2">
                                            <a href="/Wiki/EditEvent/@item.Id" class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:text-amber-500 hover:bg-amber-50 transition-colors">
                                                <span class="material-symbols-outlined text-[18px]">edit</span>
                                            </a>
                                            <form asp-controller="Wiki" asp-action="DeleteEvent" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete @item.Title?')">
                                                <button type="submit" class="w-9 h-9 flex items-center justify-center rounded-xl bg-red-50 text-red-600 hover:text-white hover:bg-red-500 transition-colors shadow-sm">
                                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="p-10 text-center text-slate-500 italic">No news items found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
}
