@model WebWikiForum.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = Localizer["Dash_Title"];
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full min-h-screen" x-data="{ activeTab: 'vtubers', assignModal: { open: false, userId: 0, username: '', assignments: [] } }">
    <!-- Phần tiêu đề -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-black text-slate-900 dark:text-white flex items-center gap-3">
                <span class="material-symbols-outlined text-primary text-4xl">admin_panel_settings</span>
                @Localizer["Dash_Title"]
            </h1>
            <p class="text-slate-600 dark:text-slate-400 mt-2">@Localizer["Dash_Desc"]</p>
        </div>
        <div class="flex items-center gap-3 w-full md:w-auto">
            <!-- Lối tắt đến Chat Sessions -->
            <a href="/Admin/ChatSessions" class="flex items-center gap-2 px-4 py-2.5 bg-amber-500 text-white font-bold rounded-xl shadow-lg shadow-amber-500/25 hover:bg-amber-600 transition-all duration-300 whitespace-nowrap text-sm">
                <span class="material-symbols-outlined text-[18px]">chat</span>
                @Localizer["Dash_Btn_Chat"]
            </a>
            <template x-if="activeTab === 'vtubers'">
                <a href="/Wiki/Create" class="flex items-center gap-2 px-5 py-3 bg-primary text-white font-bold rounded-xl shadow-lg shadow-primary/25 hover:bg-primary-dark hover:shadow-xl hover:shadow-primary/30 transition-all duration-300 whitespace-nowrap group">
                    <span class="material-symbols-outlined text-xl group-hover:rotate-90 transition-transform duration-300">add</span>
                    @Localizer["Dash_Btn_Add"]
                </a>
            </template>
            <template x-if="activeTab === 'agencies'">
                <a href="/Wiki/CreateAgency" class="flex items-center gap-2 px-5 py-3 bg-indigo-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-600/25 hover:bg-indigo-700 hover:shadow-xl hover:shadow-indigo-600/30 transition-all duration-300 whitespace-nowrap group">
                    <span class="material-symbols-outlined text-xl group-hover:rotate-90 transition-transform duration-300">domain_add</span>
                    @Localizer["Dash_Btn_AddAgency"]
                </a>
            </template>
            <template x-if="activeTab === 'events'">
                <a href="/Wiki/CreateEvent" class="flex items-center gap-2 px-5 py-3 bg-amber-500 text-white font-bold rounded-xl shadow-lg shadow-amber-500/25 hover:bg-amber-600 hover:shadow-xl hover:shadow-amber-500/30 transition-all duration-300 whitespace-nowrap group">
                    <span class="material-symbols-outlined text-xl group-hover:rotate-90 transition-transform duration-300">add_circle</span>
                    @Localizer["Dash_Btn_AddEvent"]
                </a>
            </template>
            <!-- Tab users: không hiện nút thêm, chỉ quản lý -->
        </div>
    </div>


    <!-- Thanh điều hướng Tab -->
    <div class="flex p-1 bg-slate-100 dark:bg-slate-800/50 rounded-2xl mb-8 w-full md:w-fit">
        <button 
            @@click="activeTab = 'vtubers'" 
            :class="activeTab === 'vtubers' ? 'bg-white dark:bg-slate-700 text-primary shadow-sm' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400'"
            class="flex items-center gap-2 px-8 py-2.5 rounded-xl font-bold text-sm transition-all duration-200">
            <span class="material-symbols-outlined text-[18px]">groups</span>
            @Localizer["Dash_Tab_VTubers"]
            <span class="ml-1.5 px-2 py-0.5 rounded-md bg-slate-100 dark:bg-slate-800 text-[10px]" :class="activeTab === 'vtubers' ? 'bg-primary/10 text-primary' : ''">@(Model.Vtubers?.Count() ?? 0)</span>
        </button>
        <button 
            @@click="activeTab = 'agencies'" 
            :class="activeTab === 'agencies' ? 'bg-white dark:bg-slate-700 text-indigo-600 shadow-sm' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400'"
            class="flex items-center gap-2 px-8 py-2.5 rounded-xl font-bold text-sm transition-all duration-200">
            <span class="material-symbols-outlined text-[18px]">domain</span>
            @Localizer["Dash_Tab_Agencies"]
            <span class="ml-1.5 px-2 py-0.5 rounded-md bg-slate-100 dark:bg-slate-800 text-[10px]" :class="activeTab === 'agencies' ? 'bg-indigo-600/10 text-indigo-600' : ''">@(Model.Agencies?.Count() ?? 0)</span>
        </button>
        <button 
            @@click="activeTab = 'events'" 
            :class="activeTab === 'events' ? 'bg-white dark:bg-slate-700 text-amber-500 shadow-sm' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400'"
            class="flex items-center gap-2 px-8 py-2.5 rounded-xl font-bold text-sm transition-all duration-200">
            <span class="material-symbols-outlined text-[18px]">newspaper</span>
            @Localizer["Dash_Tab_Events"]
            <span class="ml-1.5 px-2 py-0.5 rounded-md bg-slate-100 dark:bg-slate-800 text-[10px]" :class="activeTab === 'events' ? 'bg-amber-500/10 text-amber-500' : ''">@(Model.News?.Count() ?? 0)</span>
        </button>
        <!-- Tab Người dùng -->
        <button 
            @@click="activeTab = 'users'" 
            :class="activeTab === 'users' ? 'bg-white dark:bg-slate-700 text-emerald-500 shadow-sm' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400'"
            class="flex items-center gap-2 px-8 py-2.5 rounded-xl font-bold text-sm transition-all duration-200">
            <span class="material-symbols-outlined text-[18px]">manage_accounts</span>
            @Localizer["Dash_Tab_Users"]
            <span class="ml-1.5 px-2 py-0.5 rounded-md bg-slate-100 dark:bg-slate-800 text-[10px]" :class="activeTab === 'users' ? 'bg-emerald-500/10 text-emerald-500' : ''">@(Model.Users?.Count() ?? 0)</span>
        </button>
    </div>

    <!-- Nội dung Tab VTubers -->
    <div x-show="activeTab === 'vtubers'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0">
        <!-- Thẻ thống kê -->
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-8">
            <div class="bg-white dark:bg-surface-dark rounded-2xl border border-slate-200 dark:border-slate-800 p-5 flex items-center gap-4 shadow-sm">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary text-2xl">groups</span>
                </div>
                <div>
                    <p class="text-2xl font-black text-slate-900 dark:text-white">@(Model.Vtubers?.Count() ?? 0)</p>
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">@Localizer["Dash_Stat_Total"]</p>
                </div>
            </div>
            <div class="bg-white dark:bg-surface-dark rounded-2xl border border-slate-200 dark:border-slate-800 p-5 flex items-center gap-4 shadow-sm">
                <div class="w-12 h-12 rounded-xl bg-green-50 flex items-center justify-center">
                    <span class="material-symbols-outlined text-green-500 text-2xl">sensors</span>
                </div>
                <div>
                    <p class="text-2xl font-black text-slate-900 dark:text-white">@(Model.Vtubers?.Count(v => v.Status == "Active" || v.Status == "Approved") ?? 0)</p>
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">@Localizer["Status_Active"]</p>
                </div>
            </div>
            <!-- ... thống kê khác ... -->
        </div>

        <div class="bg-white dark:bg-surface-dark rounded-3xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-700 text-sm uppercase text-slate-500 font-bold tracking-wider">
                            <th class="p-5 font-semibold">@Localizer["Dash_Col_Talent"]</th>
                            <th class="p-5 font-semibold">@Localizer["Dash_Col_Info"]</th>
                            <th class="p-5 font-semibold text-center">@Localizer["Dash_Col_Status"]</th>
                            <th class="p-5 font-semibold text-right">@Localizer["Dash_Col_Actions"]</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                        @if (Model.Vtubers != null)
                        {
                            @foreach (var item in Model.Vtubers)
                            {
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/20 transition-colors group">
                                <td class="p-5">
                                    <div class="flex items-center gap-4">
                                        <div class="w-14 h-14 rounded-2xl overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-600 shadow-sm">
                                            @if (!string.IsNullOrEmpty(item.AvatarUrl))
                                            {
                                                <img src="@item.AvatarUrl" alt="@item.Name" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                            }
                                            else
                                            {
                                                <div class="w-full h-full flex items-center justify-center text-primary font-bold">@(!string.IsNullOrEmpty(item.Name) ? item.Name.Substring(0, 1) : "?")</div>
                                            }
                                        </div>
                                        <div>
                                            <div class="font-bold text-lg text-slate-900 dark:text-white">@item.Name</div>
                                            <div class="text-xs text-primary font-semibold flex items-center gap-1">
                                                <span class="material-symbols-outlined !text-[12px]">domain</span>
                                                @(item.Agency != null ? item.Agency.Name : Localizer["Dash_Independent"])
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-5 text-sm">
                                    <div class="flex flex-col gap-1">
                                        <div class="flex items-center gap-1.5 text-slate-700 dark:text-slate-300 font-medium whitespace-nowrap">
                                            <span class="material-symbols-outlined text-[16px] text-slate-400">public</span>
                                            @Localizer["Region_" + item.Region]
                                        </div>
                                        <div class="flex items-center gap-1.5 text-slate-500 dark:text-slate-400 text-xs whitespace-nowrap">
                                            <span class="material-symbols-outlined text-[16px]">calendar_month</span>
                                            @(item.DebutDate.HasValue ? item.DebutDate.Value.ToString("MMM dd, yyyy") : "N/A")
                                        </div>
                                    </div>
                                </td>
                                <td class="p-5 text-center">
                                    <div x-data="{ open: false }" class="relative flex justify-center">
                                        <button @@click="open = !open" type="button" class="px-3 py-1 rounded-full text-xs font-black transition-all hover:scale-105 @(item.Status == "Active" ? "bg-green-100 text-green-700" : item.Status == "Graduated" ? "bg-slate-100 text-slate-700" : "bg-orange-100 text-orange-700") flex items-center gap-1">
                                            @Localizer["Status_" + item.Status]
                                            <span class="material-symbols-outlined text-[14px]">arrow_drop_down</span>
                                        </button>
                                        <div x-show="open" @@click.away="open = false" x-cloak class="absolute top-full mt-2 w-32 bg-white dark:bg-slate-800 rounded-xl shadow-xl border border-slate-100 dark:border-slate-700 z-50 overflow-hidden py-1">
                                            <form asp-controller="Admin" asp-action="Approve" method="post">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" name="status" value="Active" class="w-full px-4 py-2 text-left text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-700 text-green-600">Active</button>
                                                <button type="submit" name="status" value="Graduated" class="w-full px-4 py-2 text-left text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-600">Graduated</button>
                                                <button type="submit" name="status" value="Hiatus" class="w-full px-4 py-2 text-left text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-700 text-orange-600">Hiatus</button>
                                            </form>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-5 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="/Wiki/Details/@item.Id" target="_blank" class="p-2 hover:bg-primary/10 text-slate-600 hover:text-primary rounded-lg transition-colors" title="View Profile">
                                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                                        </a>
                                        <a href="/Wiki/Edit/@item.Id" class="p-2 hover:bg-primary/10 text-slate-600 hover:text-primary rounded-lg transition-colors">
                                            <span class="material-symbols-outlined text-[20px]">edit</span>
                                        </a>
                                        <form id="delete-vtuber-@item.Id" asp-controller="Admin" asp-action="Delete" asp-route-id="@item.Id" method="post">
                                            <button type="button" onclick="confirmDelete('vtuber-@item.Id', '@Html.Raw(item.Name.Replace("'", "\\'"))')" class="p-2 hover:bg-red-50 text-slate-600 hover:text-red-600 rounded-lg transition-colors">
                                                <span class="material-symbols-outlined text-[20px]">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="p-10 text-center text-slate-500 italic">@Localizer["Dash_No_VTubers"]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Nội dung Tab Agencies -->
    <div x-show="activeTab === 'agencies'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" x-cloak>
        <div class="bg-white dark:bg-surface-dark rounded-3xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-700 text-sm uppercase text-slate-500 font-bold tracking-wider">
                            <th class="p-5 font-semibold">@Localizer["Dash_Col_Agency"]</th>
                            <th class="p-5 font-semibold">@Localizer["Dash_Col_RegionFocus"]</th>
                            <th class="p-5 font-semibold text-center">@Localizer["Dash_Col_Status"]</th>
                            <th class="p-5 font-semibold text-center">@Localizer["Dash_Col_Talents"]</th>
                            <th class="p-5 font-semibold text-right">@Localizer["Dash_Col_Actions"]</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                        @if (Model.Agencies != null && Model.Agencies.Any())
                        {
                            @foreach (var agency in Model.Agencies)
                            {
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/20 transition-colors group">
                                    <td class="p-5">
                                        <div class="flex items-center gap-4">
                                            <div class="w-14 h-14 rounded-2xl overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-600 shadow-sm">
                                                @if (!string.IsNullOrEmpty(agency.LogoUrl))
                                                {
                                                    <img src="@agency.LogoUrl" alt="@agency.Name" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                                }
                                                else
                                                {
                                                    <div class="w-full h-full flex items-center justify-center text-primary font-bold">@agency.Name.Substring(0, 1)</div>
                                                }
                                            </div>
                                            <div>
                                                <div class="font-bold text-lg text-slate-900 dark:text-white">@agency.Name</div>
                                                <div class="text-[10px] text-slate-500 uppercase font-bold tracking-widest mt-0.5 truncate max-w-[150px]">
                                                    @agency.Description
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="p-5 text-sm">
                                        <div class="flex flex-col gap-1">
                                            <span class="inline-flex items-center gap-1.5 text-slate-700 dark:text-slate-300 font-medium">
                                                <span class="material-symbols-outlined text-[16px] text-slate-400">location_on</span>
                                                @Localizer["Region_" + agency.Region]
                                            </span>
                                            <span class="inline-flex items-center gap-1.5 text-slate-500 dark:text-slate-400">
                                                <span class="material-symbols-outlined text-[16px]">stars</span>
                                                @agency.Focus
                                            </span>
                                        </div>
                                    </td>
                                    <td class="p-5 text-center">
                                        <div x-data="{ open: false }" class="relative flex justify-center">
                                            <button @@click="open = !open" type="button" class="px-3 py-1 rounded-full text-xs font-black transition-all hover:scale-105 @(agency.Status == "Active" ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700") flex items-center gap-1">
                                                @Localizer["Status_" + (agency.Status ?? "Active")]
                                                <span class="material-symbols-outlined text-[14px]">arrow_drop_down</span>
                                            </button>
                                            <div x-show="open" @@click.away="open = false" x-cloak class="absolute top-full mt-2 w-32 bg-white dark:bg-slate-800 rounded-xl shadow-xl border border-slate-100 dark:border-slate-700 z-50 overflow-hidden py-1">
                                                <form asp-controller="Admin" asp-action="ApproveAgency" method="post">
                                                    <input type="hidden" name="id" value="@agency.Id" />
                                                    <button type="submit" name="status" value="Active" class="w-full px-4 py-2 text-left text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-700 text-green-600">Active</button>
                                                    <button type="submit" name="status" value="Defunct" class="w-full px-4 py-2 text-left text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-700 text-red-600">Defunct</button>
                                                </form>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="p-5 text-center">
                                        <div class="inline-flex flex-col items-center">
                                            <span class="text-xl font-black text-slate-900 dark:text-white">@agency.TalentCount</span>
                                            <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">@Localizer["Dash_Col_Talents"]</span>
                                        </div>
                                    </td>
                                    <td class="p-5 text-right whitespace-nowrap">
                                        <div class="flex items-center justify-end gap-2">
                                            <a href="/Wiki/Agencies?searchTerm=@agency.Name" target="_blank" class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:text-indigo-600 hover:bg-indigo-50 transition-colors">
                                                <span class="material-symbols-outlined text-[18px]">visibility</span>
                                            </a>
                                            <a href="/Wiki/EditAgency/@agency.Id" class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:text-indigo-600 hover:bg-indigo-50 transition-colors">
                                                <span class="material-symbols-outlined text-[18px]">edit</span>
                                            </a>
                                            <form id="delete-agency-@agency.Id" asp-controller="Wiki" asp-action="DeleteAgency" asp-route-id="@agency.Id" method="post">
                                                <button type="button" onclick="confirmDelete('agency-@agency.Id', '@Html.Raw(agency.Name.Replace("'", "\\'"))')" class="w-9 h-9 flex items-center justify-center rounded-xl bg-red-50 text-red-600 hover:text-white hover:bg-red-500 transition-colors shadow-sm">
                                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="p-10 text-center text-slate-500 italic">@Localizer["Dash_No_Agencies"]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Nội dung Tab Events -->
    <div x-show="activeTab === 'events'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" x-cloak>
        <div class="bg-white dark:bg-surface-dark rounded-3xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-700 text-sm uppercase text-slate-500 font-bold tracking-wider">
                            <th class="p-5 font-semibold">@Localizer["Dash_Col_EventTitle"]</th>
                            <th class="p-5 font-semibold">@Localizer["Dash_Col_Category"]</th>
                            <th class="p-5 font-semibold">@Localizer["Dash_Col_Date"]</th>
                            <th class="p-5 font-semibold text-center">@Localizer["Dash_Col_Featured"]</th>
                            <th class="p-5 font-semibold text-right">@Localizer["Dash_Col_Actions"]</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                        @if (Model.News != null && Model.News.Any())
                        {
                            @foreach (var item in Model.News)
                            {
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/20 transition-colors group">
                                    <td class="p-5">
                                        <div class="flex items-center gap-4">
                                            <div class="w-16 h-10 rounded-lg overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-600 shadow-sm relative">
                                                <img src="@item.ImageUrl" alt="@item.Title" class="w-full h-full object-cover" />
                                            </div>
                                            <div class="font-bold text-slate-900 dark:text-white max-w-md truncate">@item.Title</div>
                                        </div>
                                    </td>
                                    <td class="p-5">
                                        @{
                                            var badgeColor = item.Type switch {
                                                "Event" => "bg-purple-100 text-purple-700",
                                                "Debut" => "bg-blue-100 text-blue-700",
                                                "Music" => "bg-green-100 text-green-700",
                                                "ASMR" => "bg-pink-100 text-pink-700",
                                                "Gaming" => "bg-orange-100 text-orange-700",
                                                _ => "bg-slate-100 text-slate-700"
                                            };
                                        }
                                        <span class="px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-wider @badgeColor">@Localizer["Wiki_Event_Type_" + item.Type]</span>
                                    </td>
                                    <td class="p-5 text-sm text-slate-500 dark:text-slate-400 font-medium">
                                        @item.PublishDate.ToString("MMM dd, yyyy")
                                    </td>
                                    <td class="p-5 text-center">
                                        @if (item.IsFeatured)
                                        {
                                            <span class="material-symbols-outlined text-amber-400 fill-amber-400">star</span>
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-slate-300">star</span>
                                        }
                                    </td>
                                    <td class="p-5 text-right">
                                        <div class="flex items-center justify-end gap-2">
                                            <a href="/Wiki/EditEvent/@item.Id" class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:text-amber-500 hover:bg-amber-50 transition-colors">
                                                <span class="material-symbols-outlined text-[18px]">edit</span>
                                            </a>
                                            <form id="delete-news-@item.Id" asp-controller="Wiki" asp-action="DeleteEvent" asp-route-id="@item.Id" method="post">
                                                <button type="button" onclick="confirmDelete('news-@item.Id', '@Html.Raw(item.Title.Replace("'", "\\'"))')" class="w-9 h-9 flex items-center justify-center rounded-xl bg-red-50 text-red-600 hover:text-white hover:bg-red-500 transition-colors shadow-sm">
                                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="p-10 text-center text-slate-500 italic">@Localizer["Dash_No_Events"]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ── Tab Người dùng ─────────────────────────────────────────────── -->
    <div x-show="activeTab === 'users'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" x-cloak>
        <div class="bg-white dark:bg-surface-dark rounded-3xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-700 text-sm uppercase text-slate-500 font-bold tracking-wider">
                            <th class="p-5 font-semibold">@Localizer["Dash_Col_User"]</th>
                            <th class="p-5 font-semibold">@Localizer["Dash_Col_Email"]</th>
                            <th class="p-5 font-semibold">@Localizer["Dash_Col_CreatedAt"]</th>
                            <th class="p-5 font-semibold text-center">@Localizer["Dash_Col_Role"]</th>
                            <th class="p-5 font-semibold text-center">@Localizer["Dash_Col_AssignedPosts"]</th>
                            <th class="p-5 font-semibold text-right">@Localizer["Dash_Col_Actions"]</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                        @{
                            var currentUserId = int.Parse(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0");
                        }
                        @if (Model.Users != null && Model.Users.Any())
                        {
                            @foreach (var u in Model.Users)
                            {
                                var userAssignments = Model.EditorAssignments?.Where(a => a.EditorUserId == u.Id).ToList() ?? new List<WebWikiForum.Models.EditorAssignment>();
                                var isSelf = u.Id == currentUserId;
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/20 transition-colors group">
                                    <!-- Avatar + Username -->
                                    <td class="p-5">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-full overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-600">
                                                @if (!string.IsNullOrEmpty(u.AvatarUrl))
                                                {
                                                    <img src="@u.AvatarUrl" alt="@u.Username" class="w-full h-full object-cover" />
                                                }
                                                else
                                                {
                                                    <div class="w-full h-full flex items-center justify-center text-primary font-black text-sm">@u.Username.Substring(0,1).ToUpper()</div>
                                                }
                                            </div>
                                            <div>
                                                <a href="/Account/Member/@u.Username" target="_blank" class="font-bold text-slate-900 dark:text-white hover:text-primary transition-colors">@u.Username</a>
                                                @if (isSelf)
                                                {
                                                    <span class="ml-1 text-[10px] bg-primary/10 text-primary px-1.5 py-0.5 rounded font-bold">@Localizer["Dash_Label_You"]</span>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <!-- Email -->
                                    <td class="p-5 text-sm text-slate-500 dark:text-slate-400">@u.Email</td>
                                    <!-- Ngày tạo -->
                                    <td class="p-5 text-sm text-slate-500 dark:text-slate-400 whitespace-nowrap">@u.CreatedAt.ToString("dd/MM/yyyy")</td>
                                    <!-- Role Dropdown -->
                                    <td class="p-5 text-center">
                                        @if (isSelf)
                                        {
                                            <!-- Admin không thể tự đổi role mình -->
                                            <span class="px-3 py-1 rounded-full text-xs font-black bg-primary/10 text-primary">@u.Role</span>
                                        }
                                        else
                                        {
                                            <div x-data="{ open: false }" class="relative flex justify-center">
                                                <button @@click="open = !open" type="button"
                                                    class="px-3 py-1 rounded-full text-xs font-black transition-all hover:scale-105 flex items-center gap-1
                                                    @(u.Role == "Admin" ? "bg-primary/10 text-primary" : u.Role == "Editor" ? "bg-emerald-100 text-emerald-700" : "bg-slate-100 text-slate-600")">
                                                    @u.Role
                                                    <span class="material-symbols-outlined text-[14px]">arrow_drop_down</span>
                                                </button>
                                                <div x-show="open" @@click.away="open = false" x-cloak
                                                    class="absolute top-full mt-2 w-36 bg-white dark:bg-slate-800 rounded-xl shadow-xl border border-slate-100 dark:border-slate-700 z-50 overflow-hidden py-1">
                                                    <form asp-controller="Admin" asp-action="AssignRole" method="post">
                                                        <input type="hidden" name="userId" value="@u.Id" />
                                                        <button type="submit" name="role" value="User"
                                                            class="w-full px-4 py-2 text-left text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-600 flex items-center gap-2">
                                                            <span class="material-symbols-outlined text-[14px]">person</span> User
                                                        </button>
                                                        <button type="submit" name="role" value="Editor"
                                                            class="w-full px-4 py-2 text-left text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-700 text-emerald-600 flex items-center gap-2">
                                                            <span class="material-symbols-outlined text-[14px]">edit_note</span> Editor
                                                        </button>
                                                        <button type="submit" name="role" value="Admin"
                                                            class="w-full px-4 py-2 text-left text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-700 text-primary flex items-center gap-2">
                                                            <span class="material-symbols-outlined text-[14px]">shield</span> Admin
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        }
                                    </td>
                                    <!-- Số bài được giao (chỉ hiện với Editor) -->
                                    <td class="p-5 text-center">
                                        @if (u.Role == "Editor")
                                        {
                                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-black @(userAssignments.Count > 0 ? "bg-emerald-100 text-emerald-700" : "bg-slate-100 text-slate-400")">
                                                <span class="material-symbols-outlined text-[12px]">article</span>
                                                @userAssignments.Count @Localizer["Dash_Posts_Count"]
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-slate-300 dark:text-slate-600">—</span>
                                        }
                                    </td>
                                    <!-- Hành động -->
                                    <td class="p-5 text-right">
                                        @if (u.Role == "Editor")
                                        {
                                            <button type="button"
                                                data-username="@u.Username"
                                                data-assignments="@System.Text.Json.JsonSerializer.Serialize(userAssignments.Select(a => new { id = a.Id, title = a.Discussion?.Title ?? "(bài đã xóa)" }))"
                                                @@click="assignModal = { open: true, userId: @u.Id, username: $el.dataset.username, assignments: JSON.parse($el.dataset.assignments) }"
                                                class="flex items-center gap-1.5 px-3 py-2 rounded-xl bg-emerald-50 text-emerald-700 hover:bg-emerald-100 font-bold text-xs transition-colors ml-auto">
                                                <span class="material-symbols-outlined text-[16px]">assignment</span>
                                                @Localizer["Dash_Btn_AssignPost"]
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="6" class="p-10 text-center text-slate-500 italic">@Localizer["Dash_No_Users"]</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ── Modal Giao bài forum cho Editor ──────────────────────────── -->
    <div x-show="assignModal.open" x-cloak
         class="fixed inset-0 z-50 flex items-center justify-center p-4"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" @@click="assignModal.open = false"></div>
        <!-- Panel -->
        <div class="relative bg-white dark:bg-slate-800 rounded-2xl shadow-2xl w-full max-w-lg p-6 z-10"
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0 scale-95" x-transition:enter-end="opacity-100 scale-100">
            <!-- Header modal -->
            <div class="flex items-center justify-between mb-5">
                <div>
                    <h3 class="text-lg font-black text-slate-900 dark:text-white flex items-center gap-2">
                        <span class="material-symbols-outlined text-emerald-500">assignment</span>
                        @Localizer["Dash_Modal_AssignTitle"]
                    </h3>
                    <p class="text-sm text-slate-500 mt-0.5">@Localizer["Dash_Modal_AssignEditor"]: <span class="font-bold text-emerald-600" x-text="assignModal.username"></span></p>
                </div>
                <button @@click="assignModal.open = false" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-700 rounded-lg transition-colors">
                    <span class="material-symbols-outlined text-slate-400">close</span>
                </button>
            </div>

            <!-- Form giao bài mới -->
            <form asp-controller="Admin" asp-action="AssignEditorDiscussion" method="post" class="mb-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="editorUserId" x-bind:value="assignModal.userId" />
                <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5 uppercase tracking-wider">@Localizer["Dash_Modal_ChoosePost"]</label>
                <div class="flex gap-2">
                    <div class="flex-1 relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[18px]">article</span>
                        <select name="discussionId" required
                            class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-sm font-medium focus:ring-2 focus:ring-emerald-400 focus:border-transparent outline-none">
                            <option value="">@Localizer["Dash_Modal_SelectPost"]</option>
                            @foreach (var d in Model.Discussions ?? new List<WebWikiForum.Models.Discussion>())
                            {
                                <option value="@d.Id">[@d.Category] @d.Title</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="px-4 py-2.5 bg-emerald-500 hover:bg-emerald-600 text-white font-bold rounded-xl text-sm transition-colors flex items-center gap-1">
                        <span class="material-symbols-outlined text-[18px]">add</span>
                        @Localizer["Dash_Modal_Assign"]
                    </button>
                </div>
            </form>

            <!-- Danh sách bài đã giao -->
            <div class="border-t border-slate-100 dark:border-slate-700 pt-4">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-3">@Localizer["Dash_Modal_AssignedList"]</p>
                <div class="space-y-2 max-h-52 overflow-y-auto pr-1">
                    <template x-if="assignModal.assignments.length === 0">
                        <p class="text-sm text-slate-400 italic text-center py-4">@Localizer["Dash_Modal_NoAssigned"]</p>
                    </template>
                    <template x-for="a in assignModal.assignments" :key="a.id">
                        <div class="flex items-center justify-between gap-2 p-2.5 bg-slate-50 dark:bg-slate-700/50 rounded-xl">
                            <div class="flex items-center gap-2 min-w-0">
                                <span class="material-symbols-outlined text-emerald-400 text-[16px] shrink-0">article</span>
                                <span class="text-sm font-medium text-slate-700 dark:text-slate-200 truncate" x-text="a.title"></span>
                            </div>
                            <form :action="`/Admin/RemoveEditorAssignment?assignmentId=${a.id}`" method="post" class="shrink-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="p-1.5 hover:bg-red-50 text-slate-400 hover:text-red-500 rounded-lg transition-colors" title="@Localizer["Modal_Btn_Delete"]">
                                    <span class="material-symbols-outlined text-[16px]">close</span>
                                </button>
                            </form>
                        </div>
                    </template>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script>
        function confirmDelete(formId, itemName) {
            window.showConfirmModal({
                title: '@Html.Raw(Localizer["Modal_Delete_Title"].Value.Replace("'", "\\'"))',
                message: '@Html.Raw(Localizer["Modal_Delete_Msg"].Value.Replace("'", "\\'"))'.replace('{0}', itemName),
                confirmText: '@Html.Raw(Localizer["Modal_Btn_Delete"].Value.Replace("'", "\\'"))',
                onConfirm: () => {
                    document.getElementById('delete-' + formId).submit();
                }
            });
        }
    </script>
}
