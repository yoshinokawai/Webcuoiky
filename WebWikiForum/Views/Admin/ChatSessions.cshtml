@model IEnumerable<UserChatSummary>
@{
    ViewData["Title"] = Localizer["Chat_Users_Title"];
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-2xl font-black text-slate-900 dark:text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">group</span>
                @Localizer["Chat_Users_Title"]
            </h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">@Localizer["Chat_Users_Desc"]</p>
        </div>
        <a href="/Admin/Dashboard" class="flex items-center gap-2 px-4 py-2 text-sm font-bold rounded-xl border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
            <span class="material-symbols-outlined text-[18px]">arrow_back</span>
            @Localizer["Nav_Dashboard"]
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-24 rounded-2xl border-2 border-dashed border-slate-200 dark:border-slate-700">
            <span class="material-symbols-outlined text-5xl text-slate-300 mb-4 block">person_off</span>
            <p class="text-slate-500 font-medium">@Localizer["Chat_No_Users"]</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            @foreach (var user in Model)
            {
                <a href="/Admin/UserSessions?username=@user.Username&userId=@user.UserId"
                   class="flex items-center gap-4 bg-white dark:bg-surface-dark rounded-2xl border border-slate-200 dark:border-slate-700 p-5 hover:border-primary hover:shadow-lg hover:shadow-primary/10 transition-all duration-200 group">

                    <!-- Avatar -->
                    <div class="w-14 h-14 rounded-full bg-gradient-to-br from-primary/20 to-primary/5 flex items-center justify-center flex-shrink-0 group-hover:from-primary/30 transition-all overflow-hidden border-2 border-transparent group-hover:border-primary/20">
                        @if (!string.IsNullOrEmpty(user.AvatarUrl))
                        {
                            <img src="@user.AvatarUrl" class="w-full h-full object-cover" alt="@user.Username" onerror="this.src='/img/default-avatar.png'; this.onerror=null;" />
                        }
                        else
                        {
                            <span class="text-xl font-black text-primary">@user.Username[0].ToString().ToUpper()</span>
                        }
                    </div>

                    <!-- Info -->
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                            <span class="font-bold text-slate-900 dark:text-white text-base">
                                @user.Username
                            </span>
                            @if (user.UnreadCount > 0)
                            {
                                <span class="inline-flex items-center justify-center px-2 py-0.5 text-[10px] font-black bg-red-500 text-white rounded-full">
                                    @user.UnreadCount @Localizer["Chat_Label_New"]
                                </span>
                            }
                        </div>
                        <p class="text-xs text-slate-500 dark:text-slate-400">
                            <span class="font-semibold text-primary">@string.Format(Localizer["Chat_Label_History"].Value, user.TotalSessions)</span>
                        </p>
                    </div>

                    <!-- Meta -->
                    <div class="flex flex-col items-end gap-1 flex-shrink-0">
                        <span class="text-[10px] text-slate-400 font-medium">
                            @Localizer["Chat_Label_Active"]: @user.LastActive.ToLocalTime().ToString("HH:mm dd/MM")
                        </span>
                    </div>

                    <button onclick="deleteUserHistory(event, '@user.UserId', '@user.Username')" 
                            class="p-2 text-slate-300 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-all z-10"
                            title="@Localizer["Chat_Title_DeleteHistory"]">
                        <span class="material-symbols-outlined text-sm">delete</span>
                    </button>

                    <span class="material-symbols-outlined text-slate-300 group-hover:text-primary transition-colors">chevron_right</span>
                </a>
            }
        </div>
    }
</div>

@section Scripts {
<script>
    async function deleteUserHistory(event, userId, username) {
        event.preventDefault();
        event.stopPropagation();
        
        window.showConfirmModal({
            title: '@Html.Raw(Localizer["Modal_Delete_Title"].Value.Replace("'", "\\'"))',
            message: '@Html.Raw(Localizer["Modal_Delete_Msg"].Value.Replace("'", "\\'"))'.replace('{0}', username),
            confirmText: '@Html.Raw(Localizer["Modal_Btn_Delete"].Value.Replace("'", "\\'"))',
            onConfirm: async () => {
                try {
                    const formData = new FormData();
                    if (userId && userId !== 'null') formData.append('userId', userId);
                    else formData.append('username', username);

                    const res = await fetch('/Admin/DeleteUserChatHistory', {
                        method: 'POST',
                        body: formData
                    });
                    const data = await res.json();
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('@Localizer["Chat_Status_Error"]');
                    }
                } catch (e) {
                    console.error(e);
                    alert('@Localizer["Chat_Status_Error"]');
                }
            }
        });
    }
</script>
}
