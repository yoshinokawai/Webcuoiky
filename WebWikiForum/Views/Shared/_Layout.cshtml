    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const si = document.getElementById('searchInput'), sd = document.getElementById('searchDropdown'), sr = document.getElementById('searchResults');
            let dt;
            si?.addEventListener('input', () => {
                clearTimeout(dt);
                const q = si.value.trim();
                if (q.length < 1) return;
                dt = setTimeout(async () => {
                   document.getElementById('searchLoading')?.classList.remove('hidden');
                   sr.querySelectorAll('.dynamic-result').forEach(e => e.remove());
                   try {
                       const r = await fetch(`/Wiki/SearchSuggest?query=${encodeURIComponent(q)}`);
                       const d = await r.json();
                       document.getElementById('searchLoading')?.classList.add('hidden');
                       if (d.length === 0) document.getElementById('searchEmpty')?.classList.remove('hidden');
                       else {
                           document.getElementById('searchEmpty')?.classList.add('hidden');
                           d.forEach(i => {
                               const a = document.createElement('a');
                               a.className = 'dynamic-result flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-all';
                               a.href = i.type === 'vtuber' ? `/Wiki/Details/${i.id}` : `/Wiki/AgencyDetails/${i.id}`;
                               const typeBadge = i.type === 'agency' ? `<span class="text-[9px] font-black bg-indigo-100 text-indigo-700 px-1.5 py-0.5 rounded-md uppercase ml-1.5">${i.type === 'agency' ? '@Localizer["Nav_Agencies"].Value' : ''}</span>` : '';
                               a.innerHTML = `
                                   <div class="w-9 h-9 rounded-xl ${i.type === 'agency' ? 'bg-indigo-50 text-indigo-500' : 'bg-slate-100 text-slate-400'} overflow-hidden flex items-center justify-center border border-slate-200 dark:border-slate-700 flex-shrink-0">
                                       ${i.avatarUrl ? `<img src="${i.avatarUrl}" class="w-full h-full object-cover">` : `<span class="material-symbols-outlined text-lg">${i.type === 'agency' ? 'domain' : 'person'}</span>`}
                                   </div>
                                   <div class="flex-1 min-w-0">
                                       <div class="text-sm font-bold text-slate-900 dark:text-white truncate flex items-center">${i.name}${typeBadge}</div>
                                       <div class="text-[10px] text-slate-500 font-medium truncate">${i.subtext}</div>
                                   </div>`;
                               sr.appendChild(a);
                           });
                       }
                   } catch(e) {}
                }, 300);
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- ===== GLOBAL LIGHTBOX ===== -->
    <div id="globalLightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center" style="background:rgba(0,0,0,0.92);backdrop-filter:blur(6px)" onclick="closeLightbox()">
        <button class="absolute top-4 right-4 w-11 h-11 rounded-full bg-white/10 hover:bg-white/25 flex items-center justify-center text-white transition-all z-10" onclick="closeLightbox()">
            <span class="material-symbols-outlined text-2xl">close</span>
        </button>
        <!-- Zoom controls -->
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10">
            <button class="px-3 py-1.5 rounded-full bg-white/10 hover:bg-white/25 text-white text-sm font-bold transition-all" onclick="event.stopPropagation();lbZoom(-0.2)">
                <span class="material-symbols-outlined text-base leading-none">zoom_out</span>
            </button>
            <button class="px-3 py-1.5 rounded-full bg-white/10 hover:bg-white/25 text-white text-sm font-bold transition-all" onclick="event.stopPropagation();lbZoom(0.2)">
                <span class="material-symbols-outlined text-base leading-none">zoom_in</span>
            </button>
            <button class="px-3 py-1.5 rounded-full bg-white/10 hover:bg-white/25 text-white text-sm font-bold transition-all" onclick="event.stopPropagation();lbReset()">
                <span class="material-symbols-outlined text-base leading-none">fit_screen</span>
            </button>
        </div>
        <img id="globalLightboxImg" src="" alt="" class="max-w-[92vw] max-h-[88vh] rounded-2xl shadow-2xl object-contain transition-transform duration-150 select-none" onclick="event.stopPropagation()" style="transform-origin:center center" draggable="false" />
    </div>

    <script>
        (function () {
            let lbScale = 1;

            function openLightbox(url) {
                if (!url || url === '#' || url === '') return;
                const lb = document.getElementById('globalLightbox');
                const img = document.getElementById('globalLightboxImg');
                img.src = url;
                lbScale = 1;
                img.style.transform = 'scale(1)';
                lb.classList.remove('hidden');
                lb.classList.add('flex');
                document.body.style.overflow = 'hidden';
            }

            function closeLightbox() {
                const lb = document.getElementById('globalLightbox');
                lb.classList.add('hidden');
                lb.classList.remove('flex');
                document.body.style.overflow = '';
                document.getElementById('globalLightboxImg').src = '';
            }

            function lbZoom(delta) {
                lbScale = Math.min(Math.max(lbScale + delta, 0.5), 4);
                document.getElementById('globalLightboxImg').style.transform = `scale(${lbScale})`;
            }

            function lbReset() {
                lbScale = 1;
                document.getElementById('globalLightboxImg').style.transform = 'scale(1)';
            }

            // Expose globally
            window.openLightbox = openLightbox;
            window.closeLightbox = closeLightbox;
            window.lbZoom = lbZoom;
            window.lbReset = lbReset;

            // Keyboard
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeLightbox();
                if (e.key === '+') lbZoom(0.2);
                if (e.key === '-') lbZoom(-0.2);
            });

            // Scroll to zoom
            document.getElementById('globalLightboxImg').addEventListener('wheel', function (e) {
                e.preventDefault();
                lbZoom(e.deltaY < 0 ? 0.15 : -0.15);
            }, { passive: false });

            // ===== GLOBAL EVENT DELEGATION =====
            // Clicks on: <img> tags, or any element with data-lightbox attribute
            document.addEventListener('click', function (e) {
                const lb = document.getElementById('globalLightbox');
                if (lb && !lb.classList.contains('hidden')) return; // already open

                // 1. Element with data-lightbox attribute
                const dlEl = e.target.closest('[data-lightbox]');
                if (dlEl) {
                    const url = dlEl.getAttribute('data-lightbox') || dlEl.getAttribute('src') || dlEl.style.backgroundImage?.replace(/url\(['"]?|['"]?\)/g, '');
                    if (url) { openLightbox(url); return; }
                }

                // 2. <img> tags with class "lightbox-img" OR cursor-pointer style and inside a known container
                if (e.target.tagName === 'IMG') {
                    const img = e.target;
                    // Only trigger if img has data-lightbox, or has lightbox-img class
                    if (img.classList.contains('lightbox-img') || img.hasAttribute('data-lightbox')) {
                        openLightbox(img.src);
                    }
                }
            });
        })();
    </script>
