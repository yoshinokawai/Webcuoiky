<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>@ViewData["Title"] - Web Wiki Forum</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;700;900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#994ce6",
                        "primary-dark": "#7e37c3",
                        "background-light": "#f7f6f8",
                        "background-dark": "#191121",
                        "surface-light": "#ffffff",
                        "surface-dark": "#1f1826",
                    },
                    fontFamily: {
                        "display": ["Be Vietnam Pro", "sans-serif"]
                    },
                    borderRadius: {"DEFAULT": "0.25rem", "lg": "0.6rem", "xl": "1rem", "2xl": "1.5rem", "full": "9999px"},
                },
            },
        }
    </script>
    <link href="~/css/site.css" rel="stylesheet" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased min-h-screen flex flex-col">
    <header class="sticky top-0 z-50 w-full border-b border-slate-200/60 dark:border-slate-800/60 bg-surface-light/80 dark:bg-surface-dark/80 backdrop-blur-xl supports-[backdrop-filter]:bg-surface-light/60">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16 gap-4">
                <!-- Left: Logo -->
                <a href="/Home/Index" class="flex items-center gap-2 flex-shrink-0">
                    <div class="w-10 h-10 flex items-center justify-center rounded-full bg-primary text-white shadow-sm ring-4 ring-primary/10">
                        <span class="material-symbols-outlined text-[20px]">smart_display</span>
                    </div>
                    <span class="text-xl font-black tracking-tight text-slate-900 dark:text-white ml-2"><span class="text-primary">VT</span>Wiki</span>
                </a>

                <!-- Middle: Navigation -->
                <nav class="hidden lg:flex items-center gap-8">
                    <a class="text-sm font-bold @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "text-primary border-b-2 border-primary" : "text-slate-700 dark:text-slate-300 hover:text-primary") transition-colors py-2" href="/Home/Index">@Localizer["Nav_Home"]</a>
                    
                    <div class="relative group">
                        <a href="/Home/Explore" class="flex items-center gap-1 text-sm font-bold @(ViewContext.RouteData.Values["Action"]?.ToString() == "Explore" ? "text-primary border-b-2 border-primary" : "text-slate-700 dark:text-slate-300 hover:text-primary") transition-colors py-2">
                            @Localizer["Nav_Explore"]
                            <span class="material-symbols-outlined text-[16px] group-hover:rotate-180 transition-transform">expand_more</span>
                        </a>
                        <div class="absolute top-full left-0 w-48 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-[60]">
                            <div class="bg-white dark:bg-surface-dark border border-slate-200 dark:border-slate-700 rounded-xl shadow-xl p-2 space-y-1">
                                <a class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" href="/Wiki/Agencies">@Localizer["Nav_Agencies"]</a>
                                <a class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" href="/Wiki/Independent">@Localizer["Nav_Independent"]</a>
                                <a class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" href="/Wiki/VirtualEvents">@Localizer["Nav_VirtualEvents"]</a>
                                <a class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" href="/Editor/FanTools">@Localizer["Nav_FanTools"]</a>
                                <a class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" href="/Home/TopTalent">@Localizer["Nav_TopTalents"]</a>
                            </div>
                        </div>
                    </div>

                    <div class="relative group">
                        <button class="flex items-center gap-1 text-sm font-bold text-slate-700 dark:text-slate-300 hover:text-primary transition-colors py-2">
                            @Localizer["Nav_Community"]
                            <span class="material-symbols-outlined text-[16px] group-hover:rotate-180 transition-transform">expand_more</span>
                        </button>
                        <div class="absolute top-full left-0 w-48 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-[60]">
                            <div class="bg-white dark:bg-surface-dark border border-slate-200 dark:border-slate-700 rounded-xl shadow-xl p-2 space-y-1">
                                <a class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" href="/Forum/CommunityHub">Community Hub</a>
                                <a class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" href="/Forum/Community">Forum</a>
                                <a class="group px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-[#5865F2] rounded-lg transition-all flex items-center gap-2" href="/Home/JoinDiscord">
                                    <svg class="w-4 h-4 fill-current group-hover:drop-shadow-[0_0_8px_rgba(88,101,242,0.5)]" viewBox="0 0 24 24">
                                        <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.1028 1.543 4.1335 2.4812 6.126 3.1047a.077.077 0 00.0828-.0272c.4654-.6363.876-1.3142 1.226-2.0304a.0759.0759 0 00-.0416-.1057 13.1163 13.1163 0 01-1.9213-.9148.0772.0772 0 01-.0066-.1269c.13-.0974.26-.198.3846-.3012a.0741.0741 0 01.0774-.0102c4.0125 1.8341 8.3562 1.8341 12.33 0a.0721.0721 0 01.0774.0102c.1246.1032.2546.2038.3846.3012a.0772.0772 0 01-.0066.1269 12.2991 12.2991 0 01-1.9213.9148.0759.0759 0 00-.0416.1057c.35.7162.7606 1.3941 1.226 2.0304a.077.077 0 00.0828.0272c1.9925-.6235 4.0232-1.5617 6.126-3.1047a.078.078 0 00.0312-.0561c.5002-5.1772-.8382-9.6739-3.5485-13.6604a.0688.0688 0 00-.0312-.0281zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/>
                                    </svg>
                                    Discord
                                </a>
                                <a class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" href="/Home/RecentChanges">Recent Changes</a>
                                <a class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" href="/Help/Guidelines">Guidelines</a>
                            </div>
                        </div>
                    </div>

                    <div class="relative group">
                        <button class="flex items-center gap-1 text-sm font-bold text-slate-700 dark:text-slate-300 hover:text-primary transition-colors py-2">
                            @Localizer["Nav_Wiki"]
                            <span class="material-symbols-outlined text-[16px] group-hover:rotate-180 transition-transform">expand_more</span>
                        </button>
                        <div class="absolute top-full left-0 w-48 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-[60]">
                            <div class="bg-white dark:bg-surface-dark border border-slate-200 dark:border-slate-700 rounded-xl shadow-xl p-2 space-y-1">
                                <a class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" href="/Home/AboutUs">About Us</a>
                                <a class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" href="/Admin/Dashboard">Dashboard</a>
                                <a class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" href="/Wiki/Translation">Translation</a>
                                <a class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" href="/Help/HelpCenter">Help Center</a>
                                <a class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-primary rounded-lg transition-colors" href="/Home/Donate">Donate</a>
                            </div>
                        </div>
                    </div>
                </nav>

                <!-- Right: Search & Profile -->
                <div class="flex items-center gap-3 flex-1 justify-end">
                    <!-- Dynamic Search -->
                    <div class="relative hidden sm:block w-full max-w-[240px] group z-[70]">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-slate-400 text-[18px]">search</span>
                        </div>
                        <input id="searchInput" class="peer block w-full pl-9 pr-3 py-1.5 border border-slate-200 dark:border-slate-700/50 rounded-full leading-5 bg-slate-50/80 dark:bg-slate-800/80 text-slate-900 font-medium dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary text-xs transition-all shadow-sm" placeholder="@Localizer["Nav_Search"]" type="text" autocomplete="off"/>
                        
                        <div id="searchDropdown" class="absolute top-full left-0 w-full mt-2 bg-white dark:bg-surface-dark rounded-xl border border-slate-200 dark:border-slate-700 shadow-xl opacity-0 invisible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200 origin-top transform z-[100]">
                            <div id="searchResults" class="p-2 space-y-1 max-h-[400px] overflow-y-auto">
                                <div class="px-3 py-1.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">@Localizer["Nav_Search_Suggested"]</div>
                                <div id="searchLoading" class="hidden px-3 py-4 text-center">
                                    <div class="inline-block animate-spin rounded-full h-4 w-4 border-2 border-primary border-t-transparent"></div>
                                </div>
                                <div id="searchEmpty" class="hidden px-3 py-4 text-center text-sm text-slate-500">
                                    @Localizer["Nav_Search_NoResults"]
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Language -->
                    <div class="relative group z-50">
                        <button class="flex items-center gap-1 text-sm font-bold text-slate-700 dark:text-slate-300 hover:text-primary transition-colors h-10 px-3 rounded-full border border-slate-200 dark:border-slate-700/50 hover:bg-slate-50 dark:hover:bg-slate-800/80">
                            <span class="material-symbols-outlined text-[18px]">language</span>
                            <span class="material-symbols-outlined text-[16px] group-hover:rotate-180 transition-transform">expand_more</span>
                        </button>
                        <div class="absolute top-full right-0 w-32 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 origin-top transform">
                            <div class="bg-white dark:bg-surface-dark border border-slate-200 dark:border-slate-700 rounded-xl shadow-xl p-1">
                                <form action="/Language/ChangeLanguage" method="post" class="flex flex-col">
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                    <button type="submit" name="culture" value="en" class="w-full text-left px-3 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg">English</button>
                                    <button type="submit" name="culture" value="vi" class="w-full text-left px-3 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg">Tiếng Việt</button>
                                    <button type="submit" name="culture" value="ja" class="w-full text-left px-3 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg">日本語</button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Profile -->
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="flex items-center gap-2">
                            <div class="hidden md:flex items-center gap-2 h-10 px-4 rounded-full bg-slate-100 dark:bg-slate-800 text-sm font-bold text-slate-700 dark:text-slate-300">
                                <span class="material-symbols-outlined text-primary text-[18px]">person</span>
                                @User.Identity.Name
                            </div>
                            <a href="/Account/Logout" class="flex items-center h-10 px-4 rounded-full border border-slate-200 dark:border-slate-700/50 text-sm font-bold text-slate-700 dark:text-slate-300 hover:text-primary hover:border-primary/30 transition-colors gap-2">
                                <span class="material-symbols-outlined text-[18px]">logout</span>
                                <span class="hidden sm:inline">@Localizer["Nav_Logout"]</span>
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="flex items-center gap-2">
                            <a href="/Account/Login" class="hidden sm:flex items-center h-10 px-5 rounded-full border border-slate-200 dark:border-slate-700/50 text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">@Localizer["Nav_Login"]</a>
                            <a href="/Account/CreateAccount" class="flex items-center h-10 px-5 rounded-full bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors">@Localizer["Nav_Signup"]</a>
                        </div>
                    }
                    <!-- Mobile Menu Button -->
                    <button id="mobileMenuBtn" class="lg:hidden w-10 h-10 flex items-center justify-center rounded-full text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                        <span class="material-symbols-outlined text-[28px]" id="menuIcon">menu</span>
                    </button>
                </div>
            </div>
            
            <!-- Mobile Dropdown Menu -->
            <div id="mobileDropdown" class="lg:hidden hidden overflow-hidden transition-all duration-300 max-h-0 border-t border-slate-100 dark:border-slate-800">
                <nav class="p-4 space-y-4 bg-white dark:bg-surface-dark shadow-inner max-h-[80vh] overflow-y-auto">
                    <!-- Home Section -->
                    <div class="space-y-1">
                        <a href="/Home/Index" class="flex items-center gap-3 px-4 py-3 rounded-xl font-bold text-slate-700 dark:text-slate-300 hover:bg-primary/10 hover:text-primary transition-all">
                            <span class="material-symbols-outlined text-[20px]">home</span>
                            @Localizer["Nav_Home"]
                        </a>
                    </div>
                    
                    <!-- Explore Section -->
                    <div class="space-y-1">
                        <div class="px-4 py-1 text-[10px] font-black uppercase tracking-widest text-slate-400">@Localizer["Nav_Explore"]</div>
                        <a href="/Wiki/Agencies" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800">
                            <span class="material-symbols-outlined text-[18px]">domain</span>
                            @Localizer["Nav_Agencies"]
                        </a>
                        <a href="/Wiki/Independent" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800">
                            <span class="material-symbols-outlined text-[18px]">person</span>
                            @Localizer["Nav_Independent"]
                        </a>
                        <a href="/Wiki/VirtualEvents" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800">
                            <span class="material-symbols-outlined text-[18px]">event</span>
                            @Localizer["Nav_VirtualEvents"]
                        </a>
                        <a href="/Editor/FanTools" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800">
                            <span class="material-symbols-outlined text-[18px]">build</span>
                            @Localizer["Nav_FanTools"]
                        </a>
                        <a href="/Home/TopTalent" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800">
                            <span class="material-symbols-outlined text-[18px]">star</span>
                            @Localizer["Nav_TopTalents"]
                        </a>
                    </div>

                    <!-- Community Section -->
                    <div class="space-y-1">
                        <div class="px-4 py-1 text-[10px] font-black uppercase tracking-widest text-slate-400">@Localizer["Nav_Community"]</div>
                        <a href="/Forum/CommunityHub" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800">
                            <span class="material-symbols-outlined text-[18px]">groups</span>
                            Community Hub
                        </a>
                        <a href="/Forum/Community" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800">
                            <span class="material-symbols-outlined text-[18px]">forum</span>
                            Forum
                        </a>
                        <a href="/Home/JoinDiscord" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all">
                            <svg class="w-[18px] h-[18px] fill-[#5865F2]" viewBox="0 0 24 24">
                                <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.1028 1.543 4.1335 2.4812 6.126 3.1047a.077.077 0 00.0828-.0272c.4654-.6363.876-1.3142 1.226-2.0304a.0759.0759 0 00-.0416-.1057 13.1163 13.1163 0 01-1.9213-.9148.0772.0772 0 01-.0066-.1269c.13-.0974.26-.198.3846-.3012a.0741.0741 0 01.0774-.0102c4.0125 1.8341 8.3562 1.8341 12.33 0a.0721.0721 0 01.0774.0102c.1246.1032.2546.2038.3846.3012a.0772.0772 0 01-.0066.1269 12.2991 12.2991 0 01-1.9213.9148.0759.0759 0 00-.0416.1057c.35.7162.7606 1.3941 1.226 2.0304a.077.077 0 00.0828.0272c1.9925-.6235 4.0232-1.5617 6.126-3.1047a.078.078 0 00.0312-.0561c.5002-5.1772-.8382-9.6739-3.5485-13.6604a.0688.0688 0 00-.0312-.0281zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/>
                            </svg>
                            Discord
                        </a>
                        <a href="/Home/RecentChanges" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800">
                            <span class="material-symbols-outlined text-[18px]">history</span>
                            Recent Changes
                        </a>
                        <a href="/Help/Guidelines" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800">
                            <span class="material-symbols-outlined text-[18px]">gavel</span>
                            Guidelines
                        </a>
                    </div>

                    <!-- Wiki/System Section -->
                    <div class="space-y-1">
                        <div class="px-4 py-1 text-[10px] font-black uppercase tracking-widest text-slate-400">@Localizer["Nav_Wiki"]</div>
                        <a href="/Home/AboutUs" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800">
                            <span class="material-symbols-outlined text-[18px]">info</span>
                            About Us
                        </a>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <a href="/Admin/Dashboard" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-primary hover:bg-primary/5">
                                <span class="material-symbols-outlined text-[18px]">dashboard</span>
                                Dashboard
                            </a>
                        }
                        <a href="/Wiki/Translation" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800">
                            <span class="material-symbols-outlined text-[18px]">translate</span>
                            Translation
                        </a>
                        <a href="/Help/HelpCenter" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800">
                            <span class="material-symbols-outlined text-[18px]">help</span>
                            Help Center
                        </a>
                        <a href="/Home/Donate" class="flex items-center gap-3 px-4 py-2 rounded-xl text-sm font-bold text-amber-600 hover:bg-amber-50">
                            <span class="material-symbols-outlined text-[18px]">volunteer_activism</span>
                            Donate
                        </a>
                    </div>

                    <!-- Auth Section for Guest -->
                    @if (!User.Identity.IsAuthenticated)
                    {
                        <div class="pt-4 grid grid-cols-2 gap-3 px-2 border-t border-slate-100 dark:border-slate-800">
                            <a href="/Account/Login" class="h-11 flex items-center justify-center rounded-xl border border-slate-200 dark:border-slate-700 font-bold text-sm text-slate-700 dark:text-slate-300">Login</a>
                            <a href="/Account/CreateAccount" class="h-11 flex items-center justify-center rounded-xl bg-primary text-white font-bold text-sm shadow-lg shadow-primary/20">Sign Up</a>
                        </div>
                    }
                </nav>
            </div>
        </div>
    </header>

    <main class="flex-1">
        @RenderBody()
    </main>

    <footer class="border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-surface-dark">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div class="col-span-1">
                    <a href="/Home/Index" class="flex items-center gap-2 mb-4">
                        <span class="material-symbols-outlined text-primary text-[24px]">smart_display</span>
                        <span class="text-lg font-bold text-slate-900 dark:text-white"><span class="text-primary">VT</span>Wiki</span>
                    </a>
                    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">@Localizer["Footer_Desc"]</p>
                </div>
                <div>
                    <h3 class="text-sm font-bold text-slate-900 dark:text-white uppercase mb-4">@Localizer["Footer_Wiki"]</h3>
                    <ul class="space-y-2">
                        <li><a class="text-sm text-slate-500 hover:text-primary transition-colors" href="/Home/AboutUs">About Us</a></li>
                        <li><a class="text-sm text-slate-500 hover:text-primary transition-colors" href="/Help/Guidelines">Guidelines</a></li>
                        <li><a class="text-sm text-slate-500 hover:text-primary transition-colors" href="/Editor/EditorHub">Editors Hub</a></li>
                    </ul>
                </div>
                <div>
                    <h3 class="text-sm font-bold text-slate-900 dark:text-white uppercase mb-4">@Localizer["Footer_Explore"]</h3>
                    <ul class="space-y-2">
                        <li><a class="text-sm text-slate-500 hover:text-primary transition-colors" href="/Wiki/Agencies">Agencies</a></li>
                        <li><a class="text-sm text-slate-500 hover:text-primary transition-colors" href="/Wiki/Independent">Indie VTubers</a></li>
                        <li><a class="text-sm text-slate-500 hover:text-primary transition-colors" href="/Wiki/VirtualEvents">@Localizer["Nav_VirtualEvents"]</a></li>
                    </ul>
                </div>
                <div>
                    <h3 class="text-sm font-bold text-slate-900 dark:text-white uppercase mb-4">@Localizer["Footer_Subscribe"]</h3>
                    <div class="flex gap-2">
                        <input class="w-full px-4 py-2 text-sm border border-slate-200 dark:border-slate-700/50 rounded-full bg-slate-50 dark:bg-slate-800 text-white focus:outline-none focus:ring-2 focus:ring-primary/50" placeholder="Email" type="email"/>
                        <button class="px-4 py-2 bg-primary text-white text-sm font-bold rounded-full hover:bg-primary-dark">Go</button>
                    </div>
                </div>
            </div>
            <div class="mt-8 pt-8 border-t border-slate-200 dark:border-slate-800 flex flex-col md:flex-row justify-between items-center text-xs text-slate-400">
                <p>@Localizer["Footer_Rights"]</p>
                <div class="flex gap-6">
                    <a href="/Home/Privacy">@Localizer["Footer_Privacy"]</a>
                    <a href="/Home/Privacy">@Localizer["Footer_Terms"]</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Global Modal & Toast -->
    <div id="confirmModal" class="fixed inset-0 z-[100] hidden">
        <div class="flex items-center justify-center min-h-screen p-4">
            <div id="modalOverlay" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm"></div>
            <div id="modalContent" class="relative bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-2xl max-w-md w-full border border-slate-200 dark:border-slate-800">
                <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2" id="modal-title">Confirm</h3>
                <p id="modal-message" class="text-sm text-slate-500 dark:text-slate-400 mb-6">Are you sure?</p>
                <div class="flex justify-end gap-3">
                    <button id="modalCancelBtn" class="px-5 py-2 text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full">Cancel</button>
                    <button id="modalConfirmBtn" class="px-5 py-2 text-sm font-bold bg-red-600 text-white rounded-full hover:bg-red-700">Confirm</button>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null) {
        var isErr = TempData["ErrorMessage"] != null;
        var msg = isErr ? TempData["ErrorMessage"] : TempData["SuccessMessage"];
        <div id="global-toast" class="fixed top-20 right-6 z-[100] flex items-center gap-3 px-5 py-3 rounded-2xl border bg-white dark:bg-surface-dark shadow-2xl scale-100 transition-all duration-300">
            <span class="material-symbols-outlined @(isErr ? "text-red-500":"text-green-500")">@(isErr ? "error":"check_circle")</span>
            <div class="text-sm font-medium">@msg</div>
            <button onclick="this.parentElement.remove()" class="text-slate-400 hover:text-slate-600"><span class="material-symbols-outlined text-sm">close</span></button>
        </div>
        <script>setTimeout(() => document.getElementById('global-toast')?.remove(), 5000);</script>
    }

    <script src="~/js/site.js"></script>
    <script src="~/js/filters.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const si = document.getElementById('searchInput'), sd = document.getElementById('searchDropdown'), sr = document.getElementById('searchResults');
            let dt;
            si?.addEventListener('input', () => {
                clearTimeout(dt);
                const q = si.value.trim();
                if (q.length < 1) return;
                dt = setTimeout(async () => {
                   document.getElementById('searchLoading')?.classList.remove('hidden');
                   sr.querySelectorAll('.dynamic-result').forEach(e => e.remove());
                   try {
                       const r = await fetch(`/Wiki/SearchSuggest?query=${encodeURIComponent(q)}`);
                       const d = await r.json();
                       document.getElementById('searchLoading')?.classList.add('hidden');
                       if (d.length === 0) document.getElementById('searchEmpty')?.classList.remove('hidden');
                       else {
                           document.getElementById('searchEmpty')?.classList.add('hidden');
                           d.forEach(i => {
                               const a = document.createElement('a');
                               a.className = 'dynamic-result flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-all';
                               a.href = i.type === 'vtuber' ? `/Wiki/Details/${i.id}` : `/Wiki/AgencyDetails/${i.id}`;
                               const typeBadge = i.type === 'agency' ? '<span class="text-[9px] font-black bg-indigo-100 text-indigo-700 px-1.5 py-0.5 rounded-md uppercase ml-1.5">Agency</span>' : '';
                               a.innerHTML = `
                                   <div class="w-9 h-9 rounded-xl ${i.type === 'agency' ? 'bg-indigo-50 text-indigo-500' : 'bg-slate-100 text-slate-400'} overflow-hidden flex items-center justify-center border border-slate-200 dark:border-slate-700 flex-shrink-0">
                                       ${i.avatarUrl ? `<img src="${i.avatarUrl}" class="w-full h-full object-cover">` : `<span class="material-symbols-outlined text-lg">${i.type === 'agency' ? 'domain' : 'person'}</span>`}
                                   </div>
                                   <div class="flex-1 min-w-0">
                                       <div class="text-sm font-bold text-slate-900 dark:text-white truncate flex items-center">${i.name}${typeBadge}</div>
                                       <div class="text-[10px] text-slate-500 font-medium truncate">${i.subtext}</div>
                                   </div>`;
                               sr.appendChild(a);
                           });
                       }
                   } catch(e) {}
                }, 300);
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
