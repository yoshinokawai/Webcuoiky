    </button>
    <div class="absolute top-full right-0 w-32 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 origin-top transform">
        <div class="bg-white dark:bg-surface-dark border border-slate-200 dark:border-slate-700 rounded-xl shadow-xl p-1">
            <form action="/Language/ChangeLanguage" method="post" class="flex flex-col">
                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                <button type="submit" name="culture" value="en" class="w-full text-left px-3 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors font-medium">English</button>
                <button type="submit" name="culture" value="vi" class="w-full text-left px-3 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors font-medium">Tiếng Việt</button>
