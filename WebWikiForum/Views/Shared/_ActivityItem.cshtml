@using Microsoft.Extensions.Localization
@model WebWikiForum.Models.Activity
@inject IStringLocalizer<SharedResource> Localizer

@{
    var categoryClass = Model.ActivityType.ToLower();
    
    var icon = Model.ActivityType switch {
        "Article" => Model.Action == "Created" ? "add_circle" : "edit",
        "Media" => "image",
        "Community" => Model.Action == "Commented" ? "forum" : "campaign",
        "User" => "person_add",
        _ => "history"
    };

    var iconBg = Model.Action switch {
        "Created" => "bg-green-100 dark:bg-green-900/30 text-green-600",
        "Updated" => "bg-blue-100 dark:bg-blue-900/30 text-blue-600",
        "Deleted" => "bg-red-100 dark:bg-red-900/30 text-red-600",
        "Commented" => "bg-purple-100 dark:bg-purple-900/30 text-purple-600",
        _ => "bg-slate-100 dark:bg-slate-800 text-slate-600"
    };
}

<div class="bg-white dark:bg-slate-800/40 p-4 rounded-xl border border-slate-200 dark:border-slate-700/50 flex items-start gap-4 transition-all hover:border-primary/30 group" 
     data-filter-target="rc-changes" data-category="@categoryClass">
    <div class="mt-1 @iconBg p-2 rounded-lg">
        <span class="material-symbols-outlined">@icon</span>
    </div>
    <div class="flex-1">
        <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
            <a class="text-lg font-bold text-slate-900 dark:text-white hover:text-primary transition-colors" href="@(Model.LinkUrl ?? "#")">@Model.Title</a>
            <span class="text-xs text-slate-400">@Model.Timestamp.ToString("HH:mm")</span>
        </div>
        <div class="flex items-center gap-2 mb-2">
            <div class="h-5 w-5 rounded-full overflow-hidden">
                <img alt="Editor Avatar" class="w-full h-full object-cover" src="https://ui-avatars.com/api/?name=@Model.Author&background=random"/>
            </div>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-300">@Model.Author</span>
            @if (!string.IsNullOrEmpty(Model.Detail))
            {
                var detailClass = Model.Detail.StartsWith("+") ? "text-green-600 bg-green-50 dark:bg-green-900/20" : 
                                 Model.Detail.StartsWith("-") ? "text-red-600 bg-red-50 dark:bg-red-900/20" : 
                                 "text-slate-500 bg-slate-100 dark:bg-slate-700";
                
                <span class="text-xs font-bold @detailClass px-2 py-0.5 rounded">@Model.Detail</span>
            }
        </div>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-sm text-slate-500 dark:text-slate-400 italic">"@Model.Description"</p>
        }
    </div>
    <div class="flex items-center gap-2">
        <a class="text-xs font-bold px-2 py-1 bg-slate-100 dark:bg-slate-700 rounded hover:bg-primary/10 transition-colors" href="@(Model.LinkUrl ?? "#")">view</a>
    </div>
</div>
