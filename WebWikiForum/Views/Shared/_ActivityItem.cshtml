@using Microsoft.Extensions.Localization
@model WebWikiForum.Models.Activity
@inject IStringLocalizer<SharedResource> Localizer

@{
    var categoryClass = Model.ActivityType.ToLower();
    
    var icon = Model.ActivityType switch {
        "Article" => Model.Action == "Created" ? "add_circle" : "edit",
        "Media" => "image",
        "Community" => Model.Action == "Commented" ? "forum" : "campaign",
        "User" => "person_add",
        _ => "history"
    };

    var iconBg = Model.Action switch {
        "Created"   => "bg-green-100 dark:bg-green-900/30 text-green-600",
        "Updated"   => "bg-blue-100 dark:bg-blue-900/30 text-blue-600",
        "Deleted"   => "bg-red-100 dark:bg-red-900/30 text-red-600",
        "Commented" => "bg-purple-100 dark:bg-purple-900/30 text-purple-600",
        _           => "bg-slate-100 dark:bg-slate-800 text-slate-600"
    };
}

<div class="bg-white dark:bg-slate-800/40 p-3 rounded-xl border border-slate-200 dark:border-slate-700/50 
            flex items-start gap-3 transition-all hover:border-primary/30 group overflow-hidden min-w-0"
     data-filter-target="rc-changes" data-category="@categoryClass">

    <div class="shrink-0 mt-0.5 @iconBg p-1.5 rounded-lg">
        <span class="material-symbols-outlined text-[18px]">@icon</span>
    </div>

    <div class="flex-1 min-w-0 overflow-hidden">
        <div class="flex items-start justify-between gap-2 mb-1">
            <a class="text-sm font-bold text-slate-900 dark:text-white hover:text-primary transition-colors 
                      line-clamp-2 leading-snug" 
               href="@(Model.LinkUrl ?? "#")">@Model.Title</a>
            <a class="shrink-0 text-xs font-bold px-2 py-0.5 bg-slate-100 dark:bg-slate-700 rounded 
                      hover:bg-primary/10 transition-colors whitespace-nowrap" 
               href="@(Model.LinkUrl ?? "#")">@Localizer["RC_Btn_View"]</a>
        </div>

        <div class="flex flex-wrap items-center gap-1.5 mb-1">
            <span class="text-[11px] text-slate-400 font-medium">@Model.Timestamp.ToString("HH:mm")</span>
            <div class="h-4 w-4 rounded-full overflow-hidden shrink-0">
                <img alt="@Model.Author" class="w-full h-full object-cover" 
                     src="https://ui-avatars.com/api/?name=@Model.Author&background=random"/>
            </div>
            <span class="text-xs font-medium text-slate-700 dark:text-slate-300 truncate max-w-[80px]">@Model.Author</span>
            @if (!string.IsNullOrEmpty(Model.Detail))
            {
                var detailClass = Model.Detail.StartsWith("+") ? "text-green-600 bg-green-50 dark:bg-green-900/20" : 
                                 Model.Detail.StartsWith("-") ? "text-red-600 bg-red-50 dark:bg-red-900/20" : 
                                 "text-slate-500 bg-slate-100 dark:bg-slate-700";
                <span class="text-[10px] font-bold @detailClass px-1.5 py-0.5 rounded shrink-0">@Model.Detail</span>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-xs text-slate-500 dark:text-slate-400 italic line-clamp-2">"@Model.Description"</p>
        }
    </div>
</div>
