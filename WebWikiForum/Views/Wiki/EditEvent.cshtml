@model WebWikiForum.ViewModels.NewsViewModel
@{
    ViewData["Title"] = "Edit Event";
}

<div class="max-w-4xl mx-auto px-4 py-12">
    <div class="mb-10 text-center">
        <h1 class="text-4xl font-black text-slate-900 dark:text-white mb-2">Edit <span class="text-primary italic">Event</span></h1>
        <p class="text-slate-500 dark:text-slate-400">Update the information for this news piece or highlight</p>
    </div>

    <form asp-action="EditEvent" asp-route-id="@ViewBag.Id" method="post" enctype="multipart/form-data" class="space-y-8 bg-white dark:bg-surface-dark p-8 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-xl">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

        <!-- Image Upload -->
        <div class="flex flex-col items-center">
            <div id="imagePreview" class="w-full aspect-video rounded-2xl bg-slate-100 dark:bg-slate-800 border-2 border-dashed border-slate-300 dark:border-slate-700 flex items-center justify-center overflow-hidden mb-4 relative">
                @if (!string.IsNullOrEmpty(Model.CurrentImageUrl)) {
                    <img id="previewImg" class="absolute inset-0 w-full h-full object-cover" src="@Model.CurrentImageUrl" />
                } else {
                    <span class="material-symbols-outlined text-4xl text-slate-400">add_photo_alternate</span>
                    <img id="previewImg" class="absolute inset-0 w-full h-full object-cover hidden" />
                }
            </div>
            <label class="cursor-pointer bg-primary hover:bg-primary-dark text-white px-6 py-2.5 rounded-full font-bold transition-all shadow-md active:scale-95">
                Update Cover Image
                <input type="file" name="imageFile" class="hidden" onchange="previewFile(this)" accept="image/*" />
            </label>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Title -->
            <div class="md:col-span-2 space-y-1.5">
                <label asp-for="Title" class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Event Title</label>
                <input asp-for="Title" class="w-full px-5 py-3.5 rounded-2xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" />
                <span asp-validation-for="Title" class="text-red-500 text-xs"></span>
            </div>

            <!-- Type Selector -->
            <div class="space-y-1.5">
                <label asp-for="Type" class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Event Type</label>
                <select asp-for="Type" class="w-full px-5 py-3.5 rounded-2xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all appearance-none cursor-pointer">
                    <option value="Event">Event</option>
                    <option value="Debut">Debut</option>
                    <option value="Music">Music</option>
                    <option value="ASMR">ASMR</option>
                    <option value="Gaming">Gaming</option>
                </select>
                <span asp-validation-for="Type" class="text-red-500 text-xs"></span>
            </div>

            <!-- Author -->
            <div class="space-y-1.5">
                <label asp-for="Author" class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Author Name</label>
                <input asp-for="Author" class="w-full px-5 py-3.5 rounded-2xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" />
                <span asp-validation-for="Author" class="text-red-500 text-xs"></span>
            </div>
        </div>

        <!-- Description/Content -->
        <div class="space-y-1.5">
            <label asp-for="Content" class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Rich Description</label>
            <textarea asp-for="Content" rows="6" class="w-full px-5 py-3.5 rounded-2xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all"></textarea>
        </div>

        <div class="flex items-center gap-6 pt-4 border-t border-slate-100 dark:border-slate-800/50">
            <label class="flex items-center gap-2 cursor-pointer group">
                <input asp-for="IsFeatured" type="checkbox" class="w-5 h-5 rounded border-slate-300 text-primary accent-primary" />
                <span class="text-sm font-bold text-slate-600 dark:text-slate-400 group-hover:text-primary transition-colors">Feature on Front Page</span>
            </label>
        </div>

        <div class="flex items-center justify-end gap-3 pt-6">
            <a href="/Wiki/VirtualEvents" class="px-8 py-3 rounded-full font-bold text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all">Cancel</a>
            <button type="submit" class="px-10 py-3 bg-primary hover:bg-primary-dark text-white rounded-full font-bold shadow-lg shadow-primary/25 transition-all active:scale-95">
                Save Changes
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function previewFile(input) {
            const preview = document.getElementById('previewImg');
            const placeholder = document.querySelector('#imagePreview .material-symbols-outlined');
            const file = input.files[0];
            const reader = new FileReader();

            reader.addEventListener("load", function () {
                preview.src = reader.result;
                preview.classList.remove('hidden');
                if (placeholder) placeholder.classList.add('hidden');
            }, false);

            if (file) {
                reader.readAsDataURL(file);
            }
        }
    </script>
}
