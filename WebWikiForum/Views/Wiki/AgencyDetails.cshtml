@model WebWikiForum.Models.Agency
@{
    ViewData["Title"] = Model.Name + " - VTuber Agency Profile";

    string GetYoutubeId(string? url) {
        if (string.IsNullOrEmpty(url)) return "";
        try {
            var uri = new Uri(url);
            if (uri.Host.Contains("youtu.be")) return uri.AbsolutePath.Trim('/');
            if (uri.Query.Contains("v=")) {
                var q = uri.Query.TrimStart('?').Split('&').FirstOrDefault(x => x.StartsWith("v="));
                if (q != null) return q.Substring(2);
            }
        } catch {}
        return "";
    }
    
    string introVideoId = GetYoutubeId(Model.IntroVideoUrl);
}

<div class="fixed inset-0 pointer-events-none bg-dots z-0"></div>
<div class="relative z-10">
    <!-- Hero Section -->
    <div class="relative h-64 md:h-80 w-full overflow-hidden">
        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
        {
            <div class="absolute inset-0 bg-cover bg-center cursor-pointer pointer-events-auto" data-lightbox="@Model.CoverImageUrl" style="background-image: url('@Model.CoverImageUrl')"></div>
        }
        else if (!string.IsNullOrEmpty(Model.LogoUrl))
        {
            <div class="absolute inset-0 bg-cover bg-center blur-2xl opacity-50 scale-110" style="background-image: url('@Model.LogoUrl')"></div>
        }
        else
        {
            <div class="absolute inset-0 bg-cover bg-center" style="background-image: linear-gradient(to bottom, rgba(15, 12, 41, 0.6), rgba(48, 43, 99, 0.9));"></div>
        }
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class="max-w-7xl mx-auto px-4 w-full flex flex-col md:flex-row items-center gap-8 translate-y-12 md:translate-y-16 pointer-events-auto">
                <!-- Agency Logo Large -->
                <div class="w-32 h-32 md:w-48 md:h-48 rounded-3xl bg-white dark:bg-slate-800 shadow-2xl shadow-primary/20 border-4 border-white dark:border-slate-800 flex items-center justify-center overflow-hidden shrink-0">
                    @if (!string.IsNullOrEmpty(Model.LogoUrl))
                    {
                        <img src="@Model.LogoUrl" alt="@Model.Name" class="w-full h-full object-cover cursor-pointer hover:opacity-90 transition-opacity lightbox-img" data-lightbox="@Model.LogoUrl" />
                    }
                    else
                    {
                        <span class="text-4xl font-black text-primary">@Model.Name.Substring(0, 1)</span>
                    }
                </div>
                <!-- Agency Header Info -->
                <div class="text-center md:text-left text-white">
                    <div class="flex flex-wrap items-center justify-center md:justify-start gap-3 mb-2">
                        <span class="px-3 py-1 rounded-full bg-primary/20 backdrop-blur-md border border-primary/30 text-xs font-bold uppercase tracking-widest">
                            @Localizer["Wiki_Profile_Type"]
                        </span>
                        <span class="px-3 py-1 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-xs font-bold uppercase tracking-widest flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">location_on</span>
                            @Model.Region
                        </span>
                    </div>
                    <h1 class="text-4xl md:text-6xl font-black tracking-tighter mb-4">@Model.Name</h1>
                    <div class="flex items-center justify-center md:justify-start gap-6 opacity-80 font-bold overflow-x-auto no-scrollbar">
                        <div class="flex items-center gap-2 whitespace-nowrap">
                            <span class="material-symbols-outlined">groups</span>
                            <span>@string.Format(Localizer["Wiki_Talents_Count"].Value, Model.Vtubers?.Count ?? 0)</span>
                        </div>
                        <div class="flex items-center gap-2 whitespace-nowrap">
                            <span class="material-symbols-outlined">stars</span>
                            <span>@Model.Focus</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto px-4 pt-24 md:pt-32 pb-16">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Sidebar: About -->
            <div class="lg:col-span-1 space-y-6">
                <div class="bg-white dark:bg-surface-dark rounded-3xl p-8 border border-slate-200 dark:border-slate-800 shadow-sm">
                    <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">info</span>
                        @string.Format(Localizer["Wiki_Label_About"].Value, Model.Name)
                    </h2>
                    <p class="text-slate-600 dark:text-slate-400 leading-relaxed text-sm">
                        @(string.IsNullOrEmpty(Model.Description) ? Localizer["Wiki_No_Desc"].Value : Model.Description)
                    </p>
                </div>
                @if (!string.IsNullOrEmpty(Model.WebsiteUrl) || !string.IsNullOrEmpty(Model.YoutubeUrl) || !string.IsNullOrEmpty(Model.TwitterUrl))
                {
                    <div class="bg-primary/5 rounded-3xl p-8 border border-primary/10">
                        <h3 class="font-bold text-primary mb-3">@Localizer["Wiki_Community_Links"]</h3>
                        <div class="space-y-3">
                            @if (!string.IsNullOrEmpty(Model.WebsiteUrl))
                            {
                                <a href="@Model.WebsiteUrl" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between p-3 rounded-xl bg-white dark:bg-slate-800 border border-slate-100 dark:border-slate-700 hover:border-primary transition-all group">
                                    <span class="text-sm font-bold text-slate-700 dark:text-slate-300">@Localizer["Wiki_Official_Website"]</span>
                                    <span class="material-symbols-outlined text-slate-400 group-hover:text-primary">language</span>
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(Model.YoutubeUrl))
                            {
                                <a href="@Model.YoutubeUrl" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between p-3 rounded-xl bg-white dark:bg-slate-800 border border-slate-100 dark:border-slate-700 hover:border-primary transition-all group">
                                    <span class="text-sm font-bold text-slate-700 dark:text-slate-300">@Localizer["Wiki_Youtube_Channel"]</span>
                                    <span class="material-symbols-outlined text-slate-400 group-hover:text-primary">smart_display</span>
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(Model.TwitterUrl))
                            {
                                <a href="@Model.TwitterUrl" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between p-3 rounded-xl bg-white dark:bg-slate-800 border border-slate-100 dark:border-slate-700 hover:border-primary transition-all group">
                                    <span class="text-sm font-bold text-slate-700 dark:text-slate-300">@Localizer["Wiki_Social_Twitter"]</span>
                                    <span class="material-symbols-outlined text-slate-400 group-hover:text-primary">open_in_new</span>
                                </a>
                            }
                        </div>
                    </div>
                }
                
                @if (!string.IsNullOrEmpty(Model.IntroVideoUrl) && !string.IsNullOrEmpty(introVideoId))
                {
                    <div class="mt-6">
                        <h2 class="text-xl font-bold text-slate-800 dark:text-slate-200 mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-red-500">play_circle</span>
                            @Localizer["Wiki_Label_IntroVideo"]
                        </h2>
                        <a href="@Model.IntroVideoUrl" target="_blank" rel="noopener noreferrer" class="block group relative rounded-2xl overflow-hidden shadow-lg border border-slate-200 dark:border-slate-800 bg-slate-100 dark:bg-slate-900 aspect-video w-full">
                            <img src="https://img.youtube.com/vi/@introVideoId/maxresdefault.jpg" onerror="this.src='https://img.youtube.com/vi/@introVideoId/hqdefault.jpg'" alt="Intro Video Thumbnail" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                            <div class="absolute inset-0 bg-black/30 group-hover:bg-black/10 transition-colors flex items-center justify-center">
                                <div class="w-16 h-16 bg-red-600/90 text-white rounded-full flex items-center justify-center shadow-xl transform transition-transform duration-300 group-hover:scale-110 group-hover:bg-red-600">
                                    <span class="material-symbols-outlined text-3xl ml-1">play_arrow</span>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>

            <!-- Right: Talents Grid -->
            <div class="lg:col-span-2 space-y-6">
                <div class="flex items-center justify-between px-2">
                    <h2 class="text-2xl font-black text-slate-900 dark:text-white tracking-tight">@Localizer["Wiki_Current_Talents"]</h2>
                    <div class="flex items-center gap-2 text-xs font-bold text-slate-500">
                        <span class="material-symbols-outlined text-sm">sort</span>
                        @Localizer["Wiki_Recently_Active"]
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    @if (Model.Vtubers != null && Model.Vtubers.Any())
                    {
                        foreach (var vtuber in Model.Vtubers)
                        {
                            <a href="/Wiki/Details/@vtuber.Id" class="group flex items-center p-4 rounded-2xl bg-white dark:bg-surface-dark border border-slate-100 dark:border-slate-800 hover:border-primary hover:shadow-xl hover:shadow-primary/5 transition-all">
                                <div class="w-16 h-16 rounded-xl overflow-hidden bg-slate-100 dark:bg-slate-800 border border-slate-100 dark:border-slate-700 shrink-0">
                                    <img src="@(string.IsNullOrEmpty(vtuber.AvatarUrl) ? "https://lh3.googleusercontent.com/pw/AP1GczPLjX65S_A" : vtuber.AvatarUrl)" alt="@vtuber.Name" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                </div>
                                <div class="ml-4 flex-1">
                                    <h3 class="font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors">@vtuber.Name</h3>
                                    <div class="flex items-center gap-2 mt-1">
                                        <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-green-100 text-green-700 uppercase">@vtuber.Status</span>
                                        <span class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">@vtuber.Region</span>
                                    </div>
                                </div>
                                <span class="material-symbols-outlined text-slate-300 group-hover:text-primary group-hover:translate-x-1 transition-all">chevron_right</span>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="col-span-full p-12 bg-slate-50 dark:bg-slate-800/50 rounded-3xl border-2 border-dashed border-slate-200 dark:border-slate-700 text-center">
                            <span class="material-symbols-outlined text-4xl text-slate-300 mb-2">person_search</span>
                            <p class="font-bold text-slate-500">@Localizer["Wiki_No_Talents"]</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
