@model IEnumerable<WebWikiForum.Models.Vtuber>
@section Styles {
    <link rel="stylesheet" href="~/css/Independent.css" />
}

<div class="relative min-h-screen flex flex-col">
<!-- Nền hoa văn -->
<div class="fixed inset-0 dot-pattern pointer-events-none"></div>

<main class="flex-grow max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-10">
<!-- Phần banner chính -->
<section class="mb-12">
<div class="relative overflow-hidden rounded-3xl bg-primary/10 p-8 md:p-12">
<div class="relative z-10 max-w-2xl">
<h1 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-4 leading-tight">
                            @Localizer["Indie_Title"]
                        </h1>
<p class="text-lg text-slate-600 dark:text-slate-300 mb-8">
                            @Localizer["Indie_Desc"]
                        </p>
<div class="flex flex-wrap gap-4">
<button class="bg-primary hover:bg-primary/90 text-white px-8 py-3 rounded-xl font-bold transition-all transform hover:scale-105">
                                @Localizer["Indie_Btn_Learn"]
                            </button>
<button class="bg-white/50 dark:bg-slate-800/50 backdrop-blur px-8 py-3 rounded-xl font-bold border border-primary/20 hover:bg-white transition-all">
                                @Localizer["Indie_Btn_HowTo"]
                            </button>
</div>
</div>
</div>
</section>

<!-- Search & Filters -->
<section class="mb-10 space-y-6">
<form method="get" asp-action="Independent" class="max-w-4xl mx-auto -mt-8 relative z-20 px-4">
<div class="flex flex-col md:flex-row gap-4">
<div class="flex-grow relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-primary">search</span>
<input name="searchTerm" value='@ViewData["SearchTerm"]' class="w-full pl-12 pr-4 py-4 bg-white dark:bg-slate-900 border border-primary/10 rounded-2xl shadow-sm focus:ring-2 focus:ring-primary/20 focus:border-primary" placeholder="@Localizer["Indie_Search_Placeholder"]" type="text"/>
</div>
<div class="flex gap-3 pb-2 md:pb-0">
<div class="relative min-w-[140px]">
<select name="region" onchange="this.form.submit()" class="w-full h-full pl-4 pr-10 border border-primary/10 rounded-xl bg-white dark:bg-slate-900 text-sm font-semibold appearance-none cursor-pointer focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all">
<option value="all">@Localizer["Indie_Filter_Region"]</option>
<option value="Japan" selected='@(ViewData["Region"]?.ToString() == "Japan")'>@Localizer["Region_Japan"]</option>
<option value="United States" selected='@(ViewData["Region"]?.ToString() == "United States")'>@Localizer["Region_United States"]</option>
<option value="China" selected='@(ViewData["Region"]?.ToString() == "China")'>@Localizer["Region_China"]</option>
<option value="Vietnam" selected='@(ViewData["Region"]?.ToString() == "Vietnam")'>@Localizer["Region_Vietnam"]</option>
<option value="Indonesia" selected='@(ViewData["Region"]?.ToString() == "Indonesia")'>@Localizer["Region_Indonesia"]</option>
<option value="Global" selected='@(ViewData["Region"]?.ToString() == "Global")'>@Localizer["Region_Global"]</option>
</select>
<span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">expand_more</span>
</div>
<div class="relative min-w-[140px]">
<select name="language" onchange="this.form.submit()" class="w-full h-full pl-4 pr-10 border border-primary/10 rounded-xl bg-white dark:bg-slate-900 text-sm font-semibold appearance-none cursor-pointer focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all">
<option value="all">@Localizer["Indie_Filter_Language"]</option>
<option value="English" selected='@(ViewData["Language"]?.ToString() == "English")'>@Localizer["Lang_English"]</option>
<option value="Japanese" selected='@(ViewData["Language"]?.ToString() == "Japanese")'>@Localizer["Lang_Japanese"]</option>
<option value="Chinese" selected='@(ViewData["Language"]?.ToString() == "Chinese")'>@Localizer["Lang_Chinese"]</option>
<option value="Vietnamese" selected='@(ViewData["Language"]?.ToString() == "Vietnamese")'>@Localizer["Lang_Vietnamese"]</option>
<option value="Indonesian" selected='@(ViewData["Language"]?.ToString() == "Indonesian")'>@Localizer["Lang_Indonesian"]</option>
</select>
<span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">expand_more</span>
</div>
</div>
</div>
</form>

<div class="flex flex-wrap gap-2">
<span class="px-3 py-1 bg-primary/10 text-primary text-xs font-bold rounded-full uppercase tracking-wider">@Localizer["Indie_PopularTags"]</span>
<a class="px-3 py-1 bg-white dark:bg-slate-800 border border-primary/5 rounded-full text-xs hover:border-primary transition-colors cursor-pointer" asp-action="Independent" asp-route-tag="Gaming">@Localizer["Events_Filter_Gaming"]</a>
<a class="px-3 py-1 bg-white dark:bg-slate-800 border border-primary/5 rounded-full text-xs hover:border-primary transition-colors cursor-pointer" asp-action="Independent" asp-route-tag="Singing">@Localizer["Events_Filter_Music"]</a>
<a class="px-3 py-1 bg-white dark:bg-slate-800 border border-primary/5 rounded-full text-xs hover:border-primary transition-colors cursor-pointer" asp-action="Independent" asp-route-tag="ASMR">@Localizer["Events_Filter_ASMR"]</a>
</div>
</section>

<!-- Talent Grid -->
<section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
@foreach (var vtuber in Model)
{
<div class="group bg-white dark:bg-slate-900 rounded-3xl overflow-hidden border border-primary/5 shadow-sm hover:shadow-xl hover:border-primary/20 transition-all">
<div class="aspect-square relative overflow-hidden">
<img alt="@vtuber.Name Avatar" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" src="@(string.IsNullOrEmpty(vtuber.AvatarUrl) ? "https://lh3.googleusercontent.com/aida-public/AB6AXuBcwqJmvI6QRhBoLIvALsqquG49TuN0g7UBVPkcoSNKKy9vCM6dN1_VrD4lpd7U7We5VcrAh0xyQ_pF7ZRJWi9xRe8pGEIncoMe78B52USIo5eq2dLHcBLuwQnGtyHU8D72b_9E38dspsL3CjHGaANusFkBvfszldyi6RRlEtSikuNm-3uo1iLiB8rsBRVu4OLrXFtBNSTOLkpM5nOLYuI9Gy3NJhrtjwM8Y0D1FbZ8Ql6_6Tu4OtbFSTWFM7Wrl_dk-1yA5gTxYzE" : vtuber.AvatarUrl)"/>
<div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
<p class="text-white text-xs leading-tight">@vtuber.Lore</p>
</div>
</div>
<div class="p-6">
<h3 class="text-xl font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors">@vtuber.Name</h3>
<div class="flex items-center gap-2 mt-1 mb-4">
<span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-[10px] font-bold rounded uppercase tracking-wider">@Localizer["Lang_" + vtuber.Language]</span>
<span class="text-slate-400 text-xs">•</span>
                        <span class="text-slate-500 dark:text-slate-400 text-[10px] font-bold uppercase tracking-wider">@Localizer["Region_" + vtuber.Region]</span>
</div>
<a href="/Wiki/Details/@vtuber.Id" class="block w-full">
<button class="w-full py-3 bg-primary text-white rounded-xl font-bold hover:brightness-110 transition-all shadow-lg shadow-primary/20">
                            @Localizer["Btn_ViewProfile"]
                        </button>
</a>
</div>
</div>
}
</section>

<!-- Pagination/Load More -->
<div class="mt-12 flex justify-center">
<button class="flex items-center gap-2 px-10 py-4 bg-white dark:bg-slate-900 border border-primary/20 rounded-2xl font-bold hover:bg-primary/5 transition-all">
                    @Localizer["Indie_Btn_LoadMore"]
<span class="material-symbols-outlined">expand_more</span>
</button>
</div>
</main>
</div>
