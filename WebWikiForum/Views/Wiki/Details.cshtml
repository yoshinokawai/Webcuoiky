@model WebWikiForum.Models.Vtuber
@{
    ViewData["Title"] = Model.Name + " - " + Localizer["Wiki_Profile_Type"].Value;

    string GetYoutubeId(string? url) {
        if (string.IsNullOrEmpty(url)) return "";
        try {
            var uri = new Uri(url);
            if (uri.Host.Contains("youtu.be")) return uri.AbsolutePath.Trim('/');
            if (uri.Query.Contains("v=")) {
                var q = uri.Query.TrimStart('?').Split('&').FirstOrDefault(x => x.StartsWith("v="));
                if (q != null) return q.Substring(2);
            }
        } catch {}
        return "";
    }
    
    string introVideoId = GetYoutubeId(Model.IntroVideoUrl);
}

<div class="max-w-4xl mx-auto px-4 py-8 sm:px-6 lg:px-8 mt-12 mb-20">
    <div class="bg-white dark:bg-surface-dark border border-slate-200 dark:border-slate-800 rounded-3xl overflow-hidden shadow-xl">
        
        <!-- Header Banner -->
        <div class="h-64 sm:h-80 relative overflow-hidden bg-primary/10">
            @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
            {
                <div class="absolute inset-0 bg-cover bg-center cursor-pointer" data-lightbox="@Model.CoverImageUrl" style="background-image: url('@Model.CoverImageUrl')"></div>
            }
            else if (!string.IsNullOrEmpty(Model.AvatarUrl))
            {
                <div class="absolute inset-0 bg-cover bg-center blur-2xl opacity-50 scale-110" style="background-image: url('@Model.AvatarUrl')"></div>
            }
            <!-- pointer-events-none so the gradient doesn't block clicks on the cover -->
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent pointer-events-none"></div>
        </div>

        <!-- Profile Content -->
        <div class="relative px-6 sm:px-12 pb-12">
            <!-- Avatar Overlay -->
            <div class="-mt-24 sm:-mt-32 mb-6 flex justify-between items-end">
                <div class="relative">
                    @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                    {
                        <img src="@Model.AvatarUrl" alt="@Model.Name Avatar" class="w-40 h-40 sm:w-48 sm:h-48 rounded-full border-4 border-white dark:border-surface-dark shadow-2xl object-cover bg-white dark:bg-surface-dark cursor-pointer hover:opacity-90 transition-opacity lightbox-img" data-lightbox="@Model.AvatarUrl" />
                    }
                    else
                    {
                        <div class="w-40 h-40 sm:w-48 sm:h-48 rounded-full border-4 border-white dark:border-surface-dark shadow-2xl flex items-center justify-center bg-slate-100 dark:bg-slate-800 text-slate-400">
                            <span class="material-symbols-outlined text-6xl">person</span>
                        </div>
                    }
                    <div class="absolute bottom-2 right-2 w-6 h-6 bg-green-500 border-2 border-white dark:border-surface-dark rounded-full"></div>
                </div>
                
                <div class="flex flex-wrap gap-2 justify-end">
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Wiki/Edit/@Model.Id" class="mb-4 bg-primary hover:bg-primary-dark text-white rounded-full px-6 py-2.5 font-bold transition-transform hover:scale-105 inline-flex items-center gap-2 text-sm shadow-md">
                            <span class="material-symbols-outlined text-lg">edit</span>
                            @Localizer["Details_Btn_Edit"]
                        </a>

                        <form asp-controller="Wiki" asp-action="Delete" method="post" onsubmit="event.preventDefault(); window.showConfirmModal({ title: '@Localizer["Dash_Action_Delete"]', message: '@string.Format(Localizer["Dash_Confirm_Delete"].Value, Model.Name)', onConfirm: () => this.submit() });" style="display:inline;">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="mb-4 bg-red-500 hover:bg-red-600 text-white rounded-full px-6 py-2.5 font-bold transition-transform hover:scale-105 inline-flex items-center gap-2 text-sm shadow-md">
                                <span class="material-symbols-outlined text-lg">delete</span>
                                @Localizer["Dash_Action_Delete"]
                            </button>
                        </form>
                    }
                </div>
            </div>

            <!-- Basic Info -->
            <div class="mb-8 border-b border-slate-200 dark:border-slate-800 pb-8">
                <h1 class="text-4xl sm:text-5xl font-black text-slate-900 dark:text-white tracking-tight mb-2">@Model.Name</h1>
                
                <div class="flex flex-wrap items-center gap-4 text-slate-600 dark:text-slate-400 font-medium">
                    <span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-sm">
                        @(Model.Agency != null ? Model.Agency.Name : Localizer["Details_Independent"].Value)
                    </span>
                    @if (Model.Age.HasValue)
                    {
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-sm">cake</span> @Localizer["Details_Label_Age"] @Model.Age</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Birthday))
                    {
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-sm">calendar_month</span> @Model.Birthday</span>
                    }

                    @if (!string.IsNullOrEmpty(Model.YoutubeUrl))
                    {
                        <a href="@Model.YoutubeUrl" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-red-600 text-white hover:bg-red-700 transition shadow-sm font-bold text-sm">
                            <i class="fa-brands fa-youtube"></i>
                            YouTube
                        </a>
                    }
                </div>
            </div>

            <!-- Lore Section -->
            <div>
                <h2 class="text-2xl font-bold text-slate-800 dark:text-slate-200 mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">auto_awesome</span>
                    @Localizer["Details_Lore_Title"]
                </h2>
                <div class="prose dark:prose-invert max-w-none text-slate-600 dark:text-slate-400 leading-relaxed bg-slate-50 dark:bg-slate-800/50 p-6 rounded-2xl border border-slate-100 dark:border-slate-700/50">
                    @if (!string.IsNullOrEmpty(Model.Lore))
                    {
                        @Html.Raw(Model.Lore.Replace("\n", "<br/>"))
                    }
                    else
                    {
                        <p class="italic text-slate-500">@Localizer["Details_Lore_Empty"]</p>
                    }
                </div>
            </div>
            
            <!-- Intro Video Section -->
            @if (!string.IsNullOrEmpty(Model.IntroVideoUrl) && !string.IsNullOrEmpty(introVideoId))
            {
                <div class="mt-12">
                    <h2 class="text-2xl font-bold text-slate-800 dark:text-slate-200 mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-red-500">play_circle</span>
                        @Localizer["Wiki_Label_IntroVideo"]
                    </h2>
                    <a href="@Model.IntroVideoUrl" target="_blank" rel="noopener noreferrer" class="block group relative rounded-2xl overflow-hidden shadow-lg border border-slate-200 dark:border-slate-800 bg-slate-100 dark:bg-slate-900 aspect-video max-w-3xl">
                        <img src="https://img.youtube.com/vi/@introVideoId/maxresdefault.jpg" onerror="this.src='https://img.youtube.com/vi/@introVideoId/hqdefault.jpg'" alt="Intro Video Thumbnail" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                        <div class="absolute inset-0 bg-black/30 group-hover:bg-black/10 transition-colors flex items-center justify-center pointer-events-none">
                            <div class="w-20 h-20 bg-red-600/90 text-white rounded-full flex items-center justify-center shadow-xl transform transition-transform duration-300 group-hover:scale-110 group-hover:bg-red-600">
                                <span class="material-symbols-outlined text-4xl ml-1">play_arrow</span>
                            </div>
                        </div>
                    </a>
                </div>
            }
            
        </div>
    </div>
</div>
