@model WebWikiForum.ViewModels.VtuberViewModel

@{
    ViewData["Title"] = Localizer["Wiki_Edit_Profile"] ?? "Edit Profile";
    Layout = "_Layout";
}

<div class="max-w-3xl mx-auto px-4 py-12">
    <div class="mb-8">
        <h1 class="text-3xl font-black tracking-tight text-slate-900 dark:text-white mb-2">@Localizer["Wiki_Edit_Profile"]</h1>
        <p class="text-slate-500 dark:text-slate-400">@Localizer["Wiki_Edit_Subtitle"]</p>
    </div>

    <div class="bg-white dark:bg-surface-dark border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm p-6 sm:p-8">
        <form asp-action="Edit" asp-controller="Wiki" method="post" enctype="multipart/form-data" class="space-y-6">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@ViewBag.Id" />
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <!-- Upload ảnh đại diện -->
                <div>
                    <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Wiki_Label_Avatar"]</label>
                    
                    @if (!string.IsNullOrEmpty(ViewBag.CurrentAvatar))
                    {
                        <div class="mb-4 flex items-center gap-4 p-4 bg-slate-50 dark:bg-slate-800/50 rounded-xl border border-slate-100 dark:border-slate-700">
                            <img src="@ViewBag.CurrentAvatar" class="w-16 h-16 rounded-full object-cover border-2 border-primary/20" />
                            <div>
                                <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">@Localizer["Wiki_Avatar_Current"]</p>
                                <p class="text-sm text-slate-600 dark:text-slate-400">@Localizer["Wiki_Avatar_Keep"]</p>
                            </div>
                        </div>
                    }

                    <div class="mt-1 flex flex-col justify-center items-center px-6 pt-5 pb-6 border-2 border-slate-300 dark:border-slate-700 border-dashed rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors cursor-pointer" onclick="document.getElementById('avatarFile').click()">
                        <div class="space-y-1 text-center">
                            <span class="material-symbols-outlined text-slate-400 text-4xl mb-2">cloud_upload</span>
                            <div class="text-sm text-slate-600 dark:text-slate-400 flex justify-center items-center gap-1">
                                <span class="font-medium text-primary hover:text-primary-dark">@Localizer["Wiki_Upload_File"]</span>
                                <span>@Localizer["Wiki_Upload_Drop"]</span>
                                <input id="avatarFile" name="avatarFile" type="file" class="sr-only" accept="image/*" onchange="openCropper(this, 'avatar')">
                            </div>
                            <p id="fileNameDisplay" class="text-xs text-slate-500 dark:text-slate-500 mt-2">@Localizer["Wiki_Upload_PNG"]</p>
                        </div>
                    </div>
                    <div id="avatarCropPreview" class="hidden mt-3 relative">
                        <img id="avatarCropPreviewImg" class="w-16 h-16 rounded-full object-cover border-2 border-primary mx-auto" />
                        <p class="text-xs text-center text-emerald-500 font-bold mt-1">✓ Cropped &amp; Ready</p>
                    </div>
                </div>

                <!-- Upload ảnh bìa -->
                <div>
                    <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Wiki_Label_CoverImage"]</label>
                    
                    @if (!string.IsNullOrEmpty(ViewBag.CurrentCover))
                    {
                        <div class="mb-4 flex items-center gap-4 p-4 bg-slate-50 dark:bg-slate-800/50 rounded-xl border border-slate-100 dark:border-slate-700">
                            <img src="@ViewBag.CurrentCover" class="w-24 h-12 rounded object-cover border border-slate-200 dark:border-slate-600" />
                            <div>
                                <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">@Localizer["Wiki_Avatar_Current"]</p>
                                <p class="text-sm text-slate-600 dark:text-slate-400">@Localizer["Wiki_Avatar_Keep"]</p>
                            </div>
                        </div>
                    }

                    <div class="mt-1 flex flex-col justify-center items-center px-6 pt-5 pb-6 border-2 border-slate-300 dark:border-slate-700 border-dashed rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors cursor-pointer" onclick="document.getElementById('coverImageFile').click()">
                        <div class="space-y-1 text-center">
                            <span class="material-symbols-outlined text-slate-400 text-4xl mb-2">wallpaper</span>
                            <div class="text-sm text-slate-600 dark:text-slate-400 flex justify-center items-center gap-1">
                                <span class="font-medium text-primary hover:text-primary-dark">@Localizer["Wiki_Upload_File"]</span>
                                <span>@Localizer["Wiki_Upload_Drop"]</span>
                                <input id="coverImageFile" name="coverImageFile" type="file" class="sr-only" accept="image/*" onchange="openCropper(this, 'cover')">
                            </div>
                            <p id="coverFileNameDisplay" class="text-xs text-slate-500 dark:text-slate-500 mt-2">@Localizer["Wiki_Upload_PNG"]</p>
                        </div>
                    </div>
                    <div id="coverCropPreview" class="hidden mt-3 relative">
                        <img id="coverCropPreviewImg" class="w-full h-20 rounded-xl object-cover border-2 border-primary" />
                        <p class="text-xs text-center text-emerald-500 font-bold mt-1">✓ Cropped &amp; Ready</p>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Name -->
                <div>
                    <label asp-for="Name" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Wiki_Label_Name"]</label>
                    <input asp-for="Name" class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-white dark:focus:bg-surface-dark transition-colors" placeholder="@Localizer["Wiki_Placeholder_Name"]" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- YouTube URL -->
                <div>
                    <label asp-for="YoutubeUrl" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Wiki_Label_Youtube"]</label>
                    <input asp-for="YoutubeUrl" class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-white dark:focus:bg-surface-dark transition-colors" placeholder="@Localizer["Wiki_Placeholder_Youtube"]" />
                    <span asp-validation-for="YoutubeUrl" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Intro Video URL -->
                <div>
                    <label asp-for="IntroVideoUrl" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Wiki_Label_IntroVideo"]</label>
                    <input asp-for="IntroVideoUrl" class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-white dark:focus:bg-surface-dark transition-colors" placeholder="https://www.youtube.com/watch?v=..." />
                    <span asp-validation-for="IntroVideoUrl" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Age -->
                <div>
                    <label asp-for="Age" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Wiki_Label_Age_Label"]</label>
                    <input asp-for="Age" type="number" class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-white dark:focus:bg-surface-dark transition-colors" placeholder="@Localizer["Wiki_Placeholder_Age"]" />
                </div>

                <!-- Birthday -->
                <div>
                    <label asp-for="Birthday" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Wiki_Label_Birthday"]</label>
                    <input asp-for="Birthday" class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-white dark:focus:bg-surface-dark transition-colors" placeholder="@Localizer["Wiki_Placeholder_Birthday"]" />
                </div>

                <!-- Debut Date -->
                <div>
                    <label asp-for="DebutDate" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Wiki_Label_Debut"]</label>
                    <input asp-for="DebutDate" type="date" class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-white dark:focus:bg-surface-dark transition-colors text-slate-700 dark:text-slate-300" />
                </div>

                <!-- AgencyId -->
                <div>
                    <label asp-for="AgencyId" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Wiki_Label_Agency"]</label>
                    <div class="flex gap-2">
                        <select asp-for="AgencyId" id="agencySelect" class="flex-1 px-4 py-3 bg-slate-50 dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-white dark:focus:bg-surface-dark transition-colors text-slate-700 dark:text-slate-300">
                            <option value="">-- @Localizer["Details_Independent"] --</option>
                            @if (ViewBag.Agencies != null)
                            {
                                foreach (var agency in ViewBag.Agencies)
                                {
                                    <option value="@agency.Id">@agency.Name</option>
                                }
                            }
                        </select>
                        <button type="button" onclick="openAgencyModal()" class="w-12 h-12 flex items-center justify-center bg-primary/10 hover:bg-primary/20 text-primary rounded-xl transition-colors border border-primary/20" title="Quick Add New Agency">
                            <span class="material-symbols-outlined">add</span>
                        </button>
                    </div>
                </div>

                <!-- Region -->
                <div>
                    <label asp-for="Region" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Wiki_Label_Region"]</label>
                    <select asp-for="Region" class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-white dark:focus:bg-surface-dark transition-colors text-slate-700 dark:text-slate-300">
                        <option value="Japan">@Localizer["Region_Japan"]</option>
                        <option value="United States">@Localizer["Region_United States"]</option>
                        <option value="China">@Localizer["Region_China"]</option>
                        <option value="Vietnam">@Localizer["Region_Vietnam"]</option>
                        <option value="Indonesia">@Localizer["Region_Indonesia"]</option>
                        <option value="Global">@Localizer["Region_Global"]</option>
                    </select>
                    <span asp-validation-for="Region" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Language -->
                <div>
                    <label asp-for="Language" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Wiki_Label_Language"]</label>
                    <input asp-for="Language" class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-white dark:focus:bg-surface-dark transition-colors" placeholder="@Localizer["Wiki_Placeholder_Language"]" />
                    <span asp-validation-for="Language" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Tags -->
                <div>
                    <label asp-for="Tags" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Wiki_Label_Tags"]</label>
                    <input asp-for="Tags" class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-white dark:focus:bg-surface-dark transition-colors" placeholder="@Localizer["Wiki_Placeholder_Tags"]" />
                    <span asp-validation-for="Tags" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>

            <!-- Lore -->
            <div>
                <label asp-for="Lore" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Wiki_Label_Lore"]</label>
                <textarea asp-for="Lore" rows="5" class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-white dark:focus:bg-surface-dark transition-colors resize-none" placeholder="@Localizer["Wiki_Placeholder_Lore"]"></textarea>
            </div>

            <div class="pt-4 flex justify-end gap-3">
                <a asp-action="Details" asp-controller="Wiki" asp-route-id="@ViewBag.Id" class="px-6 py-3 border border-slate-200 dark:border-slate-700 rounded-full font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">@Localizer["Wiki_Btn_Cancel"]</a>
                <button type="submit" class="px-8 py-3 bg-primary text-white font-bold rounded-full shadow-sm hover:bg-primary-dark transition-colors">
                    @Localizer["Wiki_Btn_Update"]
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal cắt ảnh -->
<div id="cropperModal" class="fixed inset-0 z-[200] hidden">
    <div class="flex items-center justify-center min-h-screen p-4">
        <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm"></div>
        <div class="relative bg-white dark:bg-slate-900 p-6 rounded-2xl shadow-2xl w-full max-w-2xl border border-slate-200 dark:border-slate-700">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <h3 id="cropperTitle" class="text-lg font-black text-slate-900 dark:text-white">Điều chỉnh ảnh</h3>
                    <p id="cropperSubtitle" class="text-xs text-slate-500 mt-0.5">Kéo để chọn vùng ảnh phù hợp</p>
                </div>
                <button type="button" onclick="closeCropper()" class="w-8 h-8 flex items-center justify-center rounded-full bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 transition-colors">
                    <span class="material-symbols-outlined text-[18px]">close</span>
                </button>
            </div>

            <!-- Cropper hint badges -->
            <div class="flex gap-2 mb-3">
                <span id="cropRatioLabel" class="inline-flex items-center gap-1 px-2 py-0.5 bg-primary/10 text-primary text-xs font-bold rounded-full">
                    <span class="material-symbols-outlined text-[14px]">crop</span>
                    <span id="cropRatioText">1:1</span>
                </span>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-slate-500 text-xs rounded-full">
                    <span class="material-symbols-outlined text-[14px]">pan_zoom</span>
                    Scroll để zoom
                </span>
            </div>

            <div class="relative bg-slate-950 rounded-xl overflow-hidden" style="max-height:400px">
                <img id="cropperImage" class="max-w-full block" />
            </div>

            <!-- Controls -->
            <div class="flex items-center gap-2 mt-4">
                <button type="button" onclick="cropperInstance && cropperInstance.rotate(-90)" class="flex-1 py-2 text-sm font-bold bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 rounded-xl transition-colors flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">rotate_left</span> -90°
                </button>
                <button type="button" onclick="cropperInstance && cropperInstance.rotate(90)" class="flex-1 py-2 text-sm font-bold bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 rounded-xl transition-colors flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">rotate_right</span> +90°
                </button>
                <button type="button" onclick="cropperInstance && cropperInstance.scaleX(cropperInstance.getData().scaleX === -1 ? 1 : -1)" class="flex-1 py-2 text-sm font-bold bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 rounded-xl transition-colors flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">flip</span> Lật ngang
                </button>
                <button type="button" onclick="cropperInstance && cropperInstance.reset()" class="flex-1 py-2 text-sm font-bold bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 rounded-xl transition-colors flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">refresh</span> Reset
                </button>
            </div>

            <div class="flex gap-3 mt-4">
                <button type="button" onclick="closeCropper()" class="flex-1 py-3 text-sm font-bold border border-slate-200 dark:border-slate-700 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">Huỷ</button>
                <button type="button" onclick="applyCrop()" class="flex-2 px-8 py-3 text-sm font-bold bg-primary text-white rounded-xl shadow-sm hover:bg-primary-dark transition-colors flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">check_circle</span>
                    Áp dụng & Xem trước
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Quick Add Agency Modal -->
<div id="quickAgencyModal" class="fixed inset-0 z-[100] hidden">
    <div class="flex items-center justify-center min-h-screen p-4">
        <div class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm" onclick="closeAgencyModal()"></div>
        <div class="relative bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-2xl max-w-md w-full border border-slate-200 dark:border-slate-800">
            <h3 class="text-xl font-black text-slate-900 dark:text-white mb-4">@Localizer["Wiki_Create_Agency_Title"]</h3>
            
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-1">@Localizer["Wiki_Label_Name"]</label>
                    <input type="text" id="quickAgencyName" class="w-full px-4 py-2 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-primary/20" placeholder="@Localizer["Wiki_Placeholder_Name"]" />
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-1">@Localizer["Wiki_Label_Region"]</label>
                    <select id="quickAgencyRegion" class="w-full px-4 py-2 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg">
                        <option value="Japan">@Localizer["Region_Japan"]</option>
                        <option value="United States">@Localizer["Region_United States"]</option>
                        <option value="China">@Localizer["Region_China"]</option>
                        <option value="Vietnam">@Localizer["Region_Vietnam"]</option>
                        <option value="Indonesia">@Localizer["Region_Indonesia"]</option>
                        <option value="Global">@Localizer["Region_Global"]</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-1">@Localizer["Wiki_Label_Focus"]</label>
                    <input type="text" id="quickAgencyFocus" class="w-full px-4 py-2 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg" placeholder="@Localizer["Wiki_Label_Focus"]" />
                </div>
            </div>

            <div class="flex justify-end gap-3 mt-8">
                <button type="button" onclick="closeAgencyModal()" class="px-5 py-2 text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors">@Localizer["Wiki_Btn_Cancel"]</button>
                <button type="button" id="quickAgencySaveBtn" onclick="saveQuickAgency()" class="px-6 py-2 text-sm font-bold bg-primary text-white rounded-full hover:bg-primary-dark shadow-sm transition-all flex items-center gap-2">
                    <span>@Localizer["Wiki_Btn_Submit"]</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Cropper.js CDN -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>

    <script>
        let cropperInstance = null;
        let currentCropTarget = null; // 'avatar' or 'cover'
        let currentFileInput = null;

        function openCropper(input, target) {
            if (!input.files || !input.files[0]) return;
            currentCropTarget = target;
            currentFileInput = input;

            const reader = new FileReader();
            reader.onload = (e) => {
                const img = document.getElementById('cropperImage');
                img.src = e.target.result;

                // Set modal title & ratio hint
                if (target === 'avatar') {
                    document.getElementById('cropperTitle').textContent = 'Điều chỉnh ảnh đại diện';
                    document.getElementById('cropperSubtitle').textContent = 'Chọn vùng vuông (1:1) cho avatar';
                    document.getElementById('cropRatioText').textContent = '1 : 1';
                } else {
                    document.getElementById('cropperTitle').textContent = 'Điều chỉnh ảnh bìa';
                    document.getElementById('cropperSubtitle').textContent = 'Chọn vùng banner ngang (3:1) cho cover';
                    document.getElementById('cropRatioText').textContent = '3 : 1';
                }

                document.getElementById('cropperModal').classList.remove('hidden');

                // Destroy old instance
                if (cropperInstance) { cropperInstance.destroy(); cropperInstance = null; }

                // Init cropper after image loads
                img.onload = () => {
                    cropperInstance = new Cropper(img, {
                        aspectRatio: target === 'avatar' ? 1 : 3 / 1,
                        viewMode: 1,
                        autoCropArea: 0.85,
                        movable: true,
                        zoomable: true,
                        rotatable: true,
                        scalable: true,
                        guides: true,
                        center: true,
                        highlight: true,
                        background: true,
                    });
                };
                // If already loaded (same src won't fire onload again)
                if (img.complete) img.onload();
            };
            reader.readAsDataURL(input.files[0]);
        }

        function closeCropper() {
            document.getElementById('cropperModal').classList.add('hidden');
            if (cropperInstance) { cropperInstance.destroy(); cropperInstance = null; }
            // Reset the file input so user can re-select same file
            if (currentFileInput) currentFileInput.value = '';
        }

        function applyCrop() {
            if (!cropperInstance) return;
            const canvas = cropperInstance.getCroppedCanvas(
                currentCropTarget === 'avatar'
                    ? { width: 512, height: 512 }
                    : { width: 1500, height: 500 }
            );

            canvas.toBlob((blob) => {
                const fileName = currentCropTarget === 'avatar' ? 'avatar_cropped.jpg' : 'cover_cropped.jpg';
                const croppedFile = new File([blob], fileName, { type: 'image/jpeg' });

                // Replace file input's files
                const dt = new DataTransfer();
                dt.items.add(croppedFile);
                currentFileInput.files = dt.files;

                // Update preview
                const url = canvas.toDataURL('image/jpeg', 0.9);
                if (currentCropTarget === 'avatar') {
                    document.getElementById('avatarCropPreviewImg').src = url;
                    document.getElementById('avatarCropPreview').classList.remove('hidden');
                    document.getElementById('fileNameDisplay').textContent = '✓ ' + fileName;
                    document.getElementById('fileNameDisplay').className = 'text-xs font-bold text-emerald-500 mt-2';
                } else {
                    document.getElementById('coverCropPreviewImg').src = url;
                    document.getElementById('coverCropPreview').classList.remove('hidden');
                    document.getElementById('coverFileNameDisplay').textContent = '✓ ' + fileName;
                    document.getElementById('coverFileNameDisplay').className = 'text-xs font-bold text-emerald-500 mt-2';
                }

                document.getElementById('cropperModal').classList.add('hidden');
                if (cropperInstance) { cropperInstance.destroy(); cropperInstance = null; }
            }, 'image/jpeg', 0.9);
        }

        // --- Quick Agency Modal ---
        function openAgencyModal() {
            document.getElementById('quickAgencyModal').classList.remove('hidden');
        }

        function closeAgencyModal() {
            document.getElementById('quickAgencyModal').classList.add('hidden');
        }

        async function saveQuickAgency() {
            const name = document.getElementById('quickAgencyName').value;
            const region = document.getElementById('quickAgencyRegion').value;
            const focus = document.getElementById('quickAgencyFocus').value;
            const btn = document.getElementById('quickAgencySaveBtn');

            if (!name) {
                alert('@Localizer["Msg_EnterAgencyName"]');
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="animate-spin material-symbols-outlined text-sm">progress_activity</span> @Localizer["Msg_Saving"]';

            try {
                const response = await fetch('/Wiki/ApiCreateAgency', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({ name, region, focus })
                });

                const result = await response.json();

                if (result.success) {
                    const select = document.getElementById('agencySelect');
                    const option = new Option(result.name, result.id);
                    select.add(option);
                    select.value = result.id;
                    closeAgencyModal();
                    document.getElementById('quickAgencyName').value = '';
                    document.getElementById('quickAgencyFocus').value = '';
                } else {
                    alert('@Localizer["Msg_ErrorPrefix"]' + result.message);
                }
            } catch (error) {
                alert('@Localizer["Msg_ConnectionError"]');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<span>@Localizer["Wiki_Btn_Submit"]</span>';
            }
        }
    </script>
}
