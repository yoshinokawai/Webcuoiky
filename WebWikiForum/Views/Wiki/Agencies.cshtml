@model IEnumerable<WebWikiForum.Models.Agency>
@section Styles {
    <link rel="stylesheet" href="~/css/Agencies.css" />
}


<!-- Background Pattern -->
<div class="fixed inset-0 pointer-events-none bg-dots z-0"></div>
<div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden z-10">
<div class="layout-container flex h-full grow flex-col">

<main class="flex flex-1 justify-center py-5">
<div class="layout-content-container flex flex-col max-w-[1200px] flex-1 px-4 lg:px-10">
<div class="@@container">
<div class="@@[480px]:py-4">
<div class="flex min-h-[360px] flex-col gap-6 bg-cover bg-center bg-no-repeat @@[480px]:gap-8 rounded-xl items-center justify-center p-8 relative overflow-hidden group shadow-2xl shadow-primary/10" data-alt="Abstract purple and blue digital background pattern" style='background-image: linear-gradient(rgba(25, 17, 33, 0.7) 0%, rgba(153, 76, 230, 0.4) 100%), url("https://lh3.googleusercontent.com/aida-public/AB6AXuCW5qV6oO-FbZCzkG8lJFjCUFA6d7C5qheRi7wTIlxOTKGrkQuyvqstCrN_1m800t-hiKaZFuZ4stXuhV6PJMzlmZ0fJKIYIdRWt5Z9QpThwj6VqppNrpvKXf2pMiARX4x1zPRqb1gAlW-3CYpabGwLAjGZ0jGfxE447N6DT2-EHJbeqIIj5cPQu9SleHGnFkssI6oVK3iN4-7KBP0WcKJMhQ3a-cjb0nEPoHa44yHJ4hIo4bgFWfm2UF8xuv5DUcDI3-7GBn9jDnw");'>
<div class="flex flex-col gap-4 text-center max-w-2xl z-10">
<h1 class="text-white text-4xl font-black leading-tight tracking-[-0.033em] @@[480px]:text-6xl">
                                        @Localizer["Agencies_Title"]
                                    </h1>
<p class="text-white/90 text-base font-normal leading-relaxed @@[480px]:text-lg">
                                        @Localizer["Agencies_Hero_Desc"]
                                    </p>
</div>
<div class="flex gap-3 z-10">
<button class="flex min-w-[84px] cursor-pointer items-center justify-center rounded-lg h-12 px-6 bg-primary text-white text-base font-bold hover:brightness-110 transition-all shadow-lg shadow-primary/30">
                                        @Localizer["Agencies_Btn_Explore"]
                                    </button>
<button class="flex min-w-[84px] cursor-pointer items-center justify-center rounded-lg h-12 px-6 bg-white/10 backdrop-blur-md text-white border border-white/20 text-base font-bold hover:bg-white/20 transition-all">
                                        @Localizer["Agencies_Btn_FAQ"]
                                    </button>
</div>
</div>
</div>
</div>
<form method="get" asp-action="Agencies" class="sticky top-[73px] z-40 bg-background-light/80 dark:bg-background-dark/80 backdrop-blur-md py-4 -mx-4 px-4">
<div class="flex flex-col md:flex-row gap-3">
<label class="flex flex-col flex-1 h-12">
<div class="flex w-full flex-1 items-stretch rounded-xl h-full shadow-sm border border-slate-200/50 dark:border-slate-700/50 overflow-hidden">
<div class="text-primary flex border-none bg-white dark:bg-slate-800 items-center justify-center pl-4 border-r-0">
<span class="material-symbols-outlined">search</span>
</div>
<input name="searchTerm" value="@ViewData["SearchTerm"]" class="form-input flex w-full min-w-0 flex-1 border-none bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:ring-0 h-full placeholder:text-slate-400 px-4" placeholder="@Localizer["Agencies_Search_Placeholder"]" type="text"/>
</div>
</label>
<div class="flex gap-2 pb-2 md:pb-0">
<div class="relative">
<select name="region" onchange="this.form.submit()" class="flex h-12 items-center justify-center gap-x-2 rounded-xl bg-white dark:bg-slate-800 px-4 text-slate-700 dark:text-slate-200 border border-slate-200/50 dark:border-slate-700/50 hover:border-primary/30 transition-all shadow-sm appearance-none cursor-pointer pr-10">
<option value="all">@Localizer["Agencies_Label_Region"]</option>
<option value="Japan" selected='@(ViewData["Region"]?.ToString() == "Japan")'>Japan</option>
<option value="US" selected='@(ViewData["Region"]?.ToString() == "US")'>United States</option>
<option value="Canada" selected='@(ViewData["Region"]?.ToString() == "Canada")'>Canada</option>
</select>
<span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">expand_more</span>
</div>
<div class="relative">
<select name="focus" onchange="this.form.submit()" class="flex h-12 items-center justify-center gap-x-2 rounded-xl bg-white dark:bg-slate-800 px-4 text-slate-700 dark:text-slate-200 border border-slate-200/50 dark:border-slate-700/50 hover:border-primary/30 transition-all shadow-sm appearance-none cursor-pointer pr-10">
<option value="all">@Localizer["Agencies_Label_Focus"]</option>
<option value="Idol" selected='@(ViewData["Focus"]?.ToString() == "Idol")'>Idol</option>
<option value="Gaming" selected='@(ViewData["Focus"]?.ToString() == "Gaming")'>Gaming</option>
<option value="Variety" selected='@(ViewData["Focus"]?.ToString() == "Variety")'>Variety</option>
</select>
<span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">expand_more</span>
</div>
<button type="submit" class="flex h-12 shrink-0 items-center justify-center gap-x-2 rounded-xl bg-primary px-4 text-white shadow-lg shadow-primary/20 transition-all hover:brightness-110">
<span class="material-symbols-outlined text-lg">tune</span>
<span class="text-sm font-semibold">@Localizer["Agencies_Label_Filters"]</span>
</button>
</div>
</div>
</form><div class="flex flex-col gap-6 pt-4">
<div class="flex items-center justify-between">
<h2 class="text-slate-900 dark:text-slate-100 text-2xl font-bold tracking-tight">@Localizer["Agencies_Major_Agencies"]</h2>
<span class="text-primary text-sm font-semibold cursor-pointer hover:underline">@Localizer["Agencies_Count"]</span>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
@foreach (var agency in Model)
{
<div class="group flex flex-col bg-white dark:bg-slate-800 rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700 hover:border-primary/50 transition-all hover:shadow-xl hover:shadow-primary/5">
<div class="h-40 w-full relative overflow-hidden">
<img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" data-alt="@agency.Name visual" src="@(string.IsNullOrEmpty(agency.LogoUrl) ? "https://lh3.googleusercontent.com/aida-public/AB6AXuC8OeEiECbxBMCzmVnvYD7-RlVhP3pQwFLMcL32o8JQjsa7RHTk8yM64H6--M3hCH-IQiRwpDyx3def2PgKv_oo66RsbsgP7IX-jGRgFoiZ5lkiQIoMA1jDXrjqJpTRD-5ul8KFVNbzSH1rxRPk0pu6H4MxVxod8rpuG6Xs6EX8WpF6C2adLCMq5yDgKVbCfd35THKbnSxt5ENTTX_K1FENQF-wLcZbYHtDfpzhVUbDZ1n3HfveWw0es1HdvshAt-J5pYCU_BuxkXA" : agency.LogoUrl)"/>
<div class="absolute top-4 left-4 bg-white/90 dark:bg-slate-900/90 p-2 rounded-lg shadow-lg">
<div class="w-12 h-12 bg-slate-100 dark:bg-slate-700 rounded flex items-center justify-center font-bold text-primary">@agency.Name.Substring(0, 1)</div>
</div>
@if (User.Identity?.IsAuthenticated == true)
{
<div class="absolute top-4 right-4 z-20 flex gap-2">
<a href="/Wiki/EditAgency/@agency.Id" class="p-2 bg-indigo-500/80 hover:bg-indigo-600 text-white rounded-lg backdrop-blur-sm transition-colors shadow-lg shadow-indigo-500/20">
<span class="material-symbols-outlined text-sm">edit</span>
</a>
<form asp-action="DeleteAgency" asp-route-id="@agency.Id" method="post" onsubmit="event.preventDefault(); window.showConfirmModal({ title: 'Delete Agency', message: 'Are you sure you want to delete @agency.Name? All its VTubers will be marked as independent.', onConfirm: () => this.submit() });">
<button type="submit" class="p-2 bg-red-500/80 hover:bg-red-600 text-white rounded-lg backdrop-blur-sm transition-colors shadow-lg shadow-red-500/20">
<span class="material-symbols-outlined text-sm">delete</span>
</button>
</form>
</div>
}
</div>
<div class="p-6 flex flex-col gap-4">
<div>
<h3 class="text-xl font-bold text-slate-900 dark:text-white">@agency.Name</h3>
<p class="text-sm text-slate-500 dark:text-slate-400 mt-1 line-clamp-2">@agency.Description</p>
</div>
<div class="flex flex-wrap gap-2">
<span class="px-3 py-1 bg-primary/10 text-primary text-xs font-semibold rounded-full">@agency.Region</span>
</div>
<div class="grid grid-cols-2 gap-4 py-4 border-y border-slate-100 dark:border-slate-700">
<div>
<p class="text-[10px] text-slate-400 dark:text-slate-500 uppercase font-bold tracking-widest">@Localizer["Agencies_Label_Talents"]</p>
<p class="text-lg font-bold text-slate-800 dark:text-slate-200">@(agency.TalentCount > 0 ? agency.TalentCount + "+" : "N/A")</p>
</div>
<div>
<p class="text-[10px] text-slate-400 dark:text-slate-500 uppercase font-bold tracking-widest">@Localizer["Agencies_Label_Focus_Card"]</p>
<p class="text-lg font-bold text-slate-800 dark:text-slate-200">@(string.IsNullOrEmpty(agency.Focus) ? "N/A" : agency.Focus)</p>
</div>
</div>
<a href="/Wiki/AgencyDetails/@agency.Id" class="block w-full py-2 bg-slate-100 dark:bg-slate-700 hover:bg-primary hover:text-white transition-all rounded-lg font-bold text-sm text-center">
                        @Localizer["Agencies_Btn_ViewDirectory"]
                    </a>
</div>
</div>
}
<div class="flex flex-col items-center justify-center bg-primary/5 border-2 border-dashed border-primary/30 rounded-xl p-8 text-center gap-4 hover:bg-primary/10 transition-colors group cursor-pointer">
<div class="size-16 bg-white dark:bg-slate-800 rounded-full flex items-center justify-center shadow-md group-hover:scale-110 transition-transform">
<span class="material-symbols-outlined text-3xl text-primary">add_circle</span>
</div>
<div>
<h3 class="text-lg font-bold text-slate-900 dark:text-white">@Localizer["Agencies_Submit_Title"]</h3>
<p class="text-sm text-slate-500 dark:text-slate-400 mt-1">@Localizer["Agencies_Submit_Desc"]</p>
</div>
<a asp-action="CreateAgency" asp-controller="Wiki" class="mt-2 text-primary font-bold text-sm underline decoration-2 underline-offset-4">@Localizer["Agencies_Submit_Btn"]</a>
</div>
</div>
</div>
<div class="mt-16 bg-white dark:bg-slate-800 rounded-2xl p-8 border border-slate-200 dark:border-slate-700 relative overflow-hidden group">
<!-- Inner card pattern -->
<div class="absolute inset-0 bg-dots opacity-[0.03] pointer-events-none"></div>
<div class="max-w-3xl relative z-10">
<h2 class="text-2xl font-bold mb-4">@Localizer["Agencies_Why_Title"]</h2>
<p class="text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
                                @Localizer["Agencies_Why_Desc"]
                            </p>
<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
<div class="flex gap-3">
<span class="material-symbols-outlined text-primary">verified</span>
<div>
<p class="font-bold text-sm">@Localizer["Agencies_Support_Title"]</p>
<p class="text-xs text-slate-500">@Localizer["Agencies_Support_Desc"]</p>
</div>
</div>
<div class="flex gap-3">
<span class="material-symbols-outlined text-primary">groups</span>
<div>
<p class="font-bold text-sm">@Localizer["Agencies_Collab_Title"]</p>
<p class="text-xs text-slate-500">@Localizer["Agencies_Collab_Desc"]</p>
</div>
</div>
</div>
</div>
</div>
</div>
</main>

</div>
</div>
