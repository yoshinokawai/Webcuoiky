@model WebWikiForum.ViewModels.AgencyViewModel
@{
    ViewData["Title"] = string.Format(Localizer["Wiki_Agency_Edit_Title"].Value, Model.Name);
}

<div class="max-w-4xl mx-auto px-4 py-12">
    <div class="mb-10 flex items-center justify-between">
        <div>
            <h1 class="text-4xl font-black text-slate-900 dark:text-white tracking-tight">@Localizer["Wiki_Agency_Edit_Title_Short"]</h1>
            <p class="text-slate-500 mt-2">@string.Format(Localizer["Wiki_Agency_Edit_Subtitle"].Value, Model.Name)</p>
        </div>
        <a href="/Admin/Dashboard" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 font-bold hover:bg-slate-200 transition-all">
            <span class="material-symbols-outlined text-[20px]">arrow_back</span>
            @Localizer["Wiki_Btn_Back"]
        </a>
    </div>

    <form asp-action="EditAgency" method="post" enctype="multipart/form-data" class="space-y-8">
        <input type="hidden" name="id" value="@ViewBag.Id" />
        
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
            <!-- Left: Logo & Cover Upload -->
            <div class="md:col-span-4 space-y-4">
                <div class="relative group">
                    <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2 text-center">@Localizer["Wiki_Label_Avatar"]</label>
                    <div class="aspect-square rounded-3xl bg-slate-100 dark:bg-slate-800 border-2 border-dashed border-slate-200 dark:border-slate-700 flex flex-col items-center justify-center overflow-hidden relative">
                        @if (!string.IsNullOrEmpty(ViewBag.CurrentLogo))
                        {
                            <img id="logoPreview" src="@ViewBag.CurrentLogo" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <div id="placeholder" class="flex flex-col items-center">
                                <span class="material-symbols-outlined text-4xl text-slate-300">account_balance</span>
                                <p class="text-[10px] uppercase font-bold text-slate-400 mt-2">@Localizer["Wiki_Logo_None"]</p>
                            </div>
                            <img id="logoPreview" class="w-full h-full object-cover hidden" />
                        }
                        
                        <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer">
                            <span class="text-white font-bold text-sm">@Localizer["Wiki_Logo_Change_Text"]</span>
                        </div>
                        <input type="file" name="logoFile" id="logoInput" class="absolute inset-0 opacity-0 cursor-pointer" accept="image/*" onchange="openCropper(this, 'logo')" />
                    </div>
                    <p class="text-[10px] text-center text-slate-400 mt-3 font-bold uppercase tracking-widest">@Localizer["Wiki_Logo_Recommended_Text"]</p>
                </div>

                <div class="relative group mt-6">
                    <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2 text-center">@Localizer["Wiki_Label_CoverImage"]</label>
                    <div class="aspect-video rounded-3xl bg-slate-100 dark:bg-slate-800 border-2 border-dashed border-slate-200 dark:border-slate-700 flex flex-col items-center justify-center overflow-hidden relative">
                        @if (!string.IsNullOrEmpty(ViewBag.CurrentCover))
                        {
                            <img id="coverPreview" src="@ViewBag.CurrentCover" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <div id="coverPlaceholder" class="flex flex-col items-center">
                                <span class="material-symbols-outlined text-4xl text-slate-300">wallpaper</span>
                                <p class="text-[10px] uppercase font-bold text-slate-400 mt-2">@Localizer["Wiki_Logo_None"]</p>
                            </div>
                            <img id="coverPreview" class="w-full h-full object-cover hidden" />
                        }
                        
                        <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer">
                            <span class="text-white font-bold text-sm">@Localizer["Wiki_Logo_Change_Text"]</span>
                        </div>
                        <input type="file" name="coverImageFile" id="coverImageInput" class="absolute inset-0 opacity-0 cursor-pointer" accept="image/*" onchange="openCropper(this, 'cover')" />
                    </div>
                </div>
            </div>

            <!-- Right: Form Fields -->
            <div class="md:col-span-8 bg-white dark:bg-surface-dark rounded-3xl border border-slate-200 dark:border-slate-800 p-8 shadow-sm space-y-6">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

                <div class="grid grid-cols-1 gap-6">
                    <div>
                        <label asp-for="Name" class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2">@Localizer["Wiki_Label_Name"]</label>
                        <input asp-for="Name" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all font-bold" />
                        <span asp-validation-for="Name" class="text-red-500 text-xs mt-1"></span>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="Region" class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2">@Localizer["Wiki_Label_Region"]</label>
                            <select asp-for="Region" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all font-bold appearance-none">
                                <option value="Japan">@Localizer["Region_Japan"]</option>
                                <option value="United States">@Localizer["Region_United States"]</option>
                                <option value="China">@Localizer["Region_China"]</option>
                                <option value="Vietnam">@Localizer["Region_Vietnam"]</option>
                                <option value="Indonesia">@Localizer["Region_Indonesia"]</option>
                                <option value="Global">@Localizer["Region_Global"]</option>
                            </select>
                        </div>
                        <div>
                            <label asp-for="Focus" class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2">@Localizer["Wiki_Label_Focus"]</label>
                            <input asp-for="Focus" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all font-bold" placeholder="@Localizer["Wiki_Placeholder_Agency_Focus"]" />
                        </div>
                    </div>

                    <div>
                        <label asp-for="TalentCount" class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2">@Localizer["Wiki_Label_estimated_talents"]</label>
                        <input asp-for="TalentCount" type="number" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all font-bold" />
                    </div>

                    <div>
                        <label asp-for="Description" class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2">@Localizer["Wiki_Label_agency_bio"]</label>
                        <textarea asp-for="Description" rows="4" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all resize-none"></textarea>
                    </div>

                    <div class="pt-4 border-t border-slate-200 dark:border-slate-800">
                        <h3 class="text-sm font-black text-slate-900 dark:text-white mb-4">@Localizer["Wiki_Section_Links"]</h3>
                        <div class="grid grid-cols-1 gap-4">
                            <div>
                                <label asp-for="WebsiteUrl" class="block text-xs font-bold text-slate-500 mb-1">@Localizer["Wiki_Label_Website"]</label>
                                <input asp-for="WebsiteUrl" type="url" class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all text-sm" placeholder="https://" />
                            </div>
                            <div>
                                <label asp-for="YoutubeUrl" class="block text-xs font-bold text-slate-500 mb-1">@Localizer["Wiki_Label_Youtube"]</label>
                                <input asp-for="YoutubeUrl" type="url" class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all text-sm" placeholder="https://youtube.com/..." />
                            </div>
                            <div>
                                <label asp-for="TwitterUrl" class="block text-xs font-bold text-slate-500 mb-1">@Localizer["Wiki_Label_Twitter"]</label>
                                <input asp-for="TwitterUrl" type="url" class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all text-sm" placeholder="https://twitter.com/..." />
                            </div>
                            <div>
                                <label asp-for="IntroVideoUrl" class="block text-xs font-bold text-slate-500 mb-1">@Localizer["Wiki_Label_IntroVideo"]</label>
                                <input asp-for="IntroVideoUrl" type="url" class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all text-sm" placeholder="https://youtube.com/watch?v=..." />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="pt-4 flex gap-3">
                    <button type="submit" class="flex-1 py-4 bg-primary text-white font-black rounded-2xl shadow-lg shadow-primary/25 hover:bg-primary-dark transition-all duration-300">
                        @Localizer["Wiki_Btn_Save_Agency"]
                    </button>
                    <button type="button" @@click="window.history.back()" class="px-8 py-4 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 font-bold rounded-2xl hover:bg-slate-200 transition-all">
                                            @Localizer["Wiki_Btn_Cancel"]
                                        </button>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Image Cropper Modal -->
<div id="cropperModal" class="fixed inset-0 z-[200] hidden">
    <div class="flex items-center justify-center min-h-screen p-4">
        <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm"></div>
        <div class="relative bg-white dark:bg-slate-900 p-6 rounded-2xl shadow-2xl w-full max-w-2xl border border-slate-200 dark:border-slate-700">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <h3 id="cropperTitle" class="text-lg font-black text-slate-900 dark:text-white">Điều chỉnh ảnh</h3>
                    <p id="cropperSubtitle" class="text-xs text-slate-500 mt-0.5">Kéo để chọn vùng ảnh phù hợp</p>
                </div>
                <button type="button" onclick="closeCropper()" class="w-8 h-8 flex items-center justify-center rounded-full bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 transition-colors">
                    <span class="material-symbols-outlined text-[18px]">close</span>
                </button>
            </div>

            <div class="flex gap-2 mb-3">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-primary/10 text-primary text-xs font-bold rounded-full">
                    <span class="material-symbols-outlined text-[14px]">crop</span>
                    <span id="cropRatioText">1:1</span>
                </span>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-slate-500 text-xs rounded-full">
                    <span class="material-symbols-outlined text-[14px]">pan_zoom</span>
                    Scroll để zoom
                </span>
            </div>

            <div class="relative bg-slate-950 rounded-xl overflow-hidden" style="max-height:400px">
                <img id="cropperImage" class="max-w-full block" />
            </div>

            <div class="flex items-center gap-2 mt-4">
                <button type="button" onclick="cropperInstance && cropperInstance.rotate(-90)" class="flex-1 py-2 text-sm font-bold bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 rounded-xl transition-colors flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">rotate_left</span> -90°
                </button>
                <button type="button" onclick="cropperInstance && cropperInstance.rotate(90)" class="flex-1 py-2 text-sm font-bold bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 rounded-xl transition-colors flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">rotate_right</span> +90°
                </button>
                <button type="button" onclick="cropperInstance && cropperInstance.scaleX(cropperInstance.getData().scaleX === -1 ? 1 : -1)" class="flex-1 py-2 text-sm font-bold bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 rounded-xl transition-colors flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">flip</span> Lật ngang
                </button>
                <button type="button" onclick="cropperInstance && cropperInstance.reset()" class="flex-1 py-2 text-sm font-bold bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 rounded-xl transition-colors flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">refresh</span> Reset
                </button>
            </div>

            <div class="flex gap-3 mt-4">
                <button type="button" onclick="closeCropper()" class="flex-1 py-3 text-sm font-bold border border-slate-200 dark:border-slate-700 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">Huỷ</button>
                <button type="button" onclick="applyCrop()" class="flex-2 px-8 py-3 text-sm font-bold bg-primary text-white rounded-xl shadow-sm hover:bg-primary-dark transition-colors flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">check_circle</span>
                    Áp dụng & Xem trước
                </button>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
<script>
    let cropperInstance = null;
    let currentCropTarget = null;
    let currentFileInput = null;

    function openCropper(input, target) {
        if (!input.files || !input.files[0]) return;
        currentCropTarget = target;
        currentFileInput = input;

        const reader = new FileReader();
        reader.onload = (e) => {
            const img = document.getElementById('cropperImage');
            img.src = e.target.result;

            if (target === 'logo') {
                document.getElementById('cropperTitle').textContent = 'Điều chỉnh Logo';
                document.getElementById('cropperSubtitle').textContent = 'Chọn vùng vuông (1:1) cho logo';
                document.getElementById('cropRatioText').textContent = '1 : 1';
            } else {
                document.getElementById('cropperTitle').textContent = 'Điều chỉnh ảnh bìa';
                document.getElementById('cropperSubtitle').textContent = 'Chọn vùng banner ngang (3:1) cho cover';
                document.getElementById('cropRatioText').textContent = '3 : 1';
            }

            document.getElementById('cropperModal').classList.remove('hidden');

            if (cropperInstance) { cropperInstance.destroy(); cropperInstance = null; }

            img.onload = () => {
                cropperInstance = new Cropper(img, {
                    aspectRatio: target === 'logo' ? 1 : 3 / 1,
                    viewMode: 1,
                    autoCropArea: 0.85,
                    movable: true,
                    zoomable: true,
                    rotatable: true,
                    scalable: true,
                    guides: true,
                    center: true,
                    highlight: true,
                    background: true,
                });
            };
            if (img.complete) img.onload();
        };
        reader.readAsDataURL(input.files[0]);
    }

    function closeCropper() {
        document.getElementById('cropperModal').classList.add('hidden');
        if (cropperInstance) { cropperInstance.destroy(); cropperInstance = null; }
        if (currentFileInput) currentFileInput.value = '';
    }

    function applyCrop() {
        if (!cropperInstance) return;
        const canvas = cropperInstance.getCroppedCanvas(
            currentCropTarget === 'logo'
                ? { width: 512, height: 512 }
                : { width: 1500, height: 500 }
        );

        canvas.toBlob((blob) => {
            const fileName = currentCropTarget === 'logo' ? 'logo_cropped.jpg' : 'cover_cropped.jpg';
            const croppedFile = new File([blob], fileName, { type: 'image/jpeg' });

            const dt = new DataTransfer();
            dt.items.add(croppedFile);
            currentFileInput.files = dt.files;

            const url = canvas.toDataURL('image/jpeg', 0.9);
            if (currentCropTarget === 'logo') {
                const preview = document.getElementById('logoPreview');
                preview.src = url;
                preview.classList.remove('hidden');
                const ph = document.getElementById('placeholder');
                if (ph) ph.classList.add('hidden');
            } else {
                const preview = document.getElementById('coverPreview');
                preview.src = url;
                preview.classList.remove('hidden');
                const ph = document.getElementById('coverPlaceholder');
                if (ph) ph.classList.add('hidden');
            }

            document.getElementById('cropperModal').classList.add('hidden');
            if (cropperInstance) { cropperInstance.destroy(); cropperInstance = null; }
        }, 'image/jpeg', 0.9);
    }
</script>
