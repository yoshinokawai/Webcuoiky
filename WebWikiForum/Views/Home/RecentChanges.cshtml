@using WebWikiForum.ViewModels
@using Microsoft.Extensions.Localization
@model RecentChangesViewModel
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["RC_Title"];
}

@section Styles {
    <link rel="stylesheet" href="~/css/RecentChanges.css" />
}

<main class="max-w-7xl mx-auto px-4 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
        <div class="flex-1">
            <div class="mb-8">
                <h2 class="text-3xl font-black text-slate-900 dark:text-white mb-2">@Localizer["RC_Title"]</h2>
                <p class="text-slate-500 dark:text-slate-400">@Localizer["RC_Desc"]</p>
            </div>

            <div class="flex flex-wrap gap-2 mb-8 bg-white dark:bg-slate-800/50 p-2 rounded-xl border border-primary/10 shadow-sm" data-filter-group="rc-changes">
                <button data-filter="all" class="px-4 py-2 rounded-lg text-sm font-bold bg-primary text-white">@Localizer["RC_Filter_All"]</button>
                <button data-filter="article" class="px-4 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-primary/10">@Localizer["RC_Filter_Articles"]</button>
                <button data-filter="media" class="px-4 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-primary/10">@Localizer["RC_Filter_Media"]</button>
                <button data-filter="user" class="px-4 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-primary/10">@Localizer["RC_Filter_Users"]</button>
                <button data-filter="community" class="px-4 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-primary/10">@Localizer["RC_Filter_Community"]</button>
            </div>

            <div class="space-y-8">
                @{
                    var today = DateTime.Now.Date;
                    var yesterday = today.AddDays(-1);
                    
                    var todayActivities = Model.RecentActivities.Where(a => a.Timestamp.Date == today).ToList();
                    var yesterdayActivities = Model.RecentActivities.Where(a => a.Timestamp.Date == yesterday).ToList();
                    var olderActivities = Model.RecentActivities.Where(a => a.Timestamp.Date < yesterday).ToList();
                }

                @if (todayActivities.Any())
                {
                    <section>
                        <h3 class="flex items-center gap-2 text-xs font-black uppercase tracking-widest text-primary mb-4">
                            <span class="material-symbols-outlined text-xs">calendar_today</span> @Localizer["RC_Today"]
                        </h3>
                        <div class="space-y-4">
                            @foreach (var activity in todayActivities)
                            {
                                @await Html.PartialAsync("_ActivityItem", activity)
                            }
                        </div>
                    </section>
                }

                @if (yesterdayActivities.Any())
                {
                    <section>
                        <h3 class="flex items-center gap-2 text-xs font-black uppercase tracking-widest text-slate-400 mb-4">
                            <span class="material-symbols-outlined text-xs">history</span> @Localizer["RC_Yesterday"]
                        </h3>
                        <div class="space-y-4">
                            @foreach (var activity in yesterdayActivities)
                            {
                                @await Html.PartialAsync("_ActivityItem", activity)
                            }
                        </div>
                    </section>
                }

                @if (olderActivities.Any())
                {
                    <section>
                        <h3 class="flex items-center gap-2 text-xs font-black uppercase tracking-widest text-slate-400 mb-4">
                            <span class="material-symbols-outlined text-xs">event_note</span> @Localizer["RC_Older"]
                        </h3>
                        <div class="space-y-4">
                            @foreach (var activity in olderActivities)
                            {
                                @await Html.PartialAsync("_ActivityItem", activity)
                            }
                        </div>
                    </section>
                }
            </div>

            @if (!Model.RecentActivities.Any())
            {
                <div class="text-center py-12 bg-white dark:bg-slate-800/40 rounded-2xl border border-dashed border-slate-300 dark:border-slate-700">
                    <span class="material-symbols-outlined text-4xl text-slate-300 mb-2">history</span>
                    <p class="text-slate-500">@Localizer["RC_NoActivities"]</p>
                </div>
            }

            <div class="mt-8 flex justify-center">
                <button class="px-6 py-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl font-bold text-primary hover:bg-primary hover:text-white transition-all shadow-sm">
                    @Localizer["RC_Btn_LoadMore"]
                </button>
            </div>
        </div>

        <aside class="w-full lg:w-80 space-y-6">
            <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 border border-primary/10 shadow-sm">
                <h4 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">analytics</span> Wiki Statistics
                </h4>
                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-slate-500">@Localizer["RC_Stat_Articles"]</span>
                        <span class="font-bold">@Model.TotalArticles.ToString("N0")</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-slate-500">@Localizer["RC_Stat_Editors"]</span>
                        <span class="font-bold">@Model.TotalEditors.ToString("N0")</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-slate-500">@Localizer["RC_Stat_Media"]</span>
                        <span class="font-bold">@Model.TotalMedia.ToString("N0")</span>
                    </div>
                    <div class="flex items-center justify-between border-t border-slate-100 dark:border-slate-700 pt-4">
                        <span class="text-sm text-slate-500">@Localizer["RC_Stat_Last24h"]</span>
                        <span class="font-bold text-primary">@Model.Last24hEdits.ToString("N0")</span>
                    </div>
                </div>
            </div>

            <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 border border-primary/10 shadow-sm">
                <h4 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">leaderboard</span> @Localizer["RC_Section_Contributors"]
                </h4>
                <div class="space-y-4">
                    @foreach (var contributor in Model.TopContributors)
                    {
                        var rankColor = contributor.Rank switch {
                            1 => "border-yellow-400",
                            2 => "border-slate-300",
                            3 => "border-orange-400",
                            _ => "border-slate-200"
                        };
                        var badgeColor = contributor.Rank switch {
                            1 => "bg-yellow-400",
                            2 => "bg-slate-300",
                            3 => "bg-orange-400",
                            _ => "bg-slate-200"
                        };

                        <div class="flex items-center gap-3">
                            <div class="relative">
                                <div class="h-10 w-10 rounded-full overflow-hidden border-2 @rankColor">
                                    <img alt="Editor Avatar" class="w-full h-full object-cover" src="@contributor.AvatarUrl"/>
                                </div>
                                <span class="absolute -top-1 -right-1 @badgeColor text-[10px] font-black w-4 h-4 rounded-full flex items-center justify-center text-white">@contributor.Rank</span>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-bold truncate">@contributor.Name</p>
                                <p class="text-[10px] text-slate-400 uppercase font-black">@string.Format(Localizer["RC_Label_Edits"].Value, contributor.EditCount.ToString("N0"))</p>
                            </div>
                        </div>
                    }
                </div>
                <button class="w-full mt-6 py-2 rounded-lg text-xs font-bold text-primary bg-primary/5 hover:bg-primary/10 transition-colors">
                    @Localizer["Trans_Btn_Leaderboard"]
                </button>
            </div>
        </aside>
    </div>
</main>
