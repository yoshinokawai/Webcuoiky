                int colorIdx = 0;
                foreach (var agency in ViewBag.Agencies as List<WebWikiForum.Models.Agency>)
                {
                    var color = colors[colorIdx % colors.Length];
                    colorIdx++;

                    // Generate a 4-letter short name for the badge
                    string shortName = agency.Name.Length >= 4 ? agency.Name.Substring(0, 4).ToUpper() : agency.Name.ToUpper();
                    if (agency.Name.Contains(" "))
                    {
                        var parts = agency.Name.Split(' ');
