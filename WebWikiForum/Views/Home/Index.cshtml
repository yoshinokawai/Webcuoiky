                </h2>
</div>
                <div class="space-y-3 bg-white dark:bg-surface-dark p-4 rounded-2xl border border-slate-100 dark:border-slate-800 shadow-sm">
                    @if (ViewBag.Trending != null)
                    {
                        int rank = 1;
                        foreach (var vtuber in ViewBag.Trending as List<WebWikiForum.Models.Vtuber>)
                        {
                            <a href="/Wiki/Details/@vtuber.Id" class="flex items-center gap-3 p-2 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors cursor-pointer group">
                                <span class="text-lg font-black @(rank == 1 ? "text-primary" : "text-slate-400") w-6 text-center italic">@rank</span>
                                <div class="relative w-10 h-10 rounded-full overflow-hidden ring-2 ring-slate-100 dark:ring-slate-700">
                                    <img src="@(string.IsNullOrEmpty(vtuber.AvatarUrl) ? "/images/default-avatar.png" : vtuber.AvatarUrl)" alt="@vtuber.Name" class="w-full h-full object-cover">
                                </div>
                                <div class="flex-1 min-w-0">
                                    <h4 class="text-sm font-bold text-slate-900 dark:text-white truncate group-hover:text-primary">@vtuber.Name</h4>
                                    <p class="text-[10px] text-slate-500 font-medium uppercase tracking-wide truncate">
                                        @(vtuber.Agency != null ? vtuber.Agency.Name : Localizer["Dash_Independent"].Value)
                                    </p>
                                </div>
                                <span class="material-symbols-outlined text-green-500 text-[18px]">arrow_drop_up</span>
                            </a>
                            rank++;
