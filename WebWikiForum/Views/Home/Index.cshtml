</section>
<section>
<div class="flex items-center justify-between mb-6">
<h2 class="text-xl font-bold text-slate-900 dark:text-white flex items-center gap-2">
<span class="material-symbols-outlined text-primary">groups</span>
                @Localizer["Home_BrowseAgency"]
            </h2>
<a class="text-sm font-bold text-primary hover:text-primary-dark transition-colors" href="/Wiki/Agencies">@Localizer["Home_ViewAllAgencies"]</a>
</div>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
            @if (ViewBag.Agencies != null)
            {
                var colors = new[] { "#2fb4d6", "#ff7300", "#ff0066", "#8a2be2", "#ffaccf" };
                int colorIdx = 0;
                foreach (var agency in ViewBag.Agencies as List<WebWikiForum.Models.Agency>)
                {
                    var color = colors[colorIdx % colors.Length];
                    colorIdx++;

                    // Generate a 4-letter short name for the badge
                    string shortName = agency.Name.Length >= 4 ? agency.Name.Substring(0, 4).ToUpper() : agency.Name.ToUpper();
                    if (agency.Name.Contains(" "))
                    {
                        var parts = agency.Name.Split(' ');
                        shortName = "";
                        foreach (var p in parts.Take(2)) if (p.Length > 0) shortName += p[0];
                        if (shortName.Length < 4 && parts.Length > 0 && parts[0].Length > 1) shortName = parts[0].Substring(0, Math.Min(4, parts[0].Length)).ToUpper();
                    }

                    <a class="group flex flex-col items-center justify-center p-6 rounded-2xl bg-white dark:bg-surface-dark border border-slate-100 dark:border-slate-800 hover:border-primary hover:shadow-lg hover:shadow-primary/10 transition-all duration-300" href="/Wiki/AgencyDetails/@agency.Id">
                        <div class="w-16 h-16 mb-3 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform" style="background-color: @(color)1a;">
                            <span class="font-black text-xs" style="color: @color;">@shortName</span>
                        </div>
                        <span class="font-bold text-slate-700 dark:text-slate-200 group-hover:text-primary text-center line-clamp-1">@agency.Name</span>
                    </a>
                }
            }
            <a class="group flex flex-col items-center justify-center p-6 rounded-2xl bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-800 hover:border-primary hover:shadow-lg hover:shadow-primary/10 transition-all duration-300" href="/Home/Explore?tab=Independent">
                <div class="w-16 h-16 mb-3 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-slate-500">person_search</span>
                </div>
                <span class="font-bold text-slate-700 dark:text-slate-200 group-hover:text-primary">@Localizer["Home_Agency_Indie"]</span>
            </a>
        </div>
</section>
