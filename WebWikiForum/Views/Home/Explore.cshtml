@model IEnumerable<WebWikiForum.Models.Vtuber>
@section Styles {
    <link rel="stylesheet" href="~/css/Explore.css" />
}

<main class="max-w-[1200px] mx-auto px-4 md:px-10 py-8">
    <form method="get" asp-action="Explore" id="filterForm">
        <!-- Search & Discovery Section -->
        <section class="mb-10">
            <h2 class="text-3xl font-bold mb-6 text-slate-900 dark:text-white">@Localizer["Explore_Title"]</h2>
            <div class="bg-white dark:bg-slate-900 p-6 rounded-xl shadow-sm border border-primary/5">
                <div class="relative w-full mb-4">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-primary text-2xl">search</span>
                    <input name="searchTerm" value="@ViewData["SearchTerm"]" class="w-full h-14 bg-background-light dark:bg-slate-800 border-none rounded-xl pl-14 pr-6 text-lg focus:ring-2 focus:ring-primary/40 transition-all shadow-inner" placeholder="@Localizer["Explore_Search_Placeholder"]" type="text"/>
                </div>
                <div class="flex flex-wrap gap-2 items-center">
                    <span class="text-xs font-bold uppercase tracking-wider text-slate-400 mr-2">@Localizer["Explore_Popular"]</span>
                    <button type="submit" name="searchTerm" value="Indie" class="flex items-center gap-1.5 px-3 py-1.5 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors hover:scale-105 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary/40"><span class="material-symbols-outlined text-sm">tag</span> @Localizer["Explore_Label_Indie"]</button>
                    <button type="submit" name="searchTerm" value="3D" class="flex items-center gap-1.5 px-3 py-1.5 bg-primary/10 text-primary rounded-lg text-sm font-medium hover:bg-primary/20 transition-colors hover:scale-105 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary/40">
                        <span class="material-symbols-outlined text-sm">tag</span> @Localizer["Explore_Label_3D"]
                    </button>
                    <button type="submit" name="searchTerm" value="ASMR" class="flex items-center gap-1.5 px-3 py-1.5 bg-primary/10 text-primary rounded-lg text-sm font-medium hover:bg-primary/20 transition-colors hover:scale-105 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary/40">
                        <span class="material-symbols-outlined text-sm">tag</span> @Localizer["Explore_Label_ASMR"]
                    </button>
                    <button type="submit" name="searchTerm" value="Karaoke" class="flex items-center gap-1.5 px-3 py-1.5 bg-primary/10 text-primary rounded-lg text-sm font-medium hover:bg-primary/20 transition-colors hover:scale-105 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary/40">
                        <span class="material-symbols-outlined text-sm">tag</span> @Localizer["Explore_Label_Karaoke"]
                    </button>
                    <button type="submit" name="searchTerm" value="Debut" class="flex items-center gap-1.5 px-3 py-1.5 bg-primary/10 text-primary rounded-lg text-sm font-medium hover:bg-primary/20 transition-colors hover:scale-105 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary/40">
                        <span class="material-symbols-outlined text-sm">tag</span> @Localizer["Explore_Label_Debut"]
                    </button>
                </div>
</div>
        <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-primary/10 shadow-sm mb-8 flex flex-wrap items-center gap-6">
            <!-- Sort By -->
            <div class="flex flex-col gap-1.5 min-w-[180px]">
                <label class="text-[10px] font-bold uppercase tracking-wider text-slate-400 ml-1">@Localizer["Explore_Filter_SortBy"]</label>
                <div class="relative">
                    <select name="sortBy" onchange="this.form.submit()" class="w-full appearance-none bg-background-light dark:bg-slate-800 border-none rounded-lg py-2 pl-3 pr-10 text-sm font-medium focus:ring-2 focus:ring-primary/20 hover:bg-primary/5 focus:ring-primary transition-colors cursor-pointer">
                        <option value="Newest Debut" selected='@(ViewData["SortBy"]?.ToString() == "Newest Debut")'>@Localizer["Explore_Sort_Newest"]</option>
                        <option value="Most Popular" selected='@(ViewData["SortBy"]?.ToString() == "Most Popular")'>@Localizer["Explore_Sort_Followers"]</option>
                        <option value="A-Z" selected='@(ViewData["SortBy"]?.ToString() == "A-Z")'>@Localizer["Explore_Sort_AZ"]</option>
                        <option value="Z-A" selected='@(ViewData["SortBy"]?.ToString() == "Z-A")'>@Localizer["Explore_Sort_ZA"]</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">expand_more</span>
                </div>
            </div>
            <!-- Content Type -->
            <div class="flex flex-col gap-1.5 min-w-[200px]">
                <label class="text-[10px] font-bold uppercase tracking-wider text-slate-400 ml-1">@Localizer["Explore_Filter_ContentType"]</label>
                <div class="relative">
                    <select name="contentType" onchange="this.form.submit()" class="w-full appearance-none bg-background-light dark:bg-slate-800 border-none rounded-lg py-2 pl-3 pr-10 text-sm font-medium focus:ring-2 focus:ring-primary/20 hover:bg-primary/5 focus:ring-primary transition-colors cursor-pointer">
                        <option value="All Types" selected='@(ViewData["ContentType"]?.ToString() == "All Types")'>@Localizer["Explore_Type_All"]</option>
                        <option value="Gaming" selected='@(ViewData["ContentType"]?.ToString() == "Gaming")'>@Localizer["Explore_Type_Gaming"]</option>
                        <option value="ASMR" selected='@(ViewData["ContentType"]?.ToString() == "ASMR")'>@Localizer["Explore_Label_ASMR"]</option>
                        <option value="Music" selected='@(ViewData["ContentType"]?.ToString() == "Music")'>@Localizer["Explore_Type_Music"]</option>
                        <option value="Variety" selected='@(ViewData["ContentType"]?.ToString() == "Variety")'>@Localizer["Explore_Type_Variety"]</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">expand_more</span>
                </div>
            </div>
            <!-- Status -->
            <div class="flex flex-col gap-1.5 min-w-[160px]">
                <label class="text-[10px] font-bold uppercase tracking-wider text-slate-400 ml-1">@Localizer["Explore_Filter_Status"]</label>
                <div class="flex bg-background-light dark:bg-slate-800 rounded-lg p-1">
                    <input type="hidden" name="status" id="statusInput" value='@ViewData["Status"]' />
                    <button type="button" onclick="setStatus('Active')" class='flex-1 py-1 px-3 text-xs font-bold rounded-md shadow-sm transition-all @(ViewData["Status"]?.ToString() == "Active" ? "bg-white dark:bg-slate-700 text-primary ring-2 ring-primary/20" : "text-slate-500 hover:text-primary")'>@Localizer["Explore_Stat_Active"]</button>
                    <button type="button" onclick="setStatus('Graduated')" class='flex-1 py-1 px-3 text-xs font-bold rounded-md shadow-sm transition-all @(ViewData["Status"]?.ToString() == "Graduated" ? "bg-white dark:bg-slate-700 text-primary ring-2 ring-primary/20" : "text-slate-500 hover:text-primary")'>@Localizer["Explore_Stat_Graduated"]</button>
                    <button type="button" onclick="setStatus('Hiatus')" class='flex-1 py-1 px-3 text-xs font-bold rounded-md shadow-sm transition-all @(ViewData["Status"]?.ToString() == "Hiatus" ? "bg-white dark:bg-slate-700 text-primary ring-2 ring-primary/20" : "text-slate-500 hover:text-primary")'>@Localizer["Explore_Stat_Hiatus"]</button>
                </div>
            </div>
            <!-- Clear Filters -->
            <a asp-action="Explore" class="ml-auto self-end mb-1 text-slate-400 hover:text-primary text-xs font-bold transition-colors flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">restart_alt</span> @Localizer["Explore_Btn_Reset"]
            </a>
        </div>
        
        <script>
            function setStatus(status) {
                document.getElementById('statusInput').value = status;
                document.getElementById('filterForm').submit();
            }
            function setLanguage(lang) {
                document.getElementById('languageInput').value = lang;
                document.getElementById('filterForm').submit();
            }
            function setTab(tab) {
                document.getElementById('tabInput').value = tab;
                document.getElementById('filterForm').submit();
            }
        </script>

        <!-- Main Content Area -->
        <div class="flex flex-col lg:flex-row gap-8">
            <!-- Left Grid & Navigation -->
            <div class="flex-1 space-y-10">
                <!-- Filters & Categorized Browsing -->
                <div class="border-b border-primary/10">
                    <input type="hidden" name="tab" id="tabInput" value='@ViewData["Tab"]' />
                    <div class="flex gap-8 overflow-x-auto no-scrollbar">
                        <button type="button" onclick="setTab('All')" class='font-bold pb-4 whitespace-nowrap @(ViewData["Tab"]?.ToString() == "All" ? "border-b-2 border-primary text-primary" : "border-b-2 border-transparent text-slate-500 hover:text-primary font-medium transition-colors")'>@Localizer["Explore_Tab_All"]</button>
                        <button type="button" onclick="setTab('Agencies')" class='font-bold pb-4 whitespace-nowrap @(ViewData["Tab"]?.ToString() == "Agencies" ? "border-b-2 border-primary text-primary" : "border-b-2 border-transparent text-slate-500 hover:text-primary font-medium transition-colors")'>@Localizer["Explore_Tab_Agencies"]</button>
                        <button type="button" onclick="setTab('Generations')" class='font-bold pb-4 whitespace-nowrap @(ViewData["Tab"]?.ToString() == "Generations" ? "border-b-2 border-primary text-primary" : "border-b-2 border-transparent text-slate-500 hover:text-primary font-medium transition-colors")'>@Localizer["Explore_Tab_Gens"]</button>
                        <button type="button" onclick="setTab('Languages')" class='font-bold pb-4 whitespace-nowrap @(ViewData["Tab"]?.ToString() == "Languages" ? "border-b-2 border-primary text-primary" : "border-b-2 border-transparent text-slate-500 hover:text-primary font-medium transition-colors")'>@Localizer["Explore_Tab_Langs"]</button>
                    </div>
                </div>
                <!-- Language Selector Pill -->
                <div class="flex items-center justify-between">
                    <div class="inline-flex bg-primary/5 p-1 rounded-xl">
                        <input type="hidden" name="language" id="languageInput" value='@ViewData["Language"]' />
                        <button type="button" onclick="setLanguage('EN')" class='px-6 py-2 rounded-lg text-sm font-bold shadow-sm transition-all @(ViewData["Language"]?.ToString() == "EN" ? "bg-white dark:bg-slate-800 text-primary" : "text-slate-500 hover:text-primary")'>EN</button>
                        <button type="button" onclick="setLanguage('JP')" class='px-6 py-2 rounded-lg text-sm font-bold shadow-sm transition-all @(ViewData["Language"]?.ToString() == "JP" ? "bg-white dark:bg-slate-800 text-primary" : "text-slate-500 hover:text-primary")'>JP</button>
                        <button type="button" onclick="setLanguage('ID')" class='px-6 py-2 rounded-lg text-sm font-bold shadow-sm transition-all @(ViewData["Language"]?.ToString() == "ID" ? "bg-white dark:bg-slate-800 text-primary" : "text-slate-500 hover:text-primary")'>ID</button>
                        <button type="button" onclick="setLanguage('KR')" class='px-6 py-2 rounded-lg text-sm font-bold shadow-sm transition-all @(ViewData["Language"]?.ToString() == "KR" ? "bg-white dark:bg-slate-800 text-primary" : "text-slate-500 hover:text-primary")'>KR</button>
                    </div>
                    <div class="text-sm text-slate-500">@string.Format(Localizer["Explore_Showing_Results"].Value, Model.Count())</div>
                </div>
<!-- Trending Now Section -->
<section class="mb-10">
    <div class="flex items-center justify-between mb-4">
        <h3 class="text-xl font-bold flex items-center gap-2">
            <span class="material-symbols-outlined text-orange-500">trending_up</span> @Localizer["Explore_Trending"]
        </h3>
        <a class="text-primary text-sm font-bold hover:underline" href="/Home/TopTalent">@Localizer["Home_ViewAll"]</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        @if (ViewBag.Trending != null)
        {
            foreach (var trend in (List<WebWikiForum.Models.Vtuber>)ViewBag.Trending)
            {
                <a asp-controller="Wiki" asp-action="Details" asp-route-id="@trend.Id" class="group relative overflow-hidden rounded-xl aspect-[16/9] cursor-pointer block">
                    <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 opacity-70" src="@trend.AvatarUrl" data-alt="@trend.Name"/>
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent p-6 flex flex-col justify-end">
                        <span class="bg-primary text-white text-[10px] font-bold px-2 py-1 rounded w-fit mb-2 uppercase tracking-widest">@Localizer["Explore_News_Major"]</span>
                        <h4 class="text-white text-xl font-bold leading-tight">@trend.Name - @(trend.Agency?.Name ?? "Independent")</h4>
                        <p class="text-slate-300 text-xs line-clamp-1">@trend.Lore</p>
                    </div>
                </a>
            }
        }
    </div>
</section>
        <!-- VTuber Grid -->
        <section>
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-xl font-bold">@Localizer["Explore_Recommended"]</h3>
                <div class="flex gap-2">
                    <button type="button" class="size-8 rounded-lg border border-primary/20 flex items-center justify-center text-primary hover:bg-primary/10 hover:scale-110 active:scale-90 transition-transform focus:outline-none focus:ring-2 focus:ring-primary/40"><span class="material-symbols-outlined text-sm">filter_list</span></button>
                    <button type="button" class="size-8 rounded-lg border border-primary/20 flex items-center justify-center text-primary hover:bg-primary/10 hover:scale-110 active:scale-90 transition-transform focus:outline-none focus:ring-2 focus:ring-primary/40"><span class="material-symbols-outlined text-sm">grid_view</span></button>
                </div>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-6">
                @if (!Model.Any())
                {
                    <div class="col-span-full py-20 text-center">
                        <span class="material-symbols-outlined text-4xl text-slate-300 mb-4">search_off</span>
                        <p class="text-slate-500 font-medium">@Localizer["Explore_No_Results"]</p>
                    </div>
                }
                @foreach (var vtuber in Model)
                {
                    <a asp-controller="Wiki" asp-action="Details" asp-route-id="@vtuber.Id" class="group bg-white dark:bg-slate-900 rounded-xl overflow-hidden border border-primary/5 hover:border-primary/40 transition-all hover:shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-primary/60 focus:outline-none focus:ring-2 focus:ring-primary/40 cursor-pointer" tabindex="0">
                        <div class="aspect-square relative overflow-hidden">
                            <img class="w-full h-full object-cover transition-transform group-hover:scale-105" data-alt="@vtuber.Name avatar" src="@(string.IsNullOrEmpty(vtuber.AvatarUrl) ? "https://via.placeholder.com/400" : vtuber.AvatarUrl)"/>
                            <div class="absolute top-2 right-2 bg-black/50 backdrop-blur-md px-2 py-1 rounded text-[10px] font-bold text-white uppercase">@vtuber.Status</div>
                        </div>
                        <div class="p-4">
                            <h5 class="font-bold text-slate-900 dark:text-white mb-1">@vtuber.Name</h5>
                            <div class="flex items-center gap-1.5 mb-3">
                                <div class="size-3 rounded-full bg-primary/40"></div>
                                <span class="text-xs text-slate-500 font-medium">@(vtuber.Agency?.Name ?? Localizer["Dash_Independent"].Value)</span>
                            </div>
                            <div class="flex items-center justify-between text-[11px] text-slate-400 border-t border-slate-50 pt-3 dark:border-slate-800">
                                <span>@Localizer["Explore_Label_Debuted"]:</span>
                                <span class="font-semibold text-slate-600 dark:text-slate-300">@(vtuber.DebutDate?.ToString("MMM dd, yyyy") ?? "N/A")</span>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </section>
    </div>
<!-- Sidebar -->
<aside class="w-full lg:w-80 space-y-8">
<!-- Wiki Statistics -->
<div class="bg-white dark:bg-slate-900 rounded-xl p-6 border border-primary/5 shadow-sm">
<h4 class="text-lg font-bold mb-5 flex items-center gap-2">
<span class="material-symbols-outlined text-primary">analytics</span> @Localizer["Explore_Sidebar_Stats"]
                    </h4>
                    <div class="space-y-4">
                        <div class="flex items-center justify-between p-3 bg-background-light dark:bg-slate-800 rounded-lg">
                            <span class="text-sm font-medium text-slate-500">@Localizer["RC_Stat_Articles"]</span>
                            <span class="text-sm font-bold text-slate-900 dark:text-white">@ViewBag.TotalArticles</span>
                        </div>
                        <div class="flex items-center justify-between p-3 bg-background-light dark:bg-slate-800 rounded-lg">
                            <span class="text-sm font-medium text-slate-500">@Localizer["RC_Stat_Editors"]</span>
                            <span class="text-sm font-bold text-slate-900 dark:text-white">@ViewBag.TotalEditors</span>
                        </div>
                        <div class="flex items-center justify-between p-3 bg-background-light dark:bg-slate-800 rounded-lg">
                            <span class="text-sm font-medium text-slate-500">@Localizer["RC_Stat_Media"]</span>
                            <span class="text-sm font-bold text-slate-900 dark:text-white">45.2k</span>
                        </div>
                        <div class="flex items-center justify-between p-3 bg-background-light dark:bg-slate-800 rounded-lg">
                            <span class="text-sm font-medium text-slate-500">@Localizer["Wiki_TalentsTracked"]</span>
                            <span class="text-sm font-bold text-slate-900 dark:text-white">@ViewBag.TalentsTracked</span>
                        </div>
                    </div>
<button class="w-full mt-6 py-2.5 rounded-lg border-2 border-primary/20 text-primary font-bold text-sm hover:bg-primary hover:text-white transition-all">
                        @Localizer["Explore_Btn_Contribute"]
                    </button>
</div>
<!-- Top Contributors -->
<div class="bg-white dark:bg-slate-900 rounded-xl p-6 border border-primary/5 shadow-sm">
<h4 class="text-lg font-bold mb-5 flex items-center gap-2">
<span class="material-symbols-outlined text-yellow-500">workspace_premium</span> @Localizer["Explore_Sidebar_Contributors"]
                    </h4>
<div class="space-y-4">
