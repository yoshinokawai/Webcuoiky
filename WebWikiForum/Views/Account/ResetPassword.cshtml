@{
    Layout = "_Layout_Blank";
}
@section Styles {
    <link rel="stylesheet" href="~/css/Login.css" />
}

<div class="min-h-screen w-full flex items-center justify-center p-6 bg-slate-50 dark:bg-slate-900">
    <div class="w-full max-w-md bg-white dark:bg-slate-800 p-8 rounded-3xl shadow-2xl border border-slate-200 dark:border-slate-700">
        <div class="text-center mb-8">
            <div class="size-16 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mx-auto mb-4">
                <span class="material-symbols-outlined text-4xl">lock_reset</span>
            </div>
            <h2 class="text-3xl font-bold text-slate-900 dark:text-white">@Localizer["Account_ResetPass_Title"]</h2>
            <p class="text-slate-500 dark:text-slate-400 mt-2">@Localizer["Account_ResetPass_Desc"]</p>
        </div>

        <div asp-validation-summary="All" class="text-red-500 text-sm mb-4"></div>

        <form asp-action="ResetPassword" method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Account_ResetPass_NewPass"]</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">lock</span>
                    <input name="newPassword" id="new-password" class="w-full pl-12 pr-12 py-4 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all" 
                           placeholder="••••••••" type="password" required/>
                    <div class="absolute inset-y-0 right-0 pr-4 flex items-center cursor-pointer text-slate-400 hover:text-slate-600" onclick="const p = document.getElementById('new-password'); const span = this.querySelector('span'); if(p.type==='password'){p.type='text'; span.textContent='visibility';}else{p.type='password'; span.textContent='visibility_off';}">
                        <span class="material-symbols-outlined">visibility_off</span>
                    </div>
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Account_ResetPass_ConfirmPass"]</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">shield</span>
                    <input name="confirmPassword" id="confirm-password" class="w-full pl-12 pr-12 py-4 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all" 
                           placeholder="••••••••" type="password" required/>
                    <div class="absolute inset-y-0 right-0 pr-4 flex items-center cursor-pointer text-slate-400 hover:text-slate-600" onclick="const p = document.getElementById('confirm-password'); const span = this.querySelector('span'); if(p.type==='password'){p.type='text'; span.textContent='visibility';}else{p.type='password'; span.textContent='visibility_off';}">
                        <span class="material-symbols-outlined">visibility_off</span>
                    </div>
                </div>
            </div>

            <button class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 rounded-xl shadow-lg shadow-primary/25 transition-all transform active:scale-[0.98] flex items-center justify-center gap-2" type="submit">
                <span>@Localizer["Account_ResetPass_Btn"]</span>
                <span class="material-symbols-outlined">update</span>
            </button>
        </form>
    </div>
</div>
