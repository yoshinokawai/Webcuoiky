@{
    ViewData["Title"] = "Access Denied";
    string returnUrl = ViewData["ReturnUrl"]?.ToString() ?? "/";
}

@section Styles {
<style>
    .denied-bg {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(ellipse at 50% 0%, rgba(239, 68, 68, 0.08) 0%, transparent 65%);
        padding: 2rem;
    }

    .denied-card {
        background: var(--color-surface, #fff);
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 2rem;
        padding: 3.5rem 3rem;
        max-width: 480px;
        width: 100%;
        text-align: center;
        box-shadow: 0 25px 60px -10px rgba(239, 68, 68, 0.12), 0 8px 24px -6px rgba(0,0,0,0.08);
        animation: cardIn 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @@keyframes cardIn {
        from { opacity: 0; transform: scale(0.88) translateY(24px); }
        to   { opacity: 1; transform: scale(1)   translateY(0);      }
    }

    .denied-icon-wrap {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        background: linear-gradient(135deg, #fee2e2, #fecaca);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.75rem;
        animation: iconPulse 2.5s ease-in-out infinite;
    }

    .dark .denied-icon-wrap {
        background: linear-gradient(135deg, rgba(239,68,68,0.25), rgba(220,38,38,0.2));
    }

    @@keyframes iconPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.3); }
        50%       { box-shadow: 0 0 0 14px rgba(239,68,68,0); }
    }

    .denied-icon-wrap .material-symbols-outlined {
        font-size: 3rem;
        color: #ef4444;
    }

    .denied-code {
        display: inline-block;
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #ef4444;
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.2);
        border-radius: 999px;
        padding: 0.3rem 1rem;
        margin-bottom: 1rem;
    }

    .denied-title {
        font-size: 1.75rem;
        font-weight: 900;
        color: var(--color-text, #0f172a);
        margin-bottom: 0.75rem;
        letter-spacing: -0.02em;
        line-height: 1.2;
    }

    .denied-desc {
        color: #64748b;
        font-size: 0.95rem;
        line-height: 1.7;
        margin-bottom: 2rem;
    }

    .denied-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(239,68,68,0.15), transparent);
        margin-bottom: 2rem;
    }

    .btn-ok {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: #fff;
        font-weight: 700;
        font-size: 0.95rem;
        border: none;
        border-radius: 999px;
        padding: 0.85rem 2.5rem;
        cursor: pointer;
        box-shadow: 0 4px 18px rgba(239,68,68,0.35);
        transition: transform 0.2s, box-shadow 0.2s, filter 0.2s;
        text-decoration: none;
        width: 100%;
        margin-bottom: 0.75rem;
    }

    .btn-ok:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(239,68,68,0.4);
        filter: brightness(1.08);
        color: #fff;
    }

    .btn-ok:active { transform: scale(0.97); }

    .btn-home {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        background: transparent;
        color: #64748b;
        font-weight: 600;
        font-size: 0.875rem;
        border: 1px solid rgba(100,116,139,0.25);
        border-radius: 999px;
        padding: 0.7rem 2rem;
        cursor: pointer;
        transition: border-color 0.2s, color 0.2s, background 0.2s;
        text-decoration: none;
        width: 100%;
    }

    .btn-home:hover {
        border-color: rgba(100,116,139,0.5);
        background: rgba(100,116,139,0.06);
        color: #334155;
    }

    .dark .denied-title { color: #f1f5f9; }
    .dark .denied-desc  { color: #94a3b8; }
    .dark .btn-home     { color: #94a3b8; border-color: rgba(148,163,184,0.2); }
    .dark .btn-home:hover { color: #f1f5f9; background: rgba(148,163,184,0.08); }
</style>
}

<div class="denied-bg">
    <div class="denied-card">
        <div class="denied-icon-wrap">
            <span class="material-symbols-outlined">lock</span>
        </div>

        <span class="denied-code">@Localizer["Account_AccessDenied_Code"]</span>

        <h1 class="denied-title">@Localizer["Account_AccessDenied_Title"]</h1>

        <p class="denied-desc">
            @Localizer["Account_AccessDenied_Desc1"] <strong>Admin</strong>.<br>
            @Localizer["Account_AccessDenied_Desc2"]
        </p>

        <div class="denied-divider"></div>

        <a href="javascript:history.back()" class="btn-ok">
            <span class="material-symbols-outlined" style="font-size:1.1rem;">arrow_back</span>
            @Localizer["Account_AccessDenied_Back"]
        </a>

        <a href="/" class="btn-home">
            <span class="material-symbols-outlined" style="font-size:1rem;">home</span>
            @Localizer["Account_AccessDenied_Home"]
        </a>
    </div>
</div>
