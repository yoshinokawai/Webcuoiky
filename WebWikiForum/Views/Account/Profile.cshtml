@model WebWikiForum.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "User Profile";
}

<div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Profile Header -->
    <div class="relative mb-12">
        <!-- Cover Banner: click = lightbox; camera button = change cover -->
        <div class="h-48 w-full rounded-3xl overflow-hidden relative group" id="coverBannerClick">
            @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
            {
                <img src="@Model.CoverImageUrl" class="w-full h-full object-cover cursor-pointer hover:brightness-90 transition-all lightbox-img" data-lightbox="@Model.CoverImageUrl" alt="Cover" />
            }
            else
            {
                <div class="h-full w-full bg-gradient-to-r from-primary/20 to-primary-dark/40 cursor-pointer" data-lightbox="">
                    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-20 pointer-events-none"></div>
                </div>
            }
            <!-- Small camera button (bottom-right corner) to change cover -->
            <button type="button"
                class="absolute bottom-3 right-3 w-10 h-10 rounded-full bg-black/50 hover:bg-black/70 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all shadow-lg z-10"
                onclick="document.getElementById('coverUploadQuick').click()" title="Đổi ảnh bìa">
                <span class="material-symbols-outlined text-[20px]">add_photo_alternate</span>
            </button>
            <input type="file" id="coverUploadQuick" class="sr-only" accept="image/*" onchange="openProfileCropper(this, 'cover')" />
        </div>
        
        <div class="absolute -bottom-16 left-8 flex items-end gap-6">
            <div class="relative group">
                <div class="w-32 h-32 rounded-3xl bg-white dark:bg-surface-dark p-1.5 shadow-2xl ring-4 ring-white dark:ring-slate-900 cursor-pointer" onclick="openLightbox('@Model.AvatarUrl')">
                    <div class="w-full h-full rounded-2xl overflow-hidden bg-slate-100 dark:bg-slate-800 flex items-center justify-center border border-slate-200 dark:border-slate-700">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img src="@Model.AvatarUrl" class="w-full h-full object-cover" alt="@Model.Username" />
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-5xl text-slate-300">person</span>
                        }
                    </div>
                </div>
                <button onclick="toggleEdit()" class="absolute -right-2 -bottom-2 w-10 h-10 bg-primary text-white rounded-full shadow-lg flex items-center justify-center hover:scale-110 transition-transform ring-4 ring-white dark:ring-slate-900">
                    <span class="material-symbols-outlined text-[20px]">edit</span>
                </button>
            </div>
            
            <div class="mb-4">
                <h1 class="text-4xl font-black text-slate-900 dark:text-white tracking-tight flex items-center gap-3">
                    @Model.Username
                    @if (Model.Role == "Admin")
                    {
                        <span class="text-[10px] font-black bg-primary text-white px-2 py-0.5 rounded-full uppercase tracking-widest">Admin</span>
                    }
                </h1>
                <p class="text-slate-500 font-medium flex items-center gap-2 mt-1">
                    <span class="material-symbols-outlined text-[18px]">verified_user</span>
                    @Localizer["Account_Profile_MemberSince"] @Model.CreatedAt.ToString("MMMM yyyy")
                </p>
            </div>
        </div>
    </div>

    <!-- Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mt-24">
        
        <div class="lg:col-span-1 space-y-6">
            <div class="bg-white dark:bg-surface-dark rounded-3xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-4">@Localizer["Account_Profile_Stats"]</h3>
                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <span class="text-slate-500 text-sm">@Localizer["Account_Profile_Role"]</span>
                        <span class="font-bold text-slate-900 dark:text-white">@Model.Role</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-slate-500 text-sm">@Localizer["Account_Profile_Email"]</span>
                        <span class="font-bold text-slate-900 dark:text-white truncate max-w-[120px]">@Model.Email</span>
                    </div>
                </div>
            </div>

            <div class="bg-primary/5 p-6 rounded-3xl border border-primary/10">
                <h3 class="text-sm font-bold text-primary mb-2">@Localizer["Profile_SocialHub"]</h3>
                <p class="text-xs text-slate-500 mb-4">@Localizer["Profile_SocialHub_MyDesc"]</p>
                <div class="flex gap-2">
                    @if (!string.IsNullOrEmpty(Model.DiscordUrl))
                    {
                        <a href="@Model.DiscordUrl" target="_blank" class="size-10 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-600 hover:text-[#5865F2] hover:border-[#5865F2] transition-all">
                            <i class="fa-brands fa-discord"></i>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.TwitterUrl))
                    {
                        <a href="@Model.TwitterUrl" target="_blank" class="size-10 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-600 hover:text-[#1DA1F2] hover:border-[#1DA1F2] transition-all">
                            <i class="fa-brands fa-twitter"></i>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.YoutubeUrl))
                    {
                        <a href="@Model.YoutubeUrl" target="_blank" class="size-10 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-600 hover:text-[#FF0000] hover:border-[#FF0000] transition-all">
                            <i class="fa-brands fa-youtube"></i>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.WebsiteUrl))
                    {
                        <a href="@Model.WebsiteUrl" target="_blank" class="size-10 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-600 hover:text-primary hover:border-primary transition-all">
                            <span class="material-symbols-outlined text-sm">language</span>
                        </a>
                    }
                    <button onclick="toggleEdit()" class="size-10 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-400 border-dashed hover:text-primary hover:border-primary transition-all">
                        <span class="material-symbols-outlined text-sm">add</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-8">
            
            <!-- Bio Section -->
            <div id="view-section" class="bg-white dark:bg-surface-dark rounded-3xl p-8 border border-slate-200 dark:border-slate-800 shadow-sm relative group">
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-2xl font-bold flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">description</span>
                        @Localizer["Account_Profile_BioTitle"]
                    </h2>
                </div>
                
                @if (string.IsNullOrEmpty(Model.Bio))
                {
                    <p class="text-slate-400 italic">@Localizer["Account_Profile_NoBio"]</p>
                }
                else
                {
                    <div class="prose dark:prose-invert max-w-none text-slate-600 dark:text-slate-400 leading-relaxed whitespace-pre-wrap">@Model.Bio</div>
                }
            </div>
            
            <!-- Recent Activity Section -->
            <div class="bg-white dark:bg-surface-dark rounded-3xl p-8 border border-slate-200 dark:border-slate-800 shadow-sm">
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-2xl font-bold flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">history</span>
                        @Localizer["Profile_RecentActivity"]
                    </h2>
                </div>
                
                <div class="space-y-4">
                    @if (Model.RecentActivities != null && Model.RecentActivities.Any())
                    {
                        foreach (var activity in Model.RecentActivities)
                        {
                            <div class="p-4 bg-slate-50 dark:bg-slate-800/30 rounded-2xl border border-slate-100 dark:border-slate-800 transition-all hover:border-primary/30 group">
                                <div class="flex items-start justify-between gap-4">
                                    <div class="flex items-start gap-4">
                                        <div class="size-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center shrink-0">
                                            <span class="material-symbols-outlined text-lg">
                                                @(activity.ActivityType switch {
                                                    "Article" => "article",
                                                    "Media" => "image",
                                                    "User" => "person",
                                                    "Community" => "groups",
                                                    _ => "star"
                                                })
                                            </span>
                                        </div>
                                        <div>
                                            <div class="font-bold text-slate-800 dark:text-slate-200 group-hover:text-primary transition-colors text-base">
                                                @if (!string.IsNullOrEmpty(activity.LinkUrl))
                                                {
                                                    <a href="@activity.LinkUrl">@activity.Title</a>
                                                }
                                                else
                                                {
                                                    @activity.Title
                                                }
                                            </div>
                                            <p class="text-sm text-slate-500 mt-1 line-clamp-2">@activity.Description</p>
                                        </div>
                                    </div>
                                    <div class="text-right shrink-0">
                                        <div class="text-[10px] font-black text-primary uppercase tracking-wider bg-primary/5 px-2 py-0.5 rounded-full border border-primary/10 mb-1">@activity.Action</div>
                                        <div class="text-[10px] text-slate-400 font-bold">@activity.Timestamp.ToString("MMM dd, yyyy")</div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="bg-slate-50 dark:bg-slate-800/50 p-8 rounded-2xl border border-dashed border-slate-200 dark:border-slate-800 text-center">
                            <span class="material-symbols-outlined text-4xl text-slate-300 mb-2">history</span>
                            <p class="text-slate-400 italic text-sm">@Localizer["Profile_NoActivity"]</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Edit Form (Hidden by default) -->
            <div id="edit-section" class="hidden bg-white dark:bg-surface-dark rounded-3xl p-8 border-2 border-primary/30 shadow-2xl relative">
                <div class="flex items-center justify-between mb-8">
                    <h2 class="text-2xl font-bold flex items-center gap-2 text-primary">
                        <span class="material-symbols-outlined">edit_square</span>
                        @Localizer["Account_Profile_EditTitle"]
                    </h2>
                    <button onclick="toggleEdit()" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full text-slate-400">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>

                <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data" class="space-y-6">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Account_Profile_ChangeAvatar"]</label>
                        <div class="flex items-center gap-4">
                            <div class="relative flex-1">
                                <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-2xl cursor-pointer hover:bg-primary/5 hover:border-primary/50 transition-all group">
                                    <div class="flex flex-col items-center justify-center pt-5 pb-6">
                                        <span class="material-symbols-outlined text-3xl text-slate-400 group-hover:text-primary mb-2">cloud_upload</span>
                                        <p class="mb-1 text-sm text-slate-500 dark:text-slate-400 font-semibold">@Localizer["Account_Profile_UploadMsg"]</p>
                                        <p class="text-xs text-slate-400">@Localizer["Account_Profile_UploadDesc"]</p>
                                    </div>
                                    <input asp-for="AvatarFile" id="avatarFileProfile" class="hidden" type="file" onchange="openProfileCropper(this, 'avatar')" accept="image/*" />
                                </label>
                            </div>
                            <!-- Live Preview Box -->
                            <div id="image-preview-container" class="hidden w-32 h-32 rounded-2xl overflow-hidden border-2 border-primary shadow-lg relative group">
                                <img id="image-preview" src="#" class="w-full h-full object-cover" />
                                <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity">
                                    <span class="text-[10px] text-white font-bold uppercase">@Localizer["Account_Profile_NewPreview"]</span>
                                </div>
                            </div>
                        </div>
                        <span asp-validation-for="AvatarFile" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <!-- Cover Image Upload in Edit Form -->
                    <div>
                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Wiki_Label_CoverImage"]</label>
                        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                        {
                            <img src="@Model.CoverImageUrl" class="w-full h-16 object-cover rounded-xl mb-2 border border-slate-200 dark:border-slate-700 cursor-pointer" onclick="openLightbox('@Model.CoverImageUrl')" />
                        }
                        <label class="flex flex-col items-center justify-center w-full h-24 border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-2xl cursor-pointer hover:bg-primary/5 hover:border-primary/50 transition-all group">
                            <div class="flex flex-col items-center justify-center">
                                <span class="material-symbols-outlined text-2xl text-slate-400 group-hover:text-primary mb-1">add_photo_alternate</span>
                                <p class="text-xs text-slate-500 font-semibold">Upload Cover / Background</p>
                            </div>
                            <input asp-for="CoverImageFile" id="coverFileProfile" class="hidden" type="file" onchange="openProfileCropper(this, 'cover')" accept="image/*" />
                        </label>
                        <div id="cover-preview-container" class="hidden mt-2">
                            <img id="cover-preview" src="#" class="w-full h-20 object-cover rounded-xl border-2 border-primary" />
                            <p class="text-xs text-emerald-500 font-bold mt-1">✓ Cropped &amp; Ready</p>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">@Localizer["Account_Profile_AboutMe"]</label>
                        <textarea asp-for="Bio" rows="6" class="w-full p-4 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 focus:ring-2 focus:ring-primary outline-none transition-all resize-none" placeholder="@Localizer["Account_Profile_AboutMePH"]"></textarea>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 border-t border-slate-100 dark:border-slate-800 pt-6">
                        <div>
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2 flex items-center gap-2">
                                <i class="fa-brands fa-discord"></i> Discord URL
                            </label>
                            <input asp-for="DiscordUrl" class="w-full p-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 focus:ring-2 focus:ring-primary outline-none transition-all" placeholder="https://discord.gg/..." />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2 flex items-center gap-2">
                                <i class="fa-brands fa-twitter"></i> Twitter URL
                            </label>
                            <input asp-for="TwitterUrl" class="w-full p-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 focus:ring-2 focus:ring-primary outline-none transition-all" placeholder="https://twitter.com/..." />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2 flex items-center gap-2">
                                <i class="fa-brands fa-youtube"></i> Youtube URL
                            </label>
                            <input asp-for="YoutubeUrl" class="w-full p-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 focus:ring-2 focus:ring-primary outline-none transition-all" placeholder="https://youtube.com/..." />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2 flex items-center gap-2">
                                <span class="material-symbols-outlined text-xs">language</span> Website URL
                            </label>
                            <input asp-for="WebsiteUrl" class="w-full p-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 focus:ring-2 focus:ring-primary outline-none transition-all" placeholder="https://..." />
                        </div>
                    </div>

                    <div class="flex gap-4 pt-4">
                        <button type="submit" class="flex-1 bg-primary hover:bg-primary-dark text-white font-bold py-4 rounded-xl shadow-lg shadow-primary/20 transition-all flex items-center justify-center gap-2">
                             <span class="material-symbols-outlined uppercase text-sm">save</span>
                             @Localizer["Account_Profile_Save"]
                        </button>
                        <button type="button" onclick="toggleEdit()" class="px-8 py-4 border border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400 font-bold rounded-xl hover:bg-slate-100 dark:hover:bg-slate-800 transition-all">
                            @Localizer["Account_Profile_Cancel"]
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

<!-- Lightbox Modal -->
<div id="lightboxModal" class="fixed inset-0 z-[300] hidden" onclick="closeLightbox()">
    <div class="absolute inset-0 bg-black/90 backdrop-blur-sm"></div>
    <div class="relative flex items-center justify-center min-h-screen p-4">
        <button class="absolute top-4 right-4 w-10 h-10 bg-white/10 hover:bg-white/20 rounded-full flex items-center justify-center text-white transition-colors z-10" onclick="closeLightbox()">
            <span class="material-symbols-outlined">close</span>
        </button>
        <img id="lightboxImg" src="" class="max-w-full max-h-[90vh] rounded-2xl shadow-2xl object-contain" onclick="event.stopPropagation()" />
    </div>
</div>

<!-- Profile Cropper Modal -->
<div id="profileCropperModal" class="fixed inset-0 z-[200] hidden">
    <div class="flex items-center justify-center min-h-screen p-4">
        <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm"></div>
        <div class="relative bg-white dark:bg-slate-900 p-6 rounded-2xl shadow-2xl w-full max-w-2xl border border-slate-200 dark:border-slate-700">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <h3 id="profileCropperTitle" class="text-lg font-black text-slate-900 dark:text-white">Điều chỉnh ảnh</h3>
                    <p class="text-xs text-slate-500 mt-0.5">Kéo để chọn vùng ảnh phù hợp</p>
                </div>
                <button type="button" onclick="closeProfileCropper()" class="w-8 h-8 flex items-center justify-center rounded-full bg-slate-100 dark:bg-slate-800">
                    <span class="material-symbols-outlined text-[18px]">close</span>
                </button>
            </div>
            <div class="flex gap-2 mb-3">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-primary/10 text-primary text-xs font-bold rounded-full">
                    <span class="material-symbols-outlined text-[14px]">crop</span>
                    <span id="profileCropRatio">1:1</span>
                </span>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-slate-500 text-xs rounded-full">
                    <span class="material-symbols-outlined text-[14px]">pan_zoom</span>
                    Scroll để zoom
                </span>
            </div>
            <div class="relative bg-slate-950 rounded-xl overflow-hidden" style="max-height:380px">
                <img id="profileCropperImage" class="max-w-full block" />
            </div>
            <div class="flex items-center gap-2 mt-4">
                <button type="button" onclick="cropperInstance && cropperInstance.rotate(-90)" class="flex-1 py-2 text-sm font-bold bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 rounded-xl transition-colors flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">rotate_left</span> -90°
                </button>
                <button type="button" onclick="cropperInstance && cropperInstance.rotate(90)" class="flex-1 py-2 text-sm font-bold bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 rounded-xl transition-colors flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">rotate_right</span> +90°
                </button>
                <button type="button" onclick="cropperInstance && cropperInstance.reset()" class="flex-1 py-2 text-sm font-bold bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 rounded-xl transition-colors flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">refresh</span> Reset
                </button>
            </div>
            <div class="flex gap-3 mt-4">
                <button type="button" onclick="closeProfileCropper()" class="flex-1 py-3 text-sm font-bold border border-slate-200 dark:border-slate-700 rounded-xl hover:bg-slate-50 transition-colors">Huỷ</button>
                <button type="button" onclick="applyProfileCrop()" class="flex-2 px-8 py-3 text-sm font-bold bg-primary text-white rounded-xl hover:bg-primary-dark transition-colors flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">check_circle</span>
                    Áp dụng & Xem trước
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
    <script>

        // ===== CROPPER =====
        let cropperInstance = null;
        let profileCropTarget = null;
        let profileCropInput = null;

        function openProfileCropper(input, target) {
            if (!input.files || !input.files[0]) return;
            profileCropTarget = target;
            profileCropInput = input;
            const reader = new FileReader();
            reader.onload = (e) => {
                const img = document.getElementById('profileCropperImage');
                img.src = e.target.result;
                document.getElementById('profileCropRatio').textContent = target === 'avatar' ? '1 : 1' : '3 : 1';
                document.getElementById('profileCropperModal').classList.remove('hidden');
                if (cropperInstance) { cropperInstance.destroy(); cropperInstance = null; }
                img.onload = () => {
                    cropperInstance = new Cropper(img, {
                        aspectRatio: target === 'avatar' ? 1 : 3,
                        viewMode: 1, autoCropArea: 0.85,
                        movable: true, zoomable: true, rotatable: true, scalable: true,
                    });
                };
                if (img.complete) img.onload();
            };
            reader.readAsDataURL(input.files[0]);
        }

        function closeProfileCropper() {
            document.getElementById('profileCropperModal').classList.add('hidden');
            if (cropperInstance) { cropperInstance.destroy(); cropperInstance = null; }
            if (profileCropInput) profileCropInput.value = '';
        }

        function applyProfileCrop() {
            if (!cropperInstance) return;
            const canvas = cropperInstance.getCroppedCanvas(
                profileCropTarget === 'avatar' ? { width: 512, height: 512 } : { width: 1500, height: 500 }
            );
            canvas.toBlob((blob) => {
                const fileName = profileCropTarget === 'avatar' ? 'avatar_cropped.jpg' : 'cover_cropped.jpg';
                const file = new File([blob], fileName, { type: 'image/jpeg' });
                const dt = new DataTransfer();
                dt.items.add(file);
                profileCropInput.files = dt.files;
                const url = canvas.toDataURL('image/jpeg', 0.9);
                if (profileCropTarget === 'avatar') {
                    document.getElementById('image-preview').src = url;
                    document.getElementById('image-preview-container').classList.remove('hidden');
                } else {
                    document.getElementById('cover-preview').src = url;
                    document.getElementById('cover-preview-container').classList.remove('hidden');
                }
                document.getElementById('profileCropperModal').classList.add('hidden');
                if (cropperInstance) { cropperInstance.destroy(); cropperInstance = null; }
            }, 'image/jpeg', 0.9);
        }

        // Quick cover upload (click on banner area)
        function openCoverCropperQuick(input) {
            openProfileCropper(input, 'cover');
