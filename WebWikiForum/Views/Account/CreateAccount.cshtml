@model WebWikiForum.ViewModels.RegisterViewModel
@{ Layout = "_Layout_Blank"; }
@section Styles {
    <link rel="stylesheet" href="~/css/CreateAccount.css" />
}


<div class="flex flex-col lg:flex-row min-h-screen w-full">
<!-- Bên trái: Hình minh họa & Thống kê -->
<div class="hidden lg:flex lg:w-1/2 signup-hero-section p-12 bg-primary/10 dark:bg-primary/5">
    <div class="signup-hero-inner max-w-xl mx-auto w-full flex flex-col justify-center">
<div class="mb-8 flex items-center gap-3">
<div class="text-primary">
<span class="material-symbols-outlined text-4xl">star_half</span>
</div>
<h2 class="text-2xl font-bold tracking-tight">VTuber Wiki</h2>
</div>
<div class="signup-avatar-frame">
<img alt="Community Mascot" class="w-full h-[400px] object-cover" data-alt="Vibrant anime character illustration with purple accents" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA5-RBTYMNcSE6LQ5Vu_Rz5GU4npPsKTE0v1YCMd1C1LmaH2hqoBqzf5KK_iULDgsNF3yCEnHiq4dlTh4QDdJ81lGvDvMeasHO7dCeWs5PwoZDPk7xXbplH5M2Fj2tWGgdKCrpORBnHvQOoq1pkS4pWpat_3cqzgxCdWN8jGYTKtzKBXBo2nWVXa7YfqVku5ai4flcwDn4PnKWI6KxbFFyBMBQ1GCudMUaINhxDOE6PWYTjFmqidkgtLofgvjfgXLQ8gJXMRG7f9Js"/>
</div>
<h1 class="text-5xl font-black leading-tight mb-4 text-slate-900 dark:text-white">
                    @Html.Raw(Localizer["Account_Signup_Hero_Title"].Value.Replace("Community", "<span class='text-primary'>Community</span>"))
</h1>
<p class="text-lg text-slate-600 dark:text-slate-400 mb-8">
                    @Localizer["Account_Signup_Hero_Desc"]
                </p>
<div class="grid grid-cols-2 gap-4">
<div class="bg-white dark:bg-slate-800 p-6 rounded-xl border border-primary/20 shadow-sm">
<p class="text-slate-500 dark:text-slate-400 text-sm font-medium mb-1">@Localizer["Account_Signup_Stats_Articles"]</p>
<p class="text-3xl font-bold text-primary">10,000+</p>
</div>
<div class="bg-white dark:bg-slate-800 p-6 rounded-xl border border-primary/20 shadow-sm">
<p class="text-slate-500 dark:text-slate-400 text-sm font-medium mb-1">@Localizer["Account_Signup_Stats_Groups"]</p>
<p class="text-3xl font-bold text-primary">@Localizer["Account_Signup_Stats_Active"]</p>
</div>
</div>
</div>
</div>
<!-- Bên phải: Biểu mẫu -->
<div class="flex-1 flex flex-col justify-center items-center p-6 md:p-12 lg:p-20 signup-form-container">
<div class="w-full max-w-md">
<div class="mb-10 lg:hidden flex flex-col items-center text-center">
<div class="size-12 bg-primary rounded-xl flex items-center justify-center text-white mb-4">
<span class="material-symbols-outlined">auto_awesome</span>
</div>
<h2 class="text-3xl font-bold">@Localizer["Account_Signup_Title"]</h2>
<p class="text-slate-500 mt-2">@Localizer["Account_Signup_Subtitle"]</p>
</div>
<div class="hidden lg:block mb-8">
<h2 class="text-3xl font-bold text-slate-900 dark:text-white">@Localizer["Account_Signup_Title"]</h2>
<p class="text-slate-500 dark:text-slate-400 mt-2">@Localizer["Account_Signup_Subtitle"]</p>
</div>
<!-- Đăng nhập mạng xã hội -->
<div class="flex flex-col sm:flex-row gap-3 mb-8">
    <button class="flex-1 flex items-center justify-center gap-3 py-3 px-4 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 font-bold hover:bg-slate-50 dark:hover:bg-slate-700 hover:border-primary/30 hover:shadow-md active:scale-[0.98] transition-all duration-200 group">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18">
            <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/>
            <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/>
            <path fill="#FBBC05" d="M3.964 10.706c-.18-.54-.282-1.117-.282-1.706s.102-1.166.282-1.706V4.962H.957C.347 6.177 0 7.551 0 9s.347 2.823.957 4.038l3.007-2.332z"/>
            <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.962l3.007 2.332c.708-2.127 2.713-3.711 5.036-3.711z"/>
        </svg>
        <span class="text-sm">Google</span>
    </button>
    <button class="flex-1 flex items-center justify-center gap-3 py-3 px-4 rounded-2xl bg-[#5865F2] hover:bg-[#4752C4] border border-transparent text-white font-bold hover:shadow-lg hover:shadow-[#5865F2]/20 active:scale-[0.98] transition-all duration-200 group">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="16" viewBox="0 0 20 16">
            <path fill="currentColor" d="M17.152 1.488C15.84 0.88 14.448 0.44 12.984 0.2c-.184.328-.392.76-.536 1.112a14.072 14.072 0 0 0-4.896 0C7.408 0.96 7.2 0.528 7.016 0.2c-1.464.24-2.856.68-4.168 1.288C.192 5.28-.432 9.184.288 13.04a11.512 11.512 0 0 0 3.48 1.76c.824-1.128 1.544-2.336 2.136-3.608a7.504 7.504 0 0 1-1.2-.568c.104-.072.2-.152.296-.232a10.456 10.456 0 0 0 10.032 0c.096.08.192.16.296.232-.384.224-.784.416-1.2.568.592 1.272 1.312 2.48 2.136 3.608a11.456 11.456 0 0 0 3.488-1.76c.84-4.528-.368-8.4-2.568-11.552ZM6.704 10.92c-.992 0-1.808-.912-1.808-2.024s.792-2.024 1.808-2.024c1.024 0 1.832.912 1.808 2.024.008 1.112-.784 2.024-1.808 2.024Zm6.592 0c-.992 0-1.808-.912-1.808-2.024s.792-2.024 1.808-2.024c1.024 0 1.832.912 1.808 2.024 0 1.112-.784 2.024-1.808 2.024Z"/>
        </svg>
        <span class="text-sm">Discord</span>
    </button>
</div>
<div class="relative mb-8">
<div class="absolute inset-0 flex items-center">
<div class="w-full border-t border-slate-200 dark:border-slate-700"></div>
</div>
<div class="relative flex justify-center text-sm uppercase">
<span class="bg-background-light dark:bg-background-dark px-4 text-slate-500">@Localizer["Account_OrContinue"]</span>
</div>
</div>

<!-- Lỗi xác thực -->
<div asp-validation-summary="All" class="text-red-500 text-sm mb-4"></div>

<!-- Biểu mẫu đăng ký -->
<form asp-action="CreateAccount" asp-controller="Account" method="post" class="space-y-5">
@Html.AntiForgeryToken()

<div>
<label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5" asp-for="Username">@Localizer["Account_Signup_Label_User"]</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">person</span>
<input asp-for="Username" class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all" placeholder="v-fan-99" type="text"/>
</div>
<span asp-validation-for="Username" class="text-red-500 text-xs mt-1 block"></span>
</div>
<div>
<label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5" asp-for="Email">@Localizer["Account_Signup_Label_Email"]</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">mail</span>
<input asp-for="Email" class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all" placeholder="name@@example.com" type="email"/>
</div>
<span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
</div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
            <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5" asp-for="Password">@Localizer["Account_Signup_Label_Pass"]</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">lock</span>
                <input asp-for="Password" class="w-full pl-12 pr-12 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all" id="reg-password" placeholder="••••••••" type="password"/>
                <div class="absolute inset-y-0 right-0 pr-4 flex items-center cursor-pointer text-slate-400 hover:text-slate-600 transition-colors" onclick="const p = document.getElementById('reg-password'); const span = this.querySelector('span'); if(p.type === 'password'){ p.type = 'text'; span.textContent = 'visibility'; } else { p.type = 'password'; span.textContent = 'visibility_off'; }">
                    <span class="material-symbols-outlined text-[20px]">visibility_off</span>
                </div>
            </div>
            <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
        </div>
        <div>
            <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5" asp-for="ConfirmPassword">@Localizer["Account_Signup_Label_Confirm"]</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">shield</span>
                <input asp-for="ConfirmPassword" class="w-full pl-12 pr-12 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all" id="reg-confirm" placeholder="••••••••" type="password"/>
                <div class="absolute inset-y-0 right-0 pr-4 flex items-center cursor-pointer text-slate-400 hover:text-slate-600 transition-colors" onclick="const p = document.getElementById('reg-confirm'); const span = this.querySelector('span'); if(p.type === 'password'){ p.type = 'text'; span.textContent = 'visibility'; } else { p.type = 'password'; span.textContent = 'visibility_off'; }">
                    <span class="material-symbols-outlined text-[20px]">visibility_off</span>
                </div>
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs mt-1 block"></span>
        </div>
    </div>

    @* Role Selection *@
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
            <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5" asp-for="Role">Register As</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">badge</span>
                <select asp-for="Role" id="role-select" class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all appearance-none cursor-pointer">
                    <option value="User">Standard User</option>
                    <option value="Admin">Administrator</option>
                </select>
                <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">expand_more</span>
            </div>
        </div>
        <div id="admin-key-group" style="display: none;">
            <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5" asp-for="AdminKey">Admin Secret Key</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">key</span>
                <input asp-for="AdminKey" class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all" placeholder=""/>
            </div>
            <span asp-validation-for="AdminKey" class="text-red-500 text-xs mt-1 block"></span>
        </div>
    </div>

    @* Security PIN Section *@
    <div class="bg-primary/5 dark:bg-primary/10 p-5 rounded-2xl border border-primary/20 mb-6">
        <label class="block text-sm font-bold text-slate-800 dark:text-slate-200 mb-2" asp-for="SecurityPin">
            <span class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">security</span>
                6-Digit Security PIN
            </span>
        </label>
        <p class="text-xs text-slate-500 mb-3">Used for account recovery if you forget your password.</p>
        <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">dialpad</span>
            <input asp-for="SecurityPin" class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all font-mono tracking-[0.5em] text-center text-xl" maxlength="6" placeholder="000000" type="text" inputmode="numeric" oninput="this.value = this.value.replace(/[^0-9]/g, '');"/>
        </div>
        <span asp-validation-for="SecurityPin" class="text-red-500 text-xs mt-1 block"></span>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const roleSelect = document.getElementById('role-select');
            const adminKeyGroup = document.getElementById('admin-key-group');
            
            function toggleAdminKey() {
                if (roleSelect.value === 'Admin') {
                    adminKeyGroup.style.display = 'block';
                } else {
                    adminKeyGroup.style.display = 'none';
                }
            }
            
            roleSelect.addEventListener('change', toggleAdminKey);
            toggleAdminKey(); // Initial state
        });
    </script>
<div class="flex items-start gap-3 py-2">
<input class="mt-1 rounded text-primary focus:ring-primary h-4 w-4 border-slate-300" id="terms" type="checkbox"/>
<label class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed" for="terms">
                            @Html.Raw(string.Format(Localizer["Account_Signup_Terms"].Value, 
                                $"<a class='text-primary hover:underline' href='#'>{Localizer["Account_Signup_Terms_Link"]}</a>", 
                                $"<a class='text-primary hover:underline' href='#'>{Localizer["Account_Signup_Privacy_Link"]}</a>"))
                        </label>
</div>
<button class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 rounded-xl shadow-lg shadow-primary/25 transition-all transform active:scale-[0.98]" type="submit">
                        @Localizer["Account_Signup_Btn"]
                    </button>
</form>
<div class="mt-8 text-center">
<p class="text-slate-600 dark:text-slate-400">
                        @Localizer["Account_Signup_HasAccount"] 
                        <a class="text-primary font-bold hover:underline ml-1 inline-flex items-center gap-1" href="/Account/Login">
                            @Localizer["Account_Signup_BackToLogin"] <span class="material-symbols-outlined text-sm">arrow_forward</span>
</a>
</p>
</div>
</div>
</div>
</div>
