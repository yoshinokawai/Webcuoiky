@model WebWikiForum.Models.Discussion
@{
    ViewData["Title"] = Model.Title;
}

<div class="max-w-5xl mx-auto px-4 py-12">
    <!-- Bài đăng thảo luận chính -->
    <div class="bg-white dark:bg-surface-dark p-8 rounded-3xl shadow-sm border border-slate-200 dark:border-slate-800 mb-8 overflow-hidden relative">
        <div class="flex items-center gap-4 mb-6">
            @{
                var authorAvatars = ViewBag.AuthorAvatars as Dictionary<string, string?> ?? new Dictionary<string, string?>();
                string? authorAvatar = null;
                authorAvatars.TryGetValue(Model.Author, out authorAvatar);
            }
            @if (!string.IsNullOrEmpty(authorAvatar))
            {
                <img src="@authorAvatar" class="w-12 h-12 rounded-2xl object-cover border-2 border-primary/20" alt="@Model.Author's avatar" />
            }
            else
            {
                <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined text-3xl">person</span>
                </div>
            }
            <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                    <span class="text-sm font-black text-slate-900 dark:text-white">@Model.Author</span>
                    <span class="text-[10px] px-2 py-0.5 rounded-full bg-primary/10 text-primary font-bold uppercase">@Localizer["Forum_Badge_OP"]</span>
                </div>
                <div class="text-xs text-slate-500 font-medium">@Localizer["Forum_Topic_PostedOn"] @Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
            </div>
            <div class="flex items-center gap-4">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    bool isAuthor = User.Identity.Name == Model.Author;
                    bool isAdmin = User.IsInRole("Admin");
                    bool isEditor = ViewBag.IsAssignedEditor == true;
                    bool canManage = isAuthor || isAdmin || isEditor;

                    if (canManage)
                    {
                        <div class="flex items-center gap-2">
                            @if (isAdmin || isEditor)
                            {
                                <form asp-action="TogglePin" asp-route-id="@Model.Id" method="post" class="inline">
                                    <button type="submit" class="p-2 rounded-xl transition-all @(Model.IsPinned ? "text-primary bg-primary/10" : "text-slate-400 hover:text-primary hover:bg-primary/5")" title="Ghim bài">
                                        <span class="material-symbols-outlined text-[20px] @(Model.IsPinned ? "fill-1" : "")">push_pin</span>
                                    </button>
                                </form>
                                <form asp-action="ToggleLock" asp-route-id="@Model.Id" method="post" class="inline">
                                    <button type="submit" class="p-2 rounded-xl transition-all @(Model.IsLocked ? "text-red-500 bg-red-50" : "text-slate-400 hover:text-red-500 hover:bg-red-50")" title="Khóa bài">
                                        <span class="material-symbols-outlined text-[20px] @(Model.IsLocked ? "fill-1" : "")">lock</span>
                                    </button>
                                </form>
                            }
                            <a asp-action="EditTopic" asp-route-id="@Model.Id" class="p-2 rounded-xl text-slate-400 hover:text-primary hover:bg-primary/5 transition-all" title="@Localizer["Forum_Topic_EditReply"]">
                                <span class="material-symbols-outlined text-[20px]">edit</span>
                            </a>
                            <form asp-action="DeleteTopic" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('@Localizer["Forum_Topic_ConfirmDeleteTitle"]');" class="inline">
                                <button type="submit" class="p-2 rounded-xl text-slate-400 hover:text-red-500 hover:bg-red-50 transition-all" title="@Localizer["Forum_Topic_DeleteReply"]">
                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                </button>
                            </form>
                        </div>
                    }
                }
                <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700">
                    <span class="material-symbols-outlined text-primary text-[18px]">visibility</span>
                    <span class="text-xs font-bold text-slate-700 dark:text-slate-300">@Model.ViewCount @Localizer["Forum_Topic_Views"]</span>
                </div>
            </div>
        </div>

        <h1 class="text-3xl font-black text-slate-900 dark:text-white mb-6 leading-tight">@Model.Title</h1>
        
        <div class="prose dark:prose-invert max-w-none text-slate- main-content text-lg leading-relaxed text-slate-700 dark:text-slate-300 whitespace-pre-wrap mb-8">
            @Model.Content
        </div>

        <div class="flex items-center gap-6 pt-6 border-t border-slate-100 dark:border-slate-800/50">
            @{
                bool isPostLiked = (ViewBag.LikedDiscussionIds as List<int>)?.Contains(Model.Id) ?? false;
            }
            <button onclick="toggleLike(@Model.Id, true, this)" 
                    class="flex items-center gap-2 text-sm font-bold transition-all @(isPostLiked ? "text-primary scale-110" : "text-slate-500 hover:text-primary")">
                <span class="material-symbols-outlined text-[22px] @(isPostLiked ? "fill-1" : "")">thumb_up</span>
                <span class="like-count">@Model.LikeCount</span>
                <span>@Localizer["Forum_Topic_Likes"]</span>
            </button>
            <button onclick="document.getElementById('replyArea').focus()" class="flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-primary transition-colors">
                <span class="material-symbols-outlined text-[22px]">reply</span>
                <span>@Localizer["Forum_Topic_Reply"]</span>
            </button>
            <button class="flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-primary transition-colors ml-auto">
                <span class="material-symbols-outlined text-[22px]">share</span>
                <span>@Localizer["Forum_Topic_Share"]</span>
            </button>
        </div>
    </div>

    <!-- Các phản hồi -->
    <div class="space-y-6 mb-12">
        <h3 class="text-xl font-black text-slate-900 dark:text-white flex items-center gap-3 ml-2">
            <span class="material-symbols-outlined text-primary">chat_bubble</span>
            @Localizer["Forum_Topic_RepliesTitle"] (@Model.Replies.Count)
        </h3>

        @if (Model.Replies != null && Model.Replies.Any())
        {
            @foreach (var reply in Model.Replies.OrderBy(r => r.CreatedAt))
            {
                <div class="bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 group" id="reply-container-@reply.Id">
                    <div class="flex items-center gap-4 mb-4">
                        @{
                            string? replyAvatar = null;
                            authorAvatars.TryGetValue(reply.Author, out replyAvatar);
                        }
                        @if (!string.IsNullOrEmpty(replyAvatar))
                        {
                            <img src="@replyAvatar" class="w-10 h-10 rounded-xl object-cover border border-slate-200 dark:border-slate-700" alt="@reply.Author's avatar" />
                        }
                        else
                        {
                            <div class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400">
                                <span class="material-symbols-outlined text-2xl">person</span>
                            </div>
                        }
                        <div class="flex-1 min-w-0">
                            <div class="text-sm font-black text-slate-900 dark:text-white mb-0.5">@reply.Author</div>
                            <div class="text-[10px] text-slate-400 font-medium">@reply.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                        
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            bool isReplyAuthor = User.Identity.Name == reply.Author;
                            bool isAdmin = User.IsInRole("Admin");
                            bool isEditor = ViewBag.IsAssignedEditor == true;
                            if (isReplyAuthor || isAdmin || isEditor)
                            {
                                <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button onclick="enableEditReply(@reply.Id)" class="p-1.5 rounded-lg text-slate-400 hover:text-primary hover:bg-primary/5 transition-all">
                                        <span class="material-symbols-outlined text-[18px]">edit</span>
                                    </button>
                                    <form asp-action="DeleteReply" asp-route-id="@reply.Id" method="post" onsubmit="return confirm('@Localizer["Forum_Topic_DeleteConfirmReply"]');" class="inline">
                                        <button type="submit" class="p-1.5 rounded-lg text-slate-400 hover:text-red-500 hover:bg-red-50 transition-all">
                                            <span class="material-symbols-outlined text-[18px]">delete</span>
                                        </button>
                                    </form>
                                </div>
                            }
                        }
                    </div>

                    <div id="reply-content-@reply.Id" class="text-slate-700 dark:text-slate-300 whitespace-pre-wrap leading-relaxed mb-4">
                        @reply.Content
                    </div>

                    <div id="reply-edit-box-@reply.Id" class="hidden mb-4">
                        <textarea id="reply-textarea-@reply.Id" class="w-full px-4 py-3 rounded-xl border border-primary/30 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary/20 outline-none transition-all mb-2">@reply.Content</textarea>
                        <div class="flex justify-end gap-2">
                            <button onclick="cancelEditReply(@reply.Id)" class="px-4 py-1.5 text-xs font-bold text-slate-500 hover:bg-slate-100 rounded-lg transition-all">@Localizer["Forum_Topic_BtnCancel"]</button>
                            <button onclick="saveEditReply(@reply.Id)" class="px-4 py-1.5 text-xs font-bold bg-primary text-white rounded-lg hover:bg-primary-dark transition-all">@Localizer["Forum_Topic_BtnSave"]</button>
                        </div>
                    </div>

                    <div class="flex items-center gap-4 border-t border-slate-50 dark:border-slate-800/50 pt-3">
                        @{
                            bool isReplyLiked = (ViewBag.LikedReplyIds as List<int>)?.Contains(reply.Id) ?? false;
                        }
                        <button onclick="toggleLike(@reply.Id, false, this)" 
                                class="flex items-center gap-2 text-xs font-bold transition-all @(isReplyLiked ? "text-primary" : "text-slate-400 hover:text-primary")">
                            <span class="material-symbols-outlined text-[18px] @(isReplyLiked ? "fill-1" : "")">thumb_up</span>
                            <span class="like-count">@reply.LikeCount</span>
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="p-12 text-center bg-slate-50/50 dark:bg-slate-800/20 rounded-3xl border border-dashed border-slate-200 dark:border-slate-700">
                <p class="text-slate-500 italic">@Localizer["Forum_Topic_NoReplies"]</p>
            </div>
        }
    </div>

    <!-- Biểu mẫu trả lời -->
    <div class="bg-white dark:bg-surface-dark p-8 rounded-3xl shadow-sm border border-slate-200 dark:border-slate-800 sticky bottom-8 transform translate-z-10 z-20 ring-4 ring-background-light dark:ring-background-dark">
        <h4 class="text-lg font-black text-slate-900 dark:text-white mb-4">@Localizer["Forum_Topic_PostReplyTitle"]</h4>
        
        @if (Model.IsLocked)
        {
            <div class="p-6 text-center bg-red-50 dark:bg-red-900/20 rounded-2xl border border-red-200 dark:border-red-800/50">
                <span class="material-symbols-outlined text-red-500 text-3xl mb-2">lock</span>
                <h4 class="text-lg font-bold text-red-600 dark:text-red-400 mb-1">Chủ đề đã bị khóa</h4>
                <p class="text-red-500/80 text-sm">Bạn không thể thêm phản hồi mới vào chủ đề này.</p>
            </div>
        }
        else if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-action="PostReply" method="post" class="space-y-4">
                <input type="hidden" name="discussionId" value="@Model.Id" />
                <textarea id="replyArea" name="content" rows="4" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary/20 outline-none transition-all placeholder-slate-400" placeholder="@Localizer["Forum_Topic_PlaceholderReply"]" required></textarea>
                <div class="flex justify-end">
                    <button type="submit" class="px-8 py-2.5 bg-primary text-white font-bold rounded-xl hover:bg-primary-dark shadow-lg shadow-primary/20 transition-all active:scale-95">@Localizer["Forum_Topic_BtnPostReply"]</button>
                </div>
            </form>
        }
        else
        {
            <div class="p-6 text-center bg-slate-50 dark:bg-slate-800/50 rounded-2xl border border-slate-200 dark:border-slate-700">
                <p class="text-slate-600 dark:text-slate-400 mb-4">@Localizer["Forum_Topic_LoginToReply"]</p>
                <a href="/Account/Login?returnUrl=@Context.Request.Path" class="inline-block px-8 py-2 bg-primary text-white font-bold rounded-xl hover:bg-primary-dark transition-all shadow-lg shadow-primary/10">@Localizer["Forum_Topic_LogIn"]</a>
            </div>
        }
    </div>
</div>

<style>
    .material-symbols-outlined.fill-1 {
        font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
</style>

<script>
    async function toggleLike(id, isTopic, btn) {
        if (!@(User.Identity?.IsAuthenticated == true ? "true" : "false")) {
            window.location.href = '/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
            return;
        }

        const url = isTopic ? `/Forum/ToggleLikeDiscussion/${id}` : `/Forum/ToggleLikeReply/${id}`;
        
        try {
            const response = await fetch(url, { method: 'POST' });
            const data = await response.json();
            
            if (data.success) {
                const countSpan = btn.querySelector('.like-count');
                const icon = btn.querySelector('.material-symbols-outlined');
                
                countSpan.textContent = data.likeCount;
                
                if (data.isLiked) {
                    btn.classList.add('text-primary');
                    btn.classList.remove('text-slate-500', 'text-slate-400');
                    icon.classList.add('fill-1');
                    btn.classList.add('scale-110');
                    setTimeout(() => btn.classList.remove('scale-110'), 200);
                } else {
                    btn.classList.remove('text-primary');
                    btn.classList.add(isTopic ? 'text-slate-500' : 'text-slate-400');
                    icon.classList.remove('fill-1');
                }
            }
        } catch (error) {
            console.error('Like error:', error);
        }
    }

    function enableEditReply(id) {
        document.getElementById(`reply-content-${id}`).classList.add('hidden');
        document.getElementById(`reply-edit-box-${id}`).classList.remove('hidden');
    }

    function cancelEditReply(id) {
        document.getElementById(`reply-content-${id}`).classList.remove('hidden');
        document.getElementById(`reply-edit-box-${id}`).classList.add('hidden');
    }

    async function saveEditReply(id) {
        const content = document.getElementById(`reply-textarea-${id}`).value;
        if (!content.trim()) return;

        try {
            const formData = new FormData();
            formData.append('id', id);
            formData.append('content', content);

            const response = await fetch('/Forum/EditReply', {
                method: 'POST',
                body: formData
            });
            
            const data = await response.json();
            if (data.success) {
                document.getElementById(`reply-content-${id}`).textContent = data.content;
                cancelEditReply(id);
            }
        } catch (error) {
            console.error('Edit error:', error);
            alert('Failed to save changes.');
        }
    }
</script>
