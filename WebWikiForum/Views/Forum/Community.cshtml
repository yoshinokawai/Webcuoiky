<div class="size-10 rounded-full bg-primary/10 flex items-center justify-center text-[10px] font-bold text-primary">
                                    +42
                                </div>
</div>
</div>
<div class="bg-gradient-to-br from-primary to-purple-700 p-6 rounded-xl text-white">
<h4 class="font-bold mb-2">@Localizer["Forum_Community_ContributorTitle"]</h4>
<p class="text-sm opacity-90 mb-4">@Localizer["Forum_Community_ContributorDesc"]</p>
<button class="w-full py-2 bg-white text-primary rounded font-bold text-sm hover:bg-slate-100 transition-colors">@Localizer["Forum_Community_ApplyMod"]</button>
</div>
</aside>
</div>
</main>

</div>
</div>
