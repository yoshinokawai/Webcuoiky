@section Styles {
    <link rel="stylesheet" href="~/css/Guidelines.css" />
}


<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">

<main class="flex-1 bg-pattern">
<div class="max-w-7xl mx-auto px-4 md:px-10 py-12">
<div class="flex flex-col gap-4 mb-12">
<h1 class="text-5xl font-black text-slate-900 tracking-tight">@Localizer["Guide_Title"]</h1>
<p class="text-lg text-slate-600 max-w-2xl leading-relaxed">
                    @Localizer["Guide_Intro"]
                </p>
</div>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
<div class="lg:col-span-8 space-y-12">
<section class="bg-white p-8 rounded-xl shadow-sm border border-primary/5" id="conduct">
<div class="flex items-center gap-3 mb-6">
<span class="material-symbols-outlined text-primary text-3xl">gavel</span>
<h2 class="text-2xl font-bold text-slate-900">@Localizer["Guide_Conduct_Title"]</h2>
</div>
<div class="space-y-4">
<div class="flex gap-4 p-4 rounded-lg bg-primary/5 border-l-4 border-primary">
<span class="material-symbols-outlined text-primary">check_circle</span>
<p class="text-slate-700"><strong>@Localizer["Guide_Respect_Title"]:</strong> @Localizer["Guide_Respect_Desc"]</p>
</div>
<div class="flex gap-4 p-4 rounded-lg bg-primary/5 border-l-4 border-primary">
<span class="material-symbols-outlined text-primary">check_circle</span>
<p class="text-slate-700"><strong>@Localizer["Guide_Inclusivity_Title"]:</strong> @Localizer["Guide_Inclusivity_Desc"]</p>
</div>
<div class="flex gap-4 p-4 rounded-lg bg-primary/5 border-l-4 border-primary">
<span class="material-symbols-outlined text-primary">check_circle</span>
<p class="text-slate-700"><strong>@Localizer["Guide_ZeroTolerance_Title"]:</strong> @Localizer["Guide_ZeroTolerance_Desc"]</p>
</div>
</div>
</section>
<section class="bg-white p-8 rounded-xl shadow-sm border border-primary/5" id="editing">
<div class="flex items-center gap-3 mb-6">
<span class="material-symbols-outlined text-primary text-3xl">edit_note</span>
<h2 class="text-2xl font-bold text-slate-900">@Localizer["Guide_Standards_Title"]</h2>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
<div class="space-y-2">
<h3 class="font-bold text-slate-800 flex items-center gap-2">
<span class="material-symbols-outlined text-sm">link</span> @Localizer["Guide_Standards_Sourcing_Title"]
                                </h3>
<p class="text-sm text-slate-600">@Localizer["Guide_Standards_Sourcing_Desc"]</p>
</div>
<div class="space-y-2">
<h3 class="font-bold text-slate-800 flex items-center gap-2">
<span class="material-symbols-outlined text-sm">balance</span> @Localizer["Guide_Standards_Neutral_Title"]
                                </h3>
<p class="text-sm text-slate-600">@Localizer["Guide_Standards_Neutral_Desc"]</p>
</div>
<div class="space-y-2">
<h3 class="font-bold text-slate-800 flex items-center gap-2">
<span class="material-symbols-outlined text-sm">format_paint</span> @Localizer["Guide_Standards_Format_Title"]
                                </h3>
<p class="text-sm text-slate-600">@Localizer["Guide_Standards_Format_Desc"]</p>
</div>
<div class="space-y-2">
<h3 class="font-bold text-slate-800 flex items-center gap-2">
<span class="material-symbols-outlined text-sm">translate</span> @Localizer["Guide_Standards_Loc_Title"]
                                </h3>
<p class="text-sm text-slate-600">@Localizer["Guide_Standards_Loc_Desc"]</p>
</div>
</div>
</section>
<section class="bg-white p-8 rounded-xl shadow-sm border border-primary/5" id="policy">
<div class="flex items-center gap-3 mb-6">
<span class="material-symbols-outlined text-primary text-3xl">rule</span>
<h2 class="text-2xl font-bold text-slate-900">@Localizer["Guide_Policy_Title"]</h2>
</div>
<p class="text-slate-600 mb-6">@Localizer["Guide_Policy_Intro"]</p>
<ul class="space-y-3">
<li class="flex items-start gap-3 text-slate-700">
<span class="material-symbols-outlined text-primary text-[20px] mt-1">fiber_manual_record</span>
<span>@Html.Raw(Localizer["Guide_Policy_Agencies"])</span>
</li>
<li class="flex items-start gap-3 text-slate-700">
<span class="material-symbols-outlined text-primary text-[20px] mt-1">fiber_manual_record</span>
<span>@Html.Raw(Localizer["Guide_Policy_Independents"])</span>
</li>
<li class="flex items-start gap-3 text-slate-700">
<span class="material-symbols-outlined text-primary text-[20px] mt-1">fiber_manual_record</span>
<span>@Html.Raw(Localizer["Guide_Policy_Privacy"])</span>
</li>
</ul>
</section>
<section class="bg-white p-8 rounded-xl shadow-sm border border-primary/5" id="moderation">
<div class="flex items-center gap-3 mb-6">
<span class="material-symbols-outlined text-primary text-3xl">shield_person</span>
<h2 class="text-2xl font-bold text-slate-900">@Localizer["Guide_Mod_Title"]</h2>
</div>
<p class="text-slate-600 leading-relaxed">
                            @Localizer["Guide_Mod_Intro"]
                        </p>
<div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-4">
<div class="p-4 bg-slate-50 rounded-lg text-center">
<p class="font-bold text-slate-900">@Localizer["Guide_Mod_Step1_Title"]</p>
<p class="text-xs text-slate-500">@Localizer["Guide_Mod_Step1_Desc"]</p>
</div>
<div class="p-4 bg-slate-50 rounded-lg text-center">
<p class="font-bold text-slate-900">@Localizer["Guide_Mod_Step2_Title"]</p>
<p class="text-xs text-slate-500">@Localizer["Guide_Mod_Step2_Desc"]</p>
</div>
<div class="p-4 bg-slate-50 rounded-lg text-center">
<p class="font-bold text-slate-900">@Localizer["Guide_Mod_Step3_Title"]</p>
<p class="text-xs text-slate-500">@Localizer["Guide_Mod_Step3_Desc"]</p>
</div>
</div>
</section>
</div>
<div class="lg:col-span-4 space-y-6">
<div class="bg-white p-6 rounded-xl shadow-sm border border-primary/5 sticky top-24">
<h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
<span class="material-symbols-outlined text-primary">bolt</span> @Localizer["Guide_Links_Title"]
                        </h3>
<div class="flex flex-col gap-2">
<a asp-controller="Home" asp-action="RecentChanges" class="flex items-center justify-between p-3 rounded-lg hover:bg-primary/5 text-slate-700 transition-colors group">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-primary/60 group-hover:text-primary">history</span>
<span class="font-medium">@Localizer["Guide_Links_Recent"]</span>
</div>
<span class="material-symbols-outlined text-sm text-slate-400">chevron_right</span>
</a>
<a asp-controller="Forum" asp-action="WikiForum" class="flex items-center justify-between p-3 rounded-lg hover:bg-primary/5 text-slate-700 transition-colors group">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-primary/60 group-hover:text-primary">forum</span>
<span class="font-medium">@Localizer["Guide_Links_Forum"]</span>
</div>
<span class="material-symbols-outlined text-sm text-slate-400">chevron_right</span>
</a>
<a asp-controller="Help" asp-action="HelpCenter" class="flex items-center justify-between p-3 rounded-lg hover:bg-primary/5 text-slate-700 transition-colors group">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-primary/60 group-hover:text-primary">mail</span>
<span class="font-medium">@Localizer["Guide_Links_Contact"]</span>
</div>
<span class="material-symbols-outlined text-sm text-slate-400">chevron_right</span>
</a>
<a asp-controller="Editor" asp-action="EditorHub" class="flex items-center justify-between p-3 rounded-lg hover:bg-primary/5 text-slate-700 transition-colors group">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-primary/60 group-hover:text-primary">help</span>
<span class="font-medium">@Localizer["Guide_Links_FAQ"]</span>
</div>
<span class="material-symbols-outlined text-sm text-slate-400">chevron_right</span>
</a>
</div>
<div class="mt-8 p-4 bg-primary rounded-xl text-white">
<p class="text-sm font-bold mb-2">@Localizer["Guide_Contribute_Title"]</p>
<p class="text-xs opacity-90 mb-4">@Localizer["Guide_Contribute_Desc"]</p>
<a asp-controller="Account" asp-action="CreateAccount" class="block w-full py-2 bg-white text-primary rounded-lg font-bold text-sm hover:bg-opacity-90 transition-all text-center">@Localizer["Guide_Contribute_Btn"]</a>
</div>
</div>
</div>
</div>
</div>
</main>

</div>
