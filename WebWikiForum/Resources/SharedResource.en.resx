  <data name="Discord_Feature_Hubs_Title" xml:space="preserve"><value>Agency Hubs</value></data>
  <data name="Discord_Feature_Hubs_Desc" xml:space="preserve"><value>Dedicated channels for Hololive, Nijisanji, VShojo, Phase Connect, and the independent VTuber scene.</value></data>
